<% const isRtl = currentLang === 'ar'; %>
<!DOCTYPE html>
<html lang="<%= currentLang === 'ar' ? 'ar' : 'en' %>" dir="<%= currentLang === 'ar' ? 'rtl' : 'ltr' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sokrat Analytics - Login</title>
    <link rel="icon" type="image/png" href="/favicon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <style>
        :root {
            --bg-primary: #050507;
            --bg-secondary: #0b0b0e;
            --accent-color: #cc090c;
            --accent-hover: #e62629;
            --accent-dark: #7b0002;
        }
        body {
            font-family: 'Plus Jakarta Sans', 'Cairo', sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            margin: 0;
            padding: 0;
            overflow-x: hidden;
        }
        
        /* Logo breathing and spinning animation */
        @keyframes float-breathing {
            0%, 100% { transform: translateY(0) scale(1); }
            50% { transform: translateY(-6px) scale(1.04); }
        }
        @keyframes spin-clockwise {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
        .logo-float-animation {
            animation: float-breathing 4s ease-in-out infinite;
        }
        .logo-outer-spin {
            animation: spin-clockwise 25s linear infinite;
        }

        .login-card {
            background: rgba(11, 11, 14, 0.45);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 1.5rem;
            padding: 2.25rem 2rem;
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.4);
        }
        
        /* Language specific overrides */
        [dir="rtl"] {
            font-family: 'Cairo', sans-serif;
        }
        [dir="rtl"] .border-r {
            border-right-width: 0px;
            border-left-width: 1px;
        }
    </style>
</head>
<body class="bg-white">
    <!-- Top Half: Brand & Animated Logo -->
    <div class="h-[50vh] min-h-[340px] bg-white flex flex-col items-center justify-center relative shrink-0 select-none">
        <!-- Animated Brand Logo Container -->
        <div class="flex flex-col items-center gap-4">
            <!-- Inner glowing circle frame -->
            <div class="w-36 h-36 rounded-full bg-[#0a0a0d] shadow-2xl flex items-center justify-center">
                <!-- The actual brand logo image, floating/breathing -->
                <img src="/logo_dark.png" alt="Sokrat Analytics" class="w-28 h-28 object-contain logo-float-animation" style="filter: drop-shadow(0 2px 4px rgba(0,0,0,0.35));">
            </div>
            
            <!-- Brand Title -->
            <h1 class="text-3xl font-extrabold tracking-[0.15em] text-[#121215] uppercase mt-2">
                Sokrat <span class="text-[var(--accent-color)]">Analytics</span>
            </h1>
        </div>
        
        <!-- Downward triangle arrow dividing the sections -->
        <div class="absolute bottom-0 left-1/2 -translate-x-1/2 translate-y-px z-20">
            <div class="w-8 h-4 bg-white" style="clip-path: polygon(0 0, 100% 0, 50% 100%);"></div>
        </div>
    </div>

    <!-- Bottom Half: Deep crimson gradient and login container -->
    <div class="flex-1 bg-gradient-to-b from-[#cc090c] to-[#7b0002] flex items-center justify-center p-6 relative">
        <div class="w-full max-w-[420px] flex flex-col items-center">
            
            <% if (typeof error !== 'undefined' && error) { %>
                <div class="w-full mb-4 text-center text-xs font-bold text-red-600 bg-red-50 border border-red-200 rounded-xl px-4 py-3 shadow-sm">
                    <%= error %>
                </div>
            <% } %>

            <% if (typeof reset !== 'undefined' && reset === 'success') { %>
                <div class="w-full bg-green-50 border border-green-200 text-green-800 rounded-xl px-4 py-3 text-sm text-center mb-4 font-semibold shadow-sm">
                    <%= currentLang === 'ar' ? 'تم إعادة تعيين كلمة المرور بنجاح' : 'Password reset successful. Please login.' %>
                </div>
            <% } %>

            <!-- Form White Card Container -->
            <div class="bg-white rounded-2xl shadow-2xl w-full p-8 border border-gray-100 flex flex-col">
                <form method="POST" action="/login" class="space-y-4">
                    <input type="hidden" name="redirect" value="<%= typeof redirect !== 'undefined' ? redirect : '/' %>">
                    
                    <!-- Username -->
                    <div class="space-y-1.5">
                        <label class="block text-sm font-semibold text-gray-700 mb-2 uppercase tracking-wide <%= isRtl ? 'text-right' : 'text-left' %>">
                            <%= currentLang === 'ar' ? 'اسم المستخدم' : 'Username' %>
                        </label>
                        <div class="relative flex items-center bg-gray-50 border border-gray-300 rounded-lg focus-within:ring-2 focus-within:ring-red-600 focus-within:border-transparent transition-all overflow-hidden">
                            <div class="w-11 h-11 flex items-center justify-center text-gray-400 border-e border-gray-300 shrink-0">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                                    <circle cx="12" cy="7" r="4"></circle>
                                </svg>
                            </div>
                            <input type="text" name="username" placeholder="admin" required autocomplete="username" autofocus class="w-full h-11 px-4 bg-transparent border-0 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-0 text-[14px]">
                        </div>
                    </div>

                    <!-- Password -->
                    <div class="space-y-1.5">
                        <label class="block text-sm font-semibold text-gray-700 mb-2 uppercase tracking-wide <%= isRtl ? 'text-right' : 'text-left' %>">
                            <%= currentLang === 'ar' ? 'كلمة المرور' : 'Password' %>
                        </label>
                        <div class="relative flex items-center bg-gray-50 border border-gray-300 rounded-lg focus-within:ring-2 focus-within:ring-red-600 focus-within:border-transparent transition-all overflow-hidden">
                            <div class="w-11 h-11 flex items-center justify-center text-gray-400 border-e border-gray-300 shrink-0">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M21 2l-2 2m-7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"></path>
                                </svg>
                            </div>
                            <input type="password" name="password" placeholder="••••••" required autocomplete="current-password" class="w-full h-11 px-4 bg-transparent border-0 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-0 text-[14px]">
                        </div>
                    </div>

                    <!-- Submit Button -->
                    <button type="submit" class="w-full bg-red-600 hover:bg-red-700 text-white font-bold py-3 px-4 rounded-lg transition-colors flex justify-center items-center gap-2 mt-6 cursor-pointer shadow-sm">
                        <span><%= currentLang === 'ar' ? 'تسجيل الدخول' : 'Sign In' %></span>
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="9 18 15 12 9 6"></polyline>
                        </svg>
                    </button>
                </form>

                <!-- Forgot Password Link -->
                <div class="mt-5 text-center">
                    <a href="#" onclick="showForgot()" class="text-sm text-red-600 hover:text-red-800 hover:underline transition-colors cursor-pointer">
                        <%= currentLang === 'ar' ? 'نسيت كلمة المرور؟' : 'Forgot Password?' %>
                    </a>
                </div>

                <!-- Forgot Password Form Block -->
                <div id="forgotForm" class="mt-5 hidden pt-4 border-t border-gray-200">
                    <p class="text-xs text-gray-500 mb-3 <%= isRtl ? 'text-right' : 'text-left' %>">
                        <%= currentLang === 'ar' ? 'أدخل اسم المستخدم والبريد الإلكتروني' : 'Enter your username and email' %>
                    </p>
                    <div class="flex flex-col gap-2.5">
                        <input type="text" id="forgotUsername" placeholder="<%= currentLang === 'ar' ? 'اسم المستخدم' : 'Username' %>" class="w-full h-10 px-4 rounded-lg bg-gray-50 border border-gray-300 text-gray-900 placeholder-gray-400 text-xs focus:outline-none focus:ring-2 focus:ring-red-600 focus:border-transparent transition-all">
                        <input type="email" id="forgotEmail" placeholder="<%= currentLang === 'ar' ? 'البريد الإلكتروني' : 'email@example.com' %>" class="w-full h-10 px-4 rounded-lg bg-gray-50 border border-gray-300 text-gray-900 placeholder-gray-400 text-xs focus:outline-none focus:ring-2 focus:ring-red-600 focus:border-transparent transition-all">
                        <button onclick="sendReset(event)" class="h-10 w-full bg-red-600 hover:bg-red-700 text-white rounded-lg text-xs font-bold uppercase tracking-wider cursor-pointer transition shadow-sm">
                            <%= currentLang === 'ar' ? 'إرسال' : 'Send' %>
                        </button>
                    </div>
                    <p id="forgotMsg" class="text-xs mt-2.5 hidden text-center font-semibold"></p>
                </div>
            </div>
            
            <!-- Footer Copyright -->
            <p class="text-xs text-white/80 mt-8 text-center select-none font-mono">
                Sokrat Analytics is licensed under GPL. 2006 - 2026.
            </p>
        </div>
    </div>

    <script>
        var uiLabels = {
            sending: '<%= currentLang === "ar" ? "جاري الإرسال..." : "Sending..." %>',
            send: '<%= currentLang === "ar" ? "إرسال" : "Send" %>'
        };
        function showForgot() {
            document.getElementById('forgotForm').classList.toggle('hidden');
        }
        async function sendReset(evt) {
            const username = document.getElementById('forgotUsername').value;
            const email = document.getElementById('forgotEmail').value;
            const btn = evt ? evt.target : document.querySelector('#forgotForm button');
            if (btn) {
                btn.disabled = true;
                btn.textContent = uiLabels.sending;
            }
            try {
                const resp = await fetch('/api/auth/forgot-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ username, email })
                });
                const data = await resp.json();
                const msg = document.getElementById('forgotMsg');
                msg.classList.remove('hidden');
                msg.textContent = data.message || data.error || 'Check your email';
                msg.className = 'text-xs mt-2.5 font-semibold ' + (data.success !== false ? 'text-green-600' : 'text-red-600');
            } catch(e) {
                const msg = document.getElementById('forgotMsg');
                msg.classList.remove('hidden');
                msg.textContent = 'Error sending request';
                msg.className = 'text-xs mt-2.5 font-semibold text-red-600';
            }
            if (btn) {
                btn.disabled = false;
                btn.textContent = uiLabels.send;
            }
        }
    </script>
</body>
</html>