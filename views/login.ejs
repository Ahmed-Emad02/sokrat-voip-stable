<!DOCTYPE html>
<html lang="<%= currentLang === 'ar' ? 'ar' : 'en' %>" dir="<%= currentLang === 'ar' ? 'rtl' : 'ltr' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Issabel Dashboard - Login</title>
    <link rel="icon" type="image/png" href="/favicon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@400;600;700&family=Roboto:wght@400;500;700;900&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <style>
        :root {
            --bg-primary: #09090b;
            --bg-secondary: #121212;
            --bg-card: #18181b;
            --bg-hover: #27272a;
            --border-primary: #27272a;
            --border-accent: #3f3f46;
            --text-primary: #ffffff;
            --text-secondary: #a1a1aa;
            --text-muted: #71717a;
            --accent-color: var(--accent-color);
            --accent-hover: var(--accent-hover);
        }
        body {
            background-color: var(--bg-primary);
            font-family: 'Roboto', 'IBM Plex Sans Arabic', sans-serif;
            color: var(--text-primary);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background-image:
                radial-gradient(circle at 10% 20%, rgba(255, 59, 48, 0.08) 0%, transparent 40%),
                radial-gradient(circle at 90% 80%, rgba(255, 255, 255, 0.02) 0%, transparent 45%);
        }
        .panel-surface {
            background-color: var(--bg-secondary);
            border: 1px solid var(--border-primary);
            border-radius: 1.5rem;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }
        input {
            background-color: var(--bg-card);
            border: 1px solid var(--border-primary);
            color: var(--text-primary);
            border-radius: 0.75rem;
            padding: 0.75rem 1rem;
            width: 100%;
            outline: none;
            transition: border-color 0.15s;
        }
        input:focus {
            border-color: var(--accent-color);
        }
        .btn-primary {
            background-color: var(--accent-color);
            color: #fff;
            border: none;
            border-radius: 0.75rem;
            padding: 0.75rem;
            width: 100%;
            font-weight: 700;
            font-size: 0.875rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            cursor: pointer;
            transition: background-color 0.15s;
        }
        .btn-primary:hover {
            background-color: var(--accent-hover);
        }
        .error-msg {
            background-color: rgba(255, 59, 48, 0.1);
            border: 1px solid rgba(255, 59, 48, 0.3);
            color: #ff6b6b;
            border-radius: 0.75rem;
            padding: 0.75rem 1rem;
            font-size: 0.875rem;
            text-align: center;
        }
    </style>
</head>
<body>
    <div class="panel-surface w-full max-w-md mx-4 p-8">
        <div class="text-center mb-8">
            <img src="/logo_dark.png" alt="Issabel Dashboard" class="w-16 h-16 object-contain mx-auto mb-4">
            <h1 class="text-2xl font-black tracking-wider">
                Issabel <span class="text-[var(--accent-color)]">Dashboard</span>
            </h1>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="error-msg mb-4"><%= error %></div>
        <% } %>

        <% if (typeof reset !== 'undefined' && reset === 'success') { %>
            <div class="bg-green-500/10 border border-green-500/30 text-green-400 rounded-xl px-4 py-3 text-sm text-center mb-4">
                <%= currentLang === 'ar' ? 'تم إعادة تعيين كلمة المرور بنجاح' : 'Password reset successful. Please login.' %>
            </div>
        <% } %>

        <form method="POST" action="/login">
            <input type="hidden" name="redirect" value="<%= typeof redirect !== 'undefined' ? redirect : '/' %>">
            <div class="mb-4">
                <label class="block text-xs font-bold text-[var(--text-secondary)] uppercase tracking-wider mb-2"><%= currentLang === 'ar' ? 'اسم المستخدم' : 'Username' %></label>
                <input type="text" name="username" placeholder="admin" required autocomplete="username" autofocus>
            </div>
            <div class="mb-6">
                <label class="block text-xs font-bold text-[var(--text-secondary)] uppercase tracking-wider mb-2"><%= currentLang === 'ar' ? 'كلمة المرور' : 'Password' %></label>
                <input type="password" name="password" placeholder="••••••" required autocomplete="current-password">
            </div>
            <button type="submit" class="btn-primary"><%= currentLang === 'ar' ? 'تسجيل الدخول' : 'Sign In' %></button>
        </form>

        <div class="mt-6 text-center">
            <a href="#" onclick="showForgot()" class="text-xs text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition underline underline-offset-2 cursor-pointer">
                <%= currentLang === 'ar' ? 'نسيت كلمة المرور؟' : 'Forgot Password?' %>
            </a>
        </div>

        <div id="forgotForm" class="mt-6 hidden">
            <hr class="border-[var(--border-primary)] mb-4">
            <p class="text-xs text-[var(--text-muted)] mb-3"><%= currentLang === 'ar' ? 'أدخل اسم المستخدم والبريد الإلكتروني' : 'Enter your username and email' %></p>
            <div class="flex flex-col gap-2">
                <input type="text" id="forgotUsername" placeholder="<%= currentLang === 'ar' ? 'اسم المستخدم' : 'Username' %>" class="text-sm" style="flex:1">
                <input type="email" id="forgotEmail" placeholder="<%= currentLang === 'ar' ? 'البريد الإلكتروني' : 'email@example.com' %>" class="text-sm" style="flex:1">
                <button onclick="sendReset(event)" class="bg-[var(--bg-hover)] hover:bg-[var(--accent-color)] text-white border border-[var(--border-primary)] rounded-xl px-4 py-2 text-xs font-bold uppercase tracking-wider cursor-pointer transition">
                    <%= currentLang === 'ar' ? 'إرسال' : 'Send' %>
                </button>
            </div>
            <p id="forgotMsg" class="text-xs text-green-400 mt-2 hidden"></p>
        </div>
    </div>

    <script>
        var uiLabels = {
            sending: '<%= currentLang === "ar" ? "جاري الإرسال..." : "Sending..." %>',
            send: '<%= currentLang === "ar" ? "إرسال" : "Send" %>'
        };
        function showForgot() {
            document.getElementById('forgotForm').classList.toggle('hidden');
        }
        async function sendReset(evt) {
            const username = document.getElementById('forgotUsername').value;
            const email = document.getElementById('forgotEmail').value;
            const btn = evt ? evt.target : document.querySelector('#forgotForm button');
            if (btn) {
                btn.disabled = true;
                btn.textContent = uiLabels.sending;
            }
            try {
                const resp = await fetch('/api/auth/forgot-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ username, email })
                });
                const data = await resp.json();
                const msg = document.getElementById('forgotMsg');
                msg.classList.remove('hidden');
                msg.textContent = data.message || data.error || 'Check your email';
                msg.className = 'text-xs mt-2 ' + (data.success !== false ? 'text-green-400' : 'text-red-400');
            } catch(e) {
                const msg = document.getElementById('forgotMsg');
                msg.classList.remove('hidden');
                msg.textContent = 'Error sending request';
                msg.className = 'text-xs mt-2 text-red-400';
            }
            if (btn) {
                btn.disabled = false;
                btn.textContent = uiLabels.send;
            }
        }
    </script>
</body>
</html>