                });
                if (actualInput.value.startsWith('from-did-direct,')) {
                    selectEl.value = actualInput.value;
                }
            } else if (destType === 'ringgroups') {
                selectEl.innerHTML = '<option value="">== choose ring group ==</option>';
                selectEl.classList.remove('hidden');
                selectEl.required = true;
                
                loadedRingGroupsList.forEach(rg => {
                    const opt = document.createElement('option');
                    opt.value = `ext-group,${rg.grpnum},1`;
                    opt.textContent = `${rg.grpnum} - ${rg.description || ''}`;
                    selectEl.appendChild(opt);
                });
                if (actualInput.value.startsWith('ext-group,')) {
                    selectEl.value = actualInput.value;
                }
            } else if (destType === 'queues') {
                selectEl.innerHTML = '<option value="">== choose queue ==</option>';
                selectEl.classList.remove('hidden');
                selectEl.required = true;
                
                loadedQueuesList.forEach(q => {
                    const opt = document.createElement('option');
                    opt.value = `ext-queues,${q.extension},1`;
                    opt.textContent = `${q.extension} - ${q.descr || ''}`;
                    selectEl.appendChild(opt);
                });
                if (actualInput.value.startsWith('ext-queues,')) {
                    selectEl.value = actualInput.value;
                }
            } else if (destType === 'custom') {
                inputEl.classList.remove('hidden');
                inputEl.required = true;
                if (actualInput.value && !actualInput.value.startsWith('from-did-direct,') && !actualInput.value.startsWith('ext-group,') && !actualInput.value.startsWith('ext-queues,')) {
                    inputEl.value = actualInput.value;
                } else {
                    inputEl.value = '';
                }
            }
        }

        function onInboundDestTypeChange() {
            loadInboundDestOptions();
            updateInboundDestinationValue();
        }

        function updateInboundDestinationValue() {
            const destType = document.getElementById('inDestType').value;
            const selectEl = document.getElementById('inDestTargetSelect');
            const inputEl = document.getElementById('inDestTargetInput');
            const actualInput = document.getElementById('inDestination');
            
            if (['extensions', 'ringgroups', 'queues'].includes(destType)) {
                actualInput.value = selectEl.value;
            } else if (destType === 'custom') {
                actualInput.value = inputEl.value.trim();
            } else {
                actualInput.value = '';
            }
        }

        function openInboundModal() {
            document.getElementById('inboundModalTitle').textContent = isRtl ? 'إضافة مسار وارد' : 'Add Inbound Route';
            document.getElementById('inboundEditExt').value = "";
            document.getElementById('inboundEditDesc').value = "";
            document.getElementById('inboundForm').reset();
            document.getElementById('inDestType').value = "";
            document.getElementById('inDestTargetSelect').classList.add('hidden');
            document.getElementById('inDestTargetInput').classList.add('hidden');
            document.getElementById('inDestination').value = "";
            openModal('inboundModal');
        }

        function editInboundRoute(extension, description, destination) {
            document.getElementById('inboundModalTitle').textContent = isRtl ? 'تعديل المسار الوارد' : 'Edit Inbound Route';
            document.getElementById('inboundEditExt').value = extension || '';
            document.getElementById('inboundEditDesc').value = description || '';
            
            document.getElementById('inDescription').value = description || '';
            document.getElementById('inExtension').value = extension || '';
            
            const actualInput = document.getElementById('inDestination');
            actualInput.value = destination || '';
            
            const destTypeSelect = document.getElementById('inDestType');
            if (destination.startsWith('from-did-direct,')) {
                destTypeSelect.value = 'extensions';
            } else if (destination.startsWith('ext-group,')) {
                destTypeSelect.value = 'ringgroups';
            } else if (destination.startsWith('ext-queues,')) {
                destTypeSelect.value = 'queues';
            } else if (destination) {
                destTypeSelect.value = 'custom';
            } else {
                destTypeSelect.value = '';
            }
            
            loadInboundDestOptions();
            openModal('inboundModal');
        }

        function saveInboundRoute(e) {
            e.preventDefault();
            const editExt = document.getElementById('inboundEditExt').value;
            const editDesc = document.getElementById('inboundEditDesc').value;
            
            const description = document.getElementById('inDescription').value.trim();
            const extension = document.getElementById('inExtension').value.trim();
            const destination = document.getElementById('inDestination').value.trim();

            if (!destination) {
                showToast(isRtl ? 'يرجى اختيار الوجهة.' : 'Please select a destination.', 'error');
                return;
            }

            const url = '/api/config/routes/inbound';
            const method = (editDesc || editExt) ? 'PUT' : 'POST';
            
            const bodyData = { description, extension, destination };
            if (method === 'PUT') {
                bodyData.originalExtension = editExt;
                bodyData.originalDescription = editDesc;
            }

            fetch(url, {
                method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(bodyData)
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    showToast(data.message, 'success');
                    closeModal('inboundModal');
                    fetchInboundRoutes();
                } else showToast(data.error, 'error');
            });
        }

        function deleteInboundRoute(extension, description) {
            if (!confirm(`Delete inbound route '${description}'?`)) return;
            fetch('/api/config/routes/inbound', {
                method: 'DELETE',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ extension, description })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    showToast(data.message, 'success');
                    fetchInboundRoutes();
                } else showToast(data.error, 'error');
            });
        }

        // --- 6. OUTBOUND ROUTES ---
        function renderModalPatterns() {
            const listEl = document.getElementById('outboundPatternsList');
            if (!listEl) return;
            listEl.innerHTML = '';
            if (modalPatternsList.length === 0) {
                listEl.innerHTML = '<span class="text-xs text-[var(--text-muted)] italic">No patterns added yet.</span>';
                return;
            }
            modalPatternsList.forEach((pat, idx) => {
                const div = document.createElement('div');
                if (idx === editingPatternIndex) {
                    div.className = 'flex items-center justify-between bg-blue-500/5 border border-blue-500/50 px-3 py-2 rounded-lg text-xs ring-1 ring-blue-500/60';
                } else {
                    div.className = 'flex items-center justify-between bg-[var(--bg-secondary)] border border-[var(--border-primary)] px-3 py-2 rounded-lg text-xs';
                }
                
                let htmlParts = [];
                if (pat.prepend) htmlParts.push(`<span class="bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 px-1 py-0.5 rounded font-mono font-bold">prepend: ${pat.prepend}</span>`);
                if (pat.prefix) htmlParts.push(`<span class="bg-blue-500/10 text-blue-400 border border-blue-500/20 px-1 py-0.5 rounded font-mono font-bold">prefix: ${pat.prefix}</span>`);
                htmlParts.push(`<span class="bg-[var(--bg-card)] text-[var(--text-primary)] border border-[var(--border-primary)] px-1.5 py-0.5 rounded font-mono font-extrabold text-blue-300">pattern: ${pat.pattern}</span>`);
                if (pat.cid) htmlParts.push(`<span class="bg-purple-500/10 text-purple-400 border border-purple-500/20 px-1 py-0.5 rounded font-mono font-bold">CID: ${pat.cid}</span>`);
                
                div.innerHTML = `
                    <div class="flex items-center gap-1.5 flex-wrap">
                        ${htmlParts.join(' ')}
                        ${idx === editingPatternIndex ? '<span class="text-[10px] text-blue-400 font-bold italic animate-pulse">(Editing...)</span>' : ''}
                    </div>
                    <div class="flex items-center gap-2">
                        <button type="button" onclick="editDialPatternInModalList(${idx})" class="text-blue-400 hover:text-blue-500 font-semibold text-[11px] cursor-pointer">
                            Edit
                        </button>
                        <button type="button" onclick="removeDialPatternFromModalList(${idx})" class="text-red-400 hover:text-red-500 cursor-pointer font-bold text-xs ml-1">
                            ✕
                        </button>
                    </div>
                `;
                listEl.appendChild(div);
            });
        }

        function editDialPatternInModalList(idx) {
            editingPatternIndex = idx;
            const pat = modalPatternsList[idx];
            document.getElementById('patPrepend').value = pat.prepend || '';
            document.getElementById('patPrefix').value = pat.prefix || '';
            document.getElementById('patPattern').value = pat.pattern || '';
            document.getElementById('patCid').value = pat.cid || '';
            
            renderModalPatterns();
            
            const btn = document.getElementById('addPatternBtn');
            if (btn) btn.textContent = isRtl ? 'تحديث النمط' : 'Update Pattern';
        }

        function addDialPatternToModalList() {
            const patternInput = document.getElementById('patPattern');
            const pattern = patternInput.value.trim();
            if (!pattern) {
                showToast(isRtl ? 'حقل النمط مطلوب.' : 'Pattern field is required.', 'error');
                return;
            }
            const prepend = document.getElementById('patPrepend').value.trim();
            const prefix = document.getElementById('patPrefix').value.trim();
            const cid = document.getElementById('patCid').value.trim();
            
            if (editingPatternIndex > -1) {
                modalPatternsList[editingPatternIndex] = { prepend, prefix, pattern, cid };
                editingPatternIndex = -1;
                const btn = document.getElementById('addPatternBtn');
                if (btn) btn.textContent = isRtl ? '+ إضافة نمط' : '+ Add Pattern';
            } else {
                modalPatternsList.push({ prepend, prefix, pattern, cid });
            }
            
            renderModalPatterns();
            
            patternInput.value = '';
            document.getElementById('patPrepend').value = '';
            document.getElementById('patPrefix').value = '';
            document.getElementById('patCid').value = '';
        }

        function removeDialPatternFromModalList(idx) {
            modalPatternsList.splice(idx, 1);
            if (editingPatternIndex === idx) {
                editingPatternIndex = -1;
                const btn = document.getElementById('addPatternBtn');
                if (btn) btn.textContent = isRtl ? '+ إضافة نمط' : '+ Add Pattern';
                document.getElementById('patPattern').value = '';
                document.getElementById('patPrepend').value = '';
                document.getElementById('patPrefix').value = '';
                document.getElementById('patCid').value = '';
            } else if (editingPatternIndex > idx) {
                editingPatternIndex--;
            }
            renderModalPatterns();
        }

        function renderModalTrunksSequence() {
            const listEl = document.getElementById('outboundTrunksSequenceList');
            if (!listEl) return;
            listEl.innerHTML = '';
            if (modalTrunksSequence.length === 0) {
                listEl.innerHTML = '<span class="text-xs text-[var(--text-muted)] italic">No trunks in sequence yet.</span>';
                return;
            }
            modalTrunksSequence.forEach((trunkId, idx) => {
                const trunkMatch = loadedTrunksList.find(t => t.trunkid == trunkId);
                const trunkName = trunkMatch ? trunkMatch.name : `Trunk ID #${trunkId}`;
                const div = document.createElement('div');
                div.className = 'flex items-center justify-between bg-[var(--bg-secondary)] border border-[var(--border-primary)] px-3 py-1.5 rounded-lg text-xs';
                div.innerHTML = `
                    <span class="font-bold text-[var(--text-primary)] font-mono">${idx + 1}. ${trunkName}</span>
                    <div class="flex items-center gap-2">
                        <button type="button" onclick="moveTrunkInSequence(${idx}, -1)" ${idx === 0 ? 'disabled' : ''} class="text-blue-400 hover:text-blue-500 disabled:opacity-35 disabled:cursor-not-allowed text-[11px] cursor-pointer">▲</button>
                        <button type="button" onclick="moveTrunkInSequence(${idx}, 1)" ${idx === modalTrunksSequence.length - 1 ? 'disabled' : ''} class="text-blue-400 hover:text-blue-500 disabled:opacity-35 disabled:cursor-not-allowed text-[11px] cursor-pointer">▼</button>
                        <button type="button" onclick="removeTrunkFromModalSequence(${idx})" class="text-red-400 hover:text-red-500 ml-2 cursor-pointer">✕</button>
                    </div>
                `;
                listEl.appendChild(div);
            });
        }

        function addTrunkToModalSequence() {
            const selectEl = document.getElementById('sequenceTrunkSelect');
            const trunkId = selectEl.value;
            if (!trunkId) return;
            if (modalTrunksSequence.includes(trunkId)) {
                showToast(isRtl ? 'خط الربط موجود بالفعل في التسلسل.' : 'Trunk is already in the sequence.', 'error');
                return;
            }
            modalTrunksSequence.push(trunkId);
            renderModalTrunksSequence();
            selectEl.value = '';
        }

        function moveTrunkInSequence(idx, dir) {
            const targetIdx = idx + dir;
            if (targetIdx < 0 || targetIdx >= modalTrunksSequence.length) return;
            const temp = modalTrunksSequence[idx];
            modalTrunksSequence[idx] = modalTrunksSequence[targetIdx];
            modalTrunksSequence[targetIdx] = temp;
            renderModalTrunksSequence();
        }

        function removeTrunkFromModalSequence(idx) {
            modalTrunksSequence.splice(idx, 1);
            renderModalTrunksSequence();
        }

        function fetchOutboundRoutes() {
            const tbody = document.getElementById('outbound-table-body');
            fetch('/api/config/routes/outbound')
                .then(res => res.json())
                .then(data => {
                    if (!data.success || !data.routes) return;
                    tbody.innerHTML = '';
                    if (data.routes.length === 0) {
                        tbody.innerHTML = '<tr><td colspan="5" class="py-6 text-center text-[var(--text-muted)]">No outbound routes found.</td></tr>';
                        return;
                    }
                    data.routes.forEach(r => {
                        const tr = document.createElement('tr');
                        tr.className = 'hover:bg-[var(--bg-hover)] transition-colors';
                        
                        const patHtml = r.patterns.map(p => {
                            let textParts = [];
                            if (p.prepend) textParts.push(`<span class="text-emerald-400 font-bold font-mono" title="Prepend">(${p.prepend})</span>`);
                            if (p.prefix) textParts.push(`<span class="text-blue-400 font-bold font-mono" title="Prefix">${p.prefix} |</span>`);
                            textParts.push(`<span class="text-[var(--text-primary)] font-extrabold font-mono" title="Match Pattern">${p.pattern}</span>`);
                            if (p.cid) textParts.push(`<span class="text-purple-400 font-mono" title="Caller ID">/ ${p.cid}</span>`);
                            
                            return `<div class="font-mono text-xs bg-[var(--bg-secondary)] px-2.5 py-1 rounded border border-[var(--border-primary)]/80 inline-flex items-center gap-1 mr-1.5 mb-1.5">${textParts.join('')}</div>`;
                        }).join(' ') || '<span class="text-[var(--text-muted)]">-</span>';
                        
                        const trunkHtml = r.trunks.map(t => {
                            return `<div class="font-mono text-xs text-emerald-400 font-semibold bg-emerald-500/10 px-2 py-0.5 rounded border border-emerald-500/20 w-fit inline-block mr-1 mb-1">${t.trunk_name}</div>`;
                        }).join(' ➔ ') || '<span class="text-[var(--text-muted)]">-</span>';
                        
                        const patternsJson = JSON.stringify(r.patterns).replace(/"/g, '&quot;');
                        const trunksJson = JSON.stringify(r.trunks).replace(/"/g, '&quot;');

                        tr.innerHTML = `
                            <td class="py-3 px-4 font-mono font-bold text-[var(--text-muted)]">${r.route_id}</td>
                            <td class="py-3 px-4 font-bold text-[var(--text-primary)]">${r.name}</td>
                            <td class="py-3 px-4">${patHtml}</td>
                            <td class="py-3 px-4">${trunkHtml}</td>
                            <td class="py-3 px-4 text-center">
                                <div class="flex items-center justify-center gap-2">
                                    <button onclick="editOutboundRoute(${r.route_id}, '${r.name}', '${patternsJson}', '${trunksJson}')" class="px-2.5 py-1 text-xs font-semibold text-blue-400 hover:bg-blue-500/10 rounded border border-blue-500/30">Edit</button>
                                    <button onclick="deleteOutboundRoute(${r.route_id})" class="px-2.5 py-1 text-xs font-semibold text-red-400 hover:bg-red-500/10 rounded border border-red-500/30">Delete</button>
                                </div>
                            </td>
                        `;
                        tbody.appendChild(tr);
                    });
                })
                .catch(err => console.error(err));
        }

        function openOutboundModal() {
            document.getElementById('outboundModalTitle').textContent = isRtl ? 'إضافة مسار صادر' : 'Add Outbound Route';
            document.getElementById('outboundEditId').value = "";
            document.getElementById('outboundForm').reset();
            modalPatternsList = [];
            modalTrunksSequence = [];
            editingPatternIndex = -1;
            
            const btn = document.getElementById('addPatternBtn');
            if (btn) btn.textContent = isRtl ? '+ إضافة نمط' : '+ Add Pattern';
            
            const sel = document.getElementById('sequenceTrunkSelect');
            if (sel) {
                sel.innerHTML = '<option value="">-- Choose Trunk --</option>';
                loadedTrunksList.forEach(t => {
                    const opt = document.createElement('option');
                    opt.value = t.trunkid;
                    opt.textContent = `${t.name} (${t.tech})`;
                    sel.appendChild(opt);
                });
            }

            renderModalPatterns();
            renderModalTrunksSequence();
            openModal('outboundModal');
        }

        function editOutboundRoute(routeId, name, patternsJson, trunksJson) {
            document.getElementById('outboundModalTitle').textContent = (isRtl ? 'تعديل المسار الصادر ' : 'Edit Outbound Route ') + name;
            document.getElementById('outboundEditId').value = routeId;
            document.getElementById('outName').value = name || '';
            editingPatternIndex = -1;
            
            const btn = document.getElementById('addPatternBtn');
            if (btn) btn.textContent = isRtl ? '+ إضافة نمط' : '+ Add Pattern';

            try {
                modalPatternsList = JSON.parse(patternsJson) || [];
            } catch(e) {
                modalPatternsList = [];
            }

            try {
                const trs = JSON.parse(trunksJson) || [];
                trs.sort((a,b) => a.seq - b.seq);
                modalTrunksSequence = trs.map(t => String(t.trunk_id));
            } catch(e) {
                modalTrunksSequence = [];
            }

            const sel = document.getElementById('sequenceTrunkSelect');
            if (sel) {
                sel.innerHTML = '<option value="">-- Choose Trunk --</option>';
                loadedTrunksList.forEach(t => {
                    const opt = document.createElement('option');
                    opt.value = t.trunkid;
                    opt.textContent = `${t.name} (${t.tech})`;
                    sel.appendChild(opt);
                });
            }

            renderModalPatterns();
            renderModalTrunksSequence();
            openModal('outboundModal');
        }

        function saveOutboundRoute(e) {
            e.preventDefault();
            const editId = document.getElementById('outboundEditId').value;
            const name = document.getElementById('outName').value.trim();

            if (modalPatternsList.length === 0) {
                showToast(isRtl ? 'يرجى إضافة نمط اتصال واحد على الأقل.' : 'Please add at least one Dial Pattern.', 'error');
                return;
            }
            if (modalTrunksSequence.length === 0) {
                showToast(isRtl ? 'يرجى تحديد خط ربط واحد على الأقل في التسلسل.' : 'Please select at least one Trunk in the sequence.', 'error');
                return;
            }

            const url = editId ? '/api/config/routes/outbound/' + editId : '/api/config/routes/outbound';
            const method = editId ? 'PUT' : 'POST';

            fetch(url, {
                method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    name,
                    patterns: modalPatternsList,
                    trunks: modalTrunksSequence
                })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    showToast(data.message, 'success');
                    closeModal('outboundModal');
                    fetchOutboundRoutes();
                } else showToast(data.error, 'error');
            });
        }

        function deleteOutboundRoute(routeId) {
            if (!confirm(`Delete outbound route ID ${routeId}?`)) return;
            fetch('/api/config/routes/outbound/' + routeId, { method: 'DELETE' })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        showToast(data.message, 'success');
                        fetchOutboundRoutes();
                    } else showToast(data.error, 'error');
                });
        }

        // Global format helper function
        window.selectDialFormat = function(format) {
            const input = document.getElementById('trunkDialString');
            if (input) {
                input.value = format;
                input.dispatchEvent(new Event('input'));
            }
            const popup = document.getElementById('dongleInfoPopup');
            if (popup) popup.classList.add('hidden');
        };

        // Load dongle list for custom dial string pop-up helper
        function loadDongleInfoPopup() {
            const listContainer = document.getElementById('dongleInfoList');
            if (!listContainer) return;
            
            listContainer.innerHTML = '<span class="text-[11px] text-[var(--text-muted)]">Loading...</span>';
            const isRtl = '<%= isRtl %>' === 'true';
            
            fetch('/api/gsm-dongles')
                .then(res => res.json())
                .then(data => {
                    if (!data.success || !data.devices || data.devices.length === 0) {
                        listContainer.innerHTML = `<span class="text-[11px] text-[var(--text-muted)]">${isRtl ? 'لا توجد أجهزة متصلة' : 'No connected dongles found.'}</span>`;
                        return;
                    }
                    
                    listContainer.innerHTML = '';
                    data.devices.forEach(d => {
                        const div = document.createElement('div');
                        div.className = 'flex flex-col sm:flex-row sm:items-center justify-between p-2.5 hover:bg-[var(--bg-hover)]/30 rounded-lg border border-[var(--border-primary)]/40 gap-2 font-mono text-[11px]';
                        
                        const statusColor = d.State.toLowerCase() === 'free' ? 'text-green-400' : 'text-amber-400';
                        const cleanImei = String(d.IMEI || '').trim();
                        const hasImei = cleanImei && cleanImei !== '-';
                        const provider = d['Provider Name'] || 'None';

                        div.innerHTML = `
                            <div class="flex flex-col text-left">
                                <span class="font-bold text-[var(--text-primary)]">
                                    ${d.ID} (${d.Number || 'Unknown'}) 
                                    <span class="text-[10px] ${statusColor} ml-1.5 font-semibold">${d.State}</span>
                                </span>
                                <span class="text-[10px] text-[var(--text-muted)]">Provider: ${provider} | IMEI: ${cleanImei}</span>
                            </div>
                            <div class="flex items-center gap-1.5 shrink-0">
                                <button type="button" onclick="selectDialFormat('dongle/${d.ID}/$OUTNUM$')" class="px-2 py-0.5 text-[9px] bg-blue-500/10 hover:bg-blue-500/20 text-blue-400 border border-blue-500/30 rounded cursor-pointer transition-colors">
                                    Use ID
                                </button>
                                ${hasImei ? `
                                <button type="button" onclick="selectDialFormat('dongle/i:${cleanImei}/$OUTNUM$')" class="px-2 py-0.5 text-[9px] bg-purple-500/10 hover:bg-purple-500/20 text-purple-400 border border-purple-500/30 rounded cursor-pointer transition-colors">
                                    Use IMEI
                                </button>
                                ` : ''}
                            </div>
                        `;
                        listContainer.appendChild(div);
                    });
                })
                .catch(err => {
                    listContainer.innerHTML = `<span class="text-[11px] text-red-400">Error: ${err.message}</span>`;
                });
        }

        // Initialize on load
        document.addEventListener('DOMContentLoaded', () => {
            const tabButtons = ['extensions', 'ringgroups', 'recordings', 'trunks', 'inbound', 'outbound', 'voicemail'];
            let defaultTab = null;
            for (const t of tabButtons) {
                if (document.getElementById('tab-btn-' + t)) {
                    defaultTab = t;
                    break;
                }
            }
            if (defaultTab) {
                switchTab(defaultTab);
            }

            if (document.getElementById('tab-btn-extensions')) fetchExtensions();
            if (document.getElementById('tab-btn-recordings')) fetchRecordings();
            if (document.getElementById('tab-btn-trunks')) fetchTrunks();
            if (document.getElementById('tab-btn-voicemail')) fetchVoicemailExtensions();

            // Dongle popup handlers
            const dialInput = document.getElementById('trunkDialString');
            const popup = document.getElementById('dongleInfoPopup');
            if (dialInput && popup) {
                dialInput.addEventListener('focus', () => {
                    popup.classList.remove('hidden');
                    loadDongleInfoPopup();
                });
                
                document.addEventListener('click', (e) => {
                    if (!dialInput.contains(e.target) && !popup.contains(e.target)) {
                        popup.classList.add('hidden');
                    }
                });
            }
        });

        // --- 7. VOICEMAIL CONFIGURATION ---
        let vmExtensionsList = [];

        function fetchVoicemailExtensions() {
            const checklist = document.getElementById('vmMailboxChecklist');
            if (!checklist) return;

            // Always fetch and populate available system recordings into dropdown
            fetch('/api/config/recordings')
                .then(res => res.json())
                .then(recData => {
                    if (recData.success && recData.recordings) {
                        loadedRecordingsList = recData.recordings;
                        populateVmGreetingSelect();
                    }
                })
                .catch(() => {});
            
            checklist.innerHTML = `<span class="text-xs text-[var(--text-muted)] italic">${isRtl ? 'جاري تحميل صناديق البريد...' : 'Loading mailboxes...'}</span>`;
            
            fetch('/api/config/voicemail/extensions')
                .then(res => res.json())
                .then(data => {
                    if (!data.success || !data.extensions) return;
                    vmExtensionsList = data.extensions;
                    checklist.innerHTML = '';
                    
                    if (data.extensions.length === 0) {
                        checklist.innerHTML = `<span class="text-xs text-[var(--text-muted)] italic">${isRtl ? 'لم يتم العثور على تحويلات مفعل بها البريد الصوتي.' : 'No voicemail-enabled extensions found.'}</span>`;
                        return;
                    }
                    
                    data.extensions.forEach(ext => {
                        const label = document.createElement('label');
                        label.className = 'flex items-center justify-between p-2 hover:bg-[var(--bg-hover)]/40 rounded cursor-pointer text-xs';
                        label.innerHTML = `
                            <span class="flex items-center gap-2 font-mono">
                                <input type="checkbox" name="vm_mailbox" value="${ext.extension}" class="tab-checkbox vm-ext-chk">
                                <span class="font-bold text-[var(--text-primary)]">${ext.extension}</span>
                                <span class="text-[var(--text-muted)]">- ${ext.name}</span>
                            </span>
                            ${ext.hasCustomGreeting ? `<span class="text-[10px] text-emerald-400 font-bold bg-emerald-500/10 border border-emerald-500/20 px-1 py-0.5 rounded">${isRtl ? 'ترحيب مخصص' : 'Custom Greeting'}</span>` : `<span class="text-[10px] text-[var(--text-muted)] bg-[var(--bg-card)] border border-[var(--border-primary)] px-1 py-0.5 rounded">${isRtl ? 'ترحيب افتراضي' : 'Default Greeting'}</span>`}
                        `;
                        checklist.appendChild(label);
                    });
                })
                .catch(err => {
                    checklist.innerHTML = `<span class="text-xs text-red-400">Error: ${err.message}</span>`;
                });
        }

        function toggleVmAllMailboxes() {
            const allChecked = document.getElementById('vmAllMailboxes').checked;
            const checkboxes = document.querySelectorAll('.vm-ext-chk');
            checkboxes.forEach(chk => chk.checked = allChecked);
        }

        function populateVmGreetingSelect() {
            const selectEl = document.getElementById('vmGreetingSelect');
            if (!selectEl) return;
            const currentVal = selectEl.value;
            selectEl.innerHTML = '<option value="">-- Choose Recording --</option>';
            loadedRecordingsList.forEach(rec => {
                if (rec.displayname === '__invalid') return;
                const opt = document.createElement('option');
                opt.value = rec.id;
                opt.textContent = `${rec.displayname} (${rec.filename})`;
                if (currentVal && String(rec.id) === String(currentVal)) {
                    opt.selected = true;
                }
                selectEl.appendChild(opt);
            });
        }

        function saveVoicemailGreeting(e) {
            e.preventDefault();
            const recordingId = document.getElementById('vmGreetingSelect').value;
            const checkboxes = document.querySelectorAll('.vm-ext-chk:checked');
            const allEnabled = document.getElementById('vmAllMailboxes').checked;
            
            const extensions = Array.from(checkboxes).map(chk => chk.value);
            
            if (!allEnabled && extensions.length === 0) {
                showToast(isRtl ? 'يرجى اختيار تحويلة واحدة على الأقل.' : 'Please select at least one extension mailbox.', 'error');
                return;
            }

            fetch('/api/config/voicemail/greeting', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ recordingId, extensions, allEnabled })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    showToast(data.message, 'success');
                    fetchVoicemailExtensions();
                } else showToast(data.error, 'error');
            });
        }

        function resetVoicemailGreetings() {
            const checkboxes = document.querySelectorAll('.vm-ext-chk:checked');
            const allEnabled = document.getElementById('vmAllMailboxes').checked;
            const extensions = Array.from(checkboxes).map(chk => chk.value);
            
            if (!allEnabled && extensions.length === 0) {
                showToast(isRtl ? 'يرجى اختيار تحويلة واحدة على الأقل للإرجاع للوضع الافتراضي.' : 'Please select at least one mailbox to reset.', 'error');
                return;
            }
            
            fetch('/api/config/voicemail/reset', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ extensions })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    showToast(data.message, 'success');
                    fetchVoicemailExtensions();
                } else showToast(data.error, 'error');
            });
        }

        // --- 8. CONFIG DIAGRAM ENGINE ---
        let diagramRawData = null;
        let diagramNodesList = [];
        let diagramLinks = [];
        
        let zoomScale = 1.0;
        let panX = 0;
        let panY = 0;
        let isDragging = false;
        let startX, startY;
        let isPanZoomInitialized = false;

        function fetchDiagramData() {
            const svgNodes = document.getElementById('diagramNodes');
            const svgWires = document.getElementById('diagramConnections');
            if (!svgNodes || !svgWires) return;

            svgNodes.innerHTML = `<foreignObject x="400" y="300" width="400" height="100">
                <div class="text-center text-[var(--text-muted)] italic text-sm">
                    ${isRtl ? 'جاري تحميل مخطط الإعدادات...' : 'Loading config diagram...'}
                </div>
            </foreignObject>`;
            svgWires.innerHTML = '';

            fetch('/api/config/diagram?t=' + Date.now())
                .then(res => res.json())
                .then(data => {
                    if (!data.success) {
                        showToast(data.error || 'Failed to fetch diagram data', 'error');
                        return;
                    }
                    diagramRawData = data;
                    renderDiagram();
                    if (!isPanZoomInitialized) {
                        initPanZoom();
                        isPanZoomInitialized = true;
                    }
                })
                .catch(err => {
                    showToast(err.message, 'error');
                });
        }

        function renderDiagram() {
            const svgNodes = document.getElementById('diagramNodes');
            const svgWires = document.getElementById('diagramConnections');
            if (!svgNodes || !svgWires || !diagramRawData) return;

            svgNodes.innerHTML = '';
            svgWires.innerHTML = '';

            const colSpacing = 380;
            const cardWidth = 280;
            const cardHeight = 135;
            const ySpacing = 185;

            function formatDestination(dest) {
                if (!dest) return isRtl ? 'غير محدد' : 'Not set';
                if (dest.startsWith('ext-group,')) {
                    return `${isRtl ? 'مجموعة:' : 'Group:'} ${dest.split(',')[1]}`;
                }
                if (dest.startsWith('from-did-direct,') || dest.startsWith('ext-local,')) {
                    return `${isRtl ? 'تحويلة:' : 'Extension:'} ${dest.split(',')[1]}`;
                }
                if (dest.startsWith('ivr-')) {
                    return `IVR: ${dest.split(',')[0]}`;
                }
                if (dest.startsWith('ext-queues,')) {
                    return `${isRtl ? 'طابور:' : 'Queue:'} ${dest.split(',')[1]}`;
                }
                return dest;
            }

            const inbound = diagramRawData.inbound || [];
            const ringgroups = diagramRawData.ringgroups || [];
            const extensions = diagramRawData.extensions || [];
            const outbound = diagramRawData.outbound || [];
            const trunks = diagramRawData.trunks || [];
            const timeconditions = diagramRawData.timeconditions || [];

            const columns = [inbound, timeconditions, ringgroups, extensions, outbound, trunks];
            const maxCount = Math.max(...columns.map(c => c.length), 1);
            const viewHeight = Math.max(maxCount * ySpacing + 100, 650);

            diagramNodesList = [];
            
            // 1. Inbound Nodes
            inbound.forEach((route, i) => {
                const startY = (viewHeight - (inbound.length * ySpacing)) / 2 + 30;
                const nodeId = 'inbound-' + (route.did || 'any') + '-' + i;
                diagramNodesList.push({
                    id: nodeId,
                    x: 50,
                    y: startY + i * ySpacing,
                    type: 'inbound',
                    title: route.did ? `DID: ${route.did}` : (isRtl ? 'أي رقم وارد' : 'Any DID'),
                    subtitle: route.description || (isRtl ? 'مسار وارد' : 'Inbound Route'),
                    desc: route.destination,
                    data: route
                });
            });

            // 2. Ring Groups Nodes
            ringgroups.forEach((rg, i) => {
                const startY = (viewHeight - (ringgroups.length * ySpacing)) / 2 + 30;
                diagramNodesList.push({
                    id: 'ringgroup-' + rg.grpnum,
                    x: 50 + colSpacing * 2,
                    y: startY + i * ySpacing,
                    type: 'ringgroup',
                    title: `${isRtl ? 'مجموعة:' : 'Group:'} ${rg.grpnum}`,
                    subtitle: rg.description || (isRtl ? 'مجموعة اتصال' : 'Ring Group'),
                    desc: `${isRtl ? 'الاستراتيجية:' : 'Strategy:'} ${rg.strategy}`,
                    data: rg
                });
            });

            // 3. Queues Nodes
            const queues = diagramRawData.queues || [];
            queues.forEach((q, i) => {
                const startY = (viewHeight - (queues.length * ySpacing)) / 2 + 30;
                diagramNodesList.push({
                    id: 'queue-' + q.extension,
                    x: 50 + colSpacing * 3,
                    y: startY + i * ySpacing,
                    type: 'queue',
                    title: `${isRtl ? 'طابور:' : 'Queue:'} ${q.extension}`,
                    subtitle: q.descr || (isRtl ? 'طابور انتظار' : 'Call Queue'),
                    desc: `${isRtl ? 'أقصى وقت:' : 'Max Wait:'} ${q.maxwait === '0' || !q.maxwait ? 'Unlimited' : q.maxwait + 's'}`,
                    data: q
                });
            });

            // 4. Extensions Nodes
            extensions.forEach((ext, i) => {
                const startY = (viewHeight - (extensions.length * ySpacing)) / 2 + 30;
                diagramNodesList.push({
                    id: 'extension-' + ext.extension,
                    x: 50 + colSpacing * 4,
                    y: startY + i * ySpacing,
                    type: 'extension',
                    title: `${isRtl ? 'تحويلة:' : 'Ext:'} ${ext.extension}`,
                    subtitle: ext.name || (isRtl ? 'تحويلة SIP' : 'SIP Extension'),
                    desc: ext.voicemail === 'novm' ? (isRtl ? 'البريد مغلق' : 'Voicemail Off') : (isRtl ? 'البريد مفعل' : 'Voicemail On'),
                    data: ext
                });
            });

            // 5. Outbound Routes Nodes
            outbound.forEach((route, i) => {
                const startY = (viewHeight - (outbound.length * ySpacing)) / 2 + 30;
                const patternStr = route.patterns.map(p => p.pattern).filter(Boolean).slice(0, 2).join(', ');
                diagramNodesList.push({
                    id: 'outbound-' + route.route_id,
                    x: 50 + colSpacing * 5,
                    y: startY + i * ySpacing,
                    type: 'outbound',
                    title: route.name,
                    subtitle: isRtl ? 'مسار صادر' : 'Outbound Route',
                    desc: patternStr ? `${isRtl ? 'أنماط:' : 'Patterns:'} ${patternStr}` : (isRtl ? 'بلا أنماط' : 'No patterns'),
                    data: route
                });
            });

            // 6. Trunks Nodes
            trunks.forEach((tk, i) => {
                const startY = (viewHeight - (trunks.length * ySpacing)) / 2 + 30;
                diagramNodesList.push({
                    id: 'trunk-' + tk.trunkid,
                    x: 50 + colSpacing * 6,
                    y: startY + i * ySpacing,
                    type: 'trunk',
                    title: tk.name,
                    subtitle: `${tk.tech ? tk.tech.toUpperCase() : 'SIP'} Trunk`,
                    desc: (tk.disabled === 'on') ? (isRtl ? 'معطل' : 'Disabled') : (isRtl ? 'نشط' : 'Active'),
                    data: tk
                });
            });

            // 7. Time Conditions Nodes
            timeconditions.forEach((tc, i) => {
                const startY = (viewHeight - (timeconditions.length * ySpacing)) / 2 + 30;
                const scheduleStr = tc.details ? tc.details.map(d => d.time + ' ' + d.name).join('; ') : '';
                diagramNodesList.push({
                    id: 'timecondition-' + tc.timeconditions_id,
                    x: 50 + colSpacing,
                    y: startY + i * ySpacing,
                    type: 'timecondition',
                    title: tc.displayname || (isRtl ? 'شرط زمني' : 'Time Condition'),
                    subtitle: tc.timegroup_name || (isRtl ? 'غير محدد' : 'No group'),
                    desc: scheduleStr || '',
                    data: tc
                });
            });

            diagramLinks = [];

            // Link 1: Inbound -> Ring Groups, Queues, or Extensions
            inbound.forEach((route, idx) => {
                const dest = route.destination || '';
                let targetId = null;
                let wireType = 'inbound-dest';
                if (dest.startsWith('ext-group,')) {
                    targetId = 'ringgroup-' + dest.split(',')[1];
                } else if (dest.startsWith('ext-queues,')) {
                    targetId = 'queue-' + dest.split(',')[1];
                } else if (dest.startsWith('from-did-direct,') || dest.startsWith('ext-local,')) {
                    targetId = 'extension-' + dest.split(',')[1];
                } else if (dest.startsWith('timeconditions,') || dest.startsWith('ext-timeconditions,')) {
                    targetId = 'timecondition-' + dest.split(',')[1];
                    wireType = 'inbound-tc';
                }
                if (targetId) {
                    diagramLinks.push({
                        id: `link-inbound-${idx}`,
                        source: 'inbound-' + (route.did || 'any') + '-' + idx,
                        target: targetId,
                        type: wireType
                    });
                }
            });

            // Link 2: Time Condition -> Destinations
            timeconditions.forEach(tc => {
                const trueDest = tc.truegoto || '';
                const falseDest = tc.falsegoto || '';
                [trueDest, falseDest].forEach((dest, isFalse) => {
                    let targetId = null;
                    let wireType = isFalse ? 'tc-false' : 'tc-true';
                    if (dest.startsWith('ext-group,')) {
                        targetId = 'ringgroup-' + dest.split(',')[1];
                    } else if (dest.startsWith('ext-queues,')) {
                        targetId = 'queue-' + dest.split(',')[1];
                    } else if (dest.startsWith('from-did-direct,') || dest.startsWith('ext-local,')) {
                        targetId = 'extension-' + dest.split(',')[1];
                    }
                    if (targetId) {
                        diagramLinks.push({
                            id: 'link-tc-' + tc.timeconditions_id + '-' + (isFalse ? 'false' : 'true') + '-' + targetId,
                            source: 'timecondition-' + tc.timeconditions_id,
                            target: targetId,
                            type: wireType
                        });
                    }
                });
            });

            // Link 3: Ring Group -> Extensions
            ringgroups.forEach(rg => {
                const members = rg.grplist ? rg.grplist.split('-') : [];
                members.forEach(ext => {
                    const extExists = extensions.some(e => String(e.extension) === String(ext));
                    if (extExists) {
                        diagramLinks.push({
                            id: `link-rg-${rg.grpnum}-${ext}`,
                            source: 'ringgroup-' + rg.grpnum,
                            target: 'extension-' + ext,
                            type: 'rg-member'
                        });
                    }
                });
            });

            // Link 3.5: Queue -> Extensions
            queues.forEach(q => {
                const members = Array.isArray(q.static_members) ? q.static_members : [];
                members.forEach(ext => {
                    const extExists = extensions.some(e => String(e.extension) === String(ext));
                    if (extExists) {
                        diagramLinks.push({
                            id: `link-queue-${q.extension}-${ext}`,
                            source: 'queue-' + q.extension,
                            target: 'extension-' + ext,
                            type: 'queue-member'
                        });
                    }
                });
            });

            // Link 4: Extension -> Outbound Routes
            extensions.forEach(ext => {
                outbound.forEach(route => {
                    const patterns = Array.isArray(route.patterns) ? route.patterns : [];
                    const hasRestrictedCid = patterns.some(p => String(p.cid) === String(ext.extension));
                    const hasGlobalRoute = patterns.some(p => !p.cid || p.cid === '');
                    if (hasRestrictedCid) {
                        diagramLinks.push({
                            id: `link-ext-outbound-${ext.extension}-${route.route_id}`,
                            source: 'extension-' + ext.extension,
                            target: 'outbound-' + route.route_id,
                            type: 'ext-route-restricted'
                        });
                    } else if (hasGlobalRoute) {
                        diagramLinks.push({
                            id: `link-ext-outbound-global-${ext.extension}-${route.route_id}`,
                            source: 'extension-' + ext.extension,
                            target: 'outbound-' + route.route_id,
                            type: 'ext-route-global'
                        });
                    }
                });
            });

            // Link 5: Outbound Route -> Trunks
            outbound.forEach(route => {
                const routeTrunks = Array.isArray(route.trunks) ? route.trunks : [];
                routeTrunks.forEach(tk => {
                    const tkId = tk.trunk_id || tk.trunkid;
                    const matchedTrunk = trunks.find(t => String(t.trunkid) === String(tkId));
                    const targetTrunkId = matchedTrunk ? matchedTrunk.trunkid : tkId;
                    if (targetTrunkId !== undefined && targetTrunkId !== null) {
                        diagramLinks.push({
                            id: `link-outbound-trunk-${route.route_id}-${targetTrunkId}`,
                            source: 'outbound-' + route.route_id,
                            target: 'trunk-' + targetTrunkId,
                            type: 'route-trunk'
                        });
                    }
                });
            });

            // Render Wires
            diagramLinks.forEach(link => {
                const sourceNode = diagramNodesList.find(n => n.id === link.source);
                const targetNode = diagramNodesList.find(n => n.id === link.target);
                if (!sourceNode || !targetNode) return;

                const x1 = sourceNode.x + cardWidth;
                const y1 = sourceNode.y + cardHeight / 2;
                const x2 = targetNode.x;
                const y2 = targetNode.y + cardHeight / 2;

                const colDistance = Math.abs(x2 - x1);
                let d = '';
                if (colDistance > colSpacing * 1.2) {
                    const arcOffset = (y1 <= y2) ? -55 : 55;
                    const controlY1 = y1 + arcOffset;
                    const controlY2 = y2 + arcOffset;
                    d = `M ${x1} ${y1} C ${x1 + colSpacing * 0.4} ${controlY1}, ${x2 - colSpacing * 0.4} ${controlY2}, ${x2} ${y2}`;
                } else {
                    const dx = colDistance * 0.45;
                    d = `M ${x1} ${y1} C ${x1 + dx} ${y1}, ${x2 - dx} ${y2}, ${x2} ${y2}`;
                }

                let strokeColor = '#3f3f46';
                if (link.type === 'inbound-dest') strokeColor = '#10b981';
                else if (link.type === 'inbound-tc') strokeColor = '#eab308';
                else if (link.type === 'tc-true') strokeColor = '#10b981';
                else if (link.type === 'tc-false') strokeColor = '#ef4444';
                else if (link.type === 'rg-member') strokeColor = '#a855f7';
                else if (link.type === 'queue-member') strokeColor = '#f59e0b';
                else if (link.type === 'queue-dest') strokeColor = '#3b82f6';
                else if (link.type === 'ext-route-restricted') strokeColor = '#f97316';
                else if (link.type === 'ext-route-global') strokeColor = '#27272a';
                else if (link.type === 'route-trunk') strokeColor = '#06b6d4';

                const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
                path.setAttribute('id', link.id);
                path.setAttribute('class', 'diagram-wire transition-all duration-200');
                path.setAttribute('d', d);
                path.setAttribute('fill', 'none');
                path.setAttribute('stroke', strokeColor);
                path.setAttribute('stroke-width', link.type === 'ext-route-global' ? '1.5px' : '2px');
                path.setAttribute('stroke-linecap', 'round');
                path.setAttribute('data-type', link.type);
                path.style.opacity = link.type === 'ext-route-global' ? '0.2' : '0.5';
                
                svgWires.appendChild(path);
            });

            // Render Nodes
            diagramNodesList.forEach(node => {
                let accentColorClass = 'border-emerald-500/20 hover:border-emerald-500';
                let iconBgClass = 'bg-emerald-500/10 text-emerald-400';
                let svgIcon = `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1" /></svg>`;

                if (node.type === 'ringgroup') {
                    accentColorClass = 'border-purple-500/20 hover:border-purple-500';
                    iconBgClass = 'bg-purple-500/10 text-purple-400';
                    svgIcon = `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>`;
                } else if (node.type === 'queue') {
                    accentColorClass = 'border-amber-500/20 hover:border-amber-500';
                    iconBgClass = 'bg-amber-500/10 text-amber-400';
                    svgIcon = `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>`;
                } else if (node.type === 'extension') {
                    accentColorClass = 'border-red-500/20 hover:border-red-500';
                    iconBgClass = 'bg-red-500/10 text-red-400';
                    svgIcon = `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>`;
                } else if (node.type === 'outbound') {
                    accentColorClass = 'border-orange-500/20 hover:border-orange-500';
                    iconBgClass = 'bg-orange-500/10 text-orange-400';
                    svgIcon = `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" /></svg>`;
                } else if (node.type === 'timecondition') {
                    accentColorClass = 'border-yellow-500/20 hover:border-yellow-500';
                    iconBgClass = 'bg-yellow-500/10 text-yellow-400';
                    svgIcon = `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`;
                } else if (node.type === 'trunk') {
                    accentColorClass = 'border-cyan-500/20 hover:border-cyan-500';
                    iconBgClass = 'bg-cyan-500/10 text-cyan-400';
