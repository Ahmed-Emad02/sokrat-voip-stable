                            <div id="rgQuickPickContainer" class="flex flex-wrap gap-1.5 pt-1">
                                <span class="text-[11px] text-[var(--text-muted)]">Loading active extensions...</span>
                            </div>
                        </div>
                    </div>
                    <div>
