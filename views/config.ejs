                        if (tg.rules && tg.rules.length > 0) {
                            tg.rules.forEach(rule => {
                                const timeStr = rule.time || '*';
                                const weekdayStr = rule.weekday || '*';
                                const monthdayStr = rule.monthday || '*';
                                const monthStr = rule.month || '*';
                                rulesHTML += `
                                    <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded text-[10px] font-semibold bg-zinc-800 text-zinc-300 border border-zinc-700 font-mono my-0.5 mr-1">
                                        <svg class="w-3 h-3 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                                        ${timeStr} | ${weekdayStr} | ${monthdayStr} | ${monthStr}
                                    </span>
                                `;
                            });
                        } else {
                            rulesHTML = '<span class="text-zinc-500 italic">No rules defined (matches always)</span>';
                        }

                        tr.innerHTML = `
                            <td class="py-3 px-4 font-mono font-bold text-[var(--text-primary)]">${tg.id}</td>
                            <td class="py-3 px-4 font-bold text-[var(--text-primary)]">${tg.description}</td>
                            <td class="py-3 px-4">${rulesHTML}</td>
                            <td class="py-3 px-4 text-center">
                                <div class="flex items-center justify-center gap-2">
