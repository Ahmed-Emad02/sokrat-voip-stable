        function highlightNode(nodeId) {
            const connections = document.querySelectorAll('.diagram-wire');
            const cards = document.querySelectorAll('.diagram-card');
            
            const connectedNodeIds = new Set([nodeId]);
            const activeWireIds = new Set();
            
            // 1. Forward Traversal (Downstream)
            let fwdQueue = [nodeId];
            let fwdVisited = new Set([nodeId]);
            while (fwdQueue.length > 0) {
                const current = fwdQueue.shift();
                diagramLinks.forEach(link => {
                    if (link.source === current) {
                        activeWireIds.add(link.id);
                        if (!fwdVisited.has(link.target)) {
                            fwdVisited.add(link.target);
                            connectedNodeIds.add(link.target);
                            fwdQueue.push(link.target);
                        }
                    }
                });
            }

            // 2. Backward Traversal (Upstream)
            let bwdQueue = [nodeId];
            let bwdVisited = new Set([nodeId]);
            while (bwdQueue.length > 0) {
                const current = bwdQueue.shift();
                diagramLinks.forEach(link => {
                    if (link.target === current) {
                        activeWireIds.add(link.id);
                        if (!bwdVisited.has(link.source)) {
                            bwdVisited.add(link.source);
                            connectedNodeIds.add(link.source);
                            bwdQueue.push(link.source);
                        }
                    }
                });
            }

            // 3. Connect intermediate wire links between all discovered connected nodes
            diagramLinks.forEach(link => {
                if (connectedNodeIds.has(link.source) && connectedNodeIds.has(link.target)) {
                    activeWireIds.add(link.id);
                }
            });

            // 4. Update Wires SVG styling
            connections.forEach(wire => {
                const id = wire.getAttribute('id');
                if (activeWireIds.has(id)) {
                    wire.style.opacity = '1';
                    wire.style.strokeWidth = '3.5px';
                    wire.style.filter = 'url(#glow-filter)';
                } else {
                    wire.style.opacity = '0.04';
                    wire.style.strokeWidth = '1.5px';
                    wire.style.filter = 'none';
                }
            });
            
            // 5. Update Cards HTML styling
            cards.forEach(card => {
                const id = card.getAttribute('data-node-id');
                if (connectedNodeIds.has(id)) {
                    card.style.opacity = '1';
                    card.style.boxShadow = '0 0 20px rgba(255, 255, 255, 0.3)';
                } else {
                    card.style.opacity = '0.15';
                }
            });
        }

        function resetHighlight() {
            const connections = document.querySelectorAll('.diagram-wire');
            const cards = document.querySelectorAll('.diagram-card');
            
            connections.forEach(wire => {
                wire.style.strokeWidth = '2px';
                wire.style.filter = 'none';
                
                const type = wire.getAttribute('data-type');
                if (type === 'inbound-dest') {
                    wire.style.stroke = '#10b981';
                    wire.style.opacity = '0.5';
                } else if (type === 'inbound-tc') {
                    wire.style.stroke = '#eab308';
                    wire.style.opacity = '0.5';
                } else if (type === 'tc-true') {
                    wire.style.stroke = '#10b981';
                    wire.style.opacity = '0.5';
                } else if (type === 'tc-false') {
                    wire.style.stroke = '#ef4444';
                    wire.style.opacity = '0.5';
                } else if (type === 'rg-member') {
                    wire.style.stroke = '#a855f7';
                    wire.style.opacity = '0.5';
                } else if (type === 'ext-route-restricted') {
                    wire.style.stroke = '#f97316';
                    wire.style.opacity = '0.5';
                } else if (type === 'ext-route-global') {
                    wire.style.stroke = '#27272a';
                    wire.style.strokeWidth = '1.5px';
                    wire.style.opacity = '0.2';
                } else if (type === 'route-trunk') {
                    wire.style.stroke = '#06b6d4';
                    wire.style.opacity = '0.5';
                }
            });
            
            cards.forEach(card => {
                card.style.opacity = '1';
                card.style.borderColor = '';
                card.style.boxShadow = '';
            });
        }

        function filterDiagramNodes() {
            const query = document.getElementById('diagramSearch').value.toLowerCase().trim();
            const cards = document.querySelectorAll('.diagram-card');
            const connections = document.querySelectorAll('.diagram-wire');

            if (!query) {
                resetHighlight();
                return;
            }

            const matchedNodeIds = new Set();
            diagramNodesList.forEach(node => {
                if (node.title.toLowerCase().includes(query) || 
                    node.subtitle.toLowerCase().includes(query) || 
                    (node.desc && node.desc.toLowerCase().includes(query))) {
                    matchedNodeIds.add(node.id);
                }
            });

            const activeWireIds = new Set();
            diagramLinks.forEach(link => {
                if (matchedNodeIds.has(link.source) || matchedNodeIds.has(link.target)) {
                    activeWireIds.add(link.id);
                    matchedNodeIds.add(link.source);
                    matchedNodeIds.add(link.target);
                }
            });

            cards.forEach(card => {
                const id = card.getAttribute('data-node-id');
                if (matchedNodeIds.has(id)) {
                    card.style.opacity = '1';
                    card.style.borderColor = '#ef4444';
                    card.style.boxShadow = '0 0 15px rgba(239, 68, 68, 0.2)';
                } else {
                    card.style.opacity = '0.15';
                }
            });

            connections.forEach(wire => {
                const id = wire.getAttribute('id');
                if (activeWireIds.has(id)) {
                    wire.style.opacity = '1';
                    wire.style.strokeWidth = '3px';
                    wire.style.stroke = '#ef4444';
                } else {
                    wire.style.opacity = '0.04';
                }
            });
        }

        function initPanZoom() {
            const svg = document.getElementById('diagramSvg');
            if (!svg) return;

            svg.addEventListener('mousedown', (e) => {
                if (e.target.closest('foreignObject') || e.target.closest('button') || e.target.closest('input')) return;
                isDragging = true;
                svg.style.cursor = 'grabbing';
                startX = e.clientX - panX;
                startY = e.clientY - panY;
            });

            svg.addEventListener('mousemove', (e) => {
                if (!isDragging) return;
                panX = e.clientX - startX;
                panY = e.clientY - startY;
                updateTransform();
            });

            window.addEventListener('mouseup', () => {
                if (isDragging) {
                    isDragging = false;
                    svg.style.cursor = 'grab';
                }
            });

            svg.addEventListener('wheel', (e) => {
                e.preventDefault();
                const zoomFactor = 1.08;
                const oldScale = zoomScale;
                if (e.deltaY < 0) {
                    zoomScale *= zoomFactor;
                } else {
                    zoomScale /= zoomFactor;
                }
                zoomScale = Math.min(Math.max(zoomScale, 0.15), 3.0);
                
                const rect = svg.getBoundingClientRect();
                const mouseX = e.clientX - rect.left;
                const mouseY = e.clientY - rect.top;
                panX = mouseX - (mouseX - panX) * (zoomScale / oldScale);
                panY = mouseY - (mouseY - panY) * (zoomScale / oldScale);
                
                updateTransform();
            });
            svg.style.cursor = 'grab';
        }

        function updateTransform() {
            const viewport = document.getElementById('diagramViewport');
            if (viewport) {
                viewport.setAttribute('transform', `translate(${panX}, ${panY}) scale(${zoomScale})`);
            }
        }

        function zoomDiagram(factor) {
            const svg = document.getElementById('diagramSvg');
            if (!svg) return;
            const rect = svg.getBoundingClientRect();
            const centerX = rect.width / 2;
            const centerY = rect.height / 2;
            const oldScale = zoomScale;
            
            zoomScale *= factor;
            zoomScale = Math.min(Math.max(zoomScale, 0.15), 3.0);
            
            panX = centerX - (centerX - panX) * (zoomScale / oldScale);
            panY = centerY - (centerY - panY) * (zoomScale / oldScale);
            updateTransform();
        }

        function resetDiagramZoom() {
            zoomScale = 1.0;
            panX = 0;
            panY = 0;
            updateTransform();
            document.getElementById('diagramSearch').value = '';
            resetHighlight();
        }

