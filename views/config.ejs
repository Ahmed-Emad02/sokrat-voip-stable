                    <span class="flex items-center gap-1.5 text-emerald-400"><span class="w-2.5 h-2.5 rounded-full bg-emerald-500"></span><%= isRtl ? 'مسارات واردة' : 'Inbound Routes' %></span>
                    <span class="flex items-center gap-1.5 text-yellow-400"><span class="w-2.5 h-2.5 rounded-full bg-yellow-500"></span><%= isRtl ? 'شروط الوقت' : 'Time Conditions' %></span>
                    <span class="flex items-center gap-1.5 text-purple-400"><span class="w-2.5 h-2.5 rounded-full bg-purple-500"></span><%= isRtl ? 'مجموعات الاتصال' : 'Ring Groups' %></span>
                    <span class="flex items-center gap-1.5 text-amber-400"><span class="w-2.5 h-2.5 rounded-full bg-amber-500"></span><%= isRtl ? 'طوابير الانتظار (Queues)' : 'Call Queues' %></span>
                    <span class="flex items-center gap-1.5 text-red-400"><span class="w-2.5 h-2.5 rounded-full bg-red-500"></span><%= isRtl ? 'التحويلات' : 'Extensions' %></span>
                    <span class="flex items-center gap-1.5 text-orange-400"><span class="w-2.5 h-2.5 rounded-full bg-orange-500"></span><%= isRtl ? 'مسارات صادرة' : 'Outbound Routes' %></span>
                    <span class="flex items-center gap-1.5 text-cyan-400"><span class="w-2.5 h-2.5 rounded-full bg-cyan-500"></span><%= isRtl ? 'خطوط الربط' : 'Trunks' %></span>
                </div>

                <!-- Canvas Wrapper -->
                <div id="diagramCanvasContainer" class="flex-1 relative border border-[var(--border-primary)] rounded-xl overflow-hidden bg-[#09090b]">
                    <svg id="diagramSvg" class="w-full h-full cursor-grab active:cursor-grabbing select-none">
                        <!-- Grid pattern definition -->
                        <defs>
                            <pattern id="grid-pattern" width="30" height="30" patternUnits="userSpaceOnUse">
                                <circle cx="2" cy="2" r="1.5" fill="#222" />
                            </pattern>
                            <!-- Drop shadow filter for highlights -->
                            <filter id="glow-filter" x="-20%" y="-20%" width="140%" height="140%">
                                <feGaussianBlur stdDeviation="4" result="blur" />
                                <feComposite in="SourceGraphic" in2="blur" operator="over" />
                            </filter>
                        </defs>
                        <!-- Grid rect -->
                        <rect width="100%" height="100%" fill="url(#grid-pattern)" />
                        <!-- Zoom and pan group -->
                        <g id="diagramViewport" transform="translate(0,0) scale(1)">
                            <!-- Connections / Wires -->
                            <g id="diagramConnections"></g>
                            <!-- Nodes / Cards -->
                            <g id="diagramNodes"></g>
                        </g>
                    </svg>
                </div>
            </div>
        </div>
        <% } %>

        <!-- TAB 9: TIME GROUPS -->
        <% if (isTabAllowed('timegroups')) { %>
        <div id="section-timegroups" class="tab-section hidden">
            <div class="config-card p-6">
                <div class="flex flex-col sm:flex-row items-center justify-between gap-4 mb-6">
                    <div>
                        <h2 class="text-lg font-extrabold text-[var(--text-primary)]"><%= isRtl ? 'مجموعات الوقت (Time Groups)' : 'Time Groups' %></h2>
                        <p class="text-xs text-[var(--text-muted)]"><%= isRtl ? 'تعريف الفترات الزمنية لتحديد شروط تحويل المكالمات' : 'Define time intervals used to route calls based on schedule' %></p>
                    </div>
                    <button onclick="openTimeGroupModal()" class="config-btn-primary px-4 py-2 flex items-center gap-2 text-xs cursor-pointer">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
                        <span><%= isRtl ? 'إضافة مجموعة وقت' : 'Add Time Group' %></span>
                    </button>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-[var(--bg-card)] border-b border-[var(--border-primary)] text-xs font-bold text-[var(--text-secondary)] uppercase tracking-wider">
                                <th class="py-3 px-4 w-20"><%= isRtl ? 'الرقم' : 'ID' %></th>
                                <th class="py-3 px-4"><%= isRtl ? 'الوصف' : 'Description' %></th>
                                <th class="py-3 px-4"><%= isRtl ? 'القواعد المحددة' : 'Configured Time Rules' %></th>
                                <th class="py-3 px-4 text-center w-40"><%= isRtl ? 'الإجراءات' : 'Actions' %></th>
                            </tr>
                        </thead>
                        <tbody id="timegroups-table-body">
                            <!-- Populated dynamically -->
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <% } %>

        <!-- TAB 10: TIME CONDITIONS -->
        <% if (isTabAllowed('timeconditions')) { %>
        <div id="section-timeconditions" class="tab-section hidden">
            <div class="config-card p-6">
                <div class="flex flex-col sm:flex-row items-center justify-between gap-4 mb-6">
                    <div>
                        <h2 class="text-lg font-extrabold text-[var(--text-primary)]"><%= isRtl ? 'شروط الوقت (Time Conditions)' : 'Time Conditions' %></h2>
                        <p class="text-xs text-[var(--text-muted)]"><%= isRtl ? 'تحويل المكالمات لوجهات مختلفة بناءً على وقت الاتصال الحالي ومجموعة الوقت المحددة' : 'Route calls to different destinations based on time match/no-match' %></p>
                    </div>
                    <button onclick="openTimeConditionModal()" class="config-btn-primary px-4 py-2 flex items-center gap-2 text-xs cursor-pointer">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
                        <span><%= isRtl ? 'إضافة شرط وقت' : 'Add Time Condition' %></span>
                    </button>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-[var(--bg-card)] border-b border-[var(--border-primary)] text-xs font-bold text-[var(--text-secondary)] uppercase tracking-wider">
                                <th class="py-3 px-4 w-20"><%= isRtl ? 'الرقم' : 'ID' %></th>
                                <th class="py-3 px-4"><%= isRtl ? 'الاسم الظاهر' : 'Display Name' %></th>
                                <th class="py-3 px-4"><%= isRtl ? 'مجموعة الوقت' : 'Time Group' %></th>
                                <th class="py-3 px-4"><%= isRtl ? 'الوجهة عند المطابقة (True)' : 'Destination if Matched' %></th>
                                <th class="py-3 px-4"><%= isRtl ? 'الوجهة عند عدم المطابقة (False)' : 'Destination if Not Matched' %></th>
                                <th class="py-3 px-4 text-center w-40"><%= isRtl ? 'الإجراءات' : 'Actions' %></th>
                            </tr>
                        </thead>
                        <tbody id="timeconditions-table-body">
                            <!-- Populated dynamically -->
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <% } %>

    </div>

    <!-- MODAL 1: EXTENSION FORM -->
    <div id="extensionModal" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center hidden p-4">
        <div class="bg-[var(--bg-secondary)] rounded-2xl border border-[var(--border-primary)] shadow-2xl max-w-lg w-full p-6 text-[var(--text-primary)]">
            <div class="flex items-center justify-between mb-5 pb-3 border-b border-[var(--border-primary)]">
                <h3 id="extModalTitle" class="text-base font-extrabold text-[var(--text-primary)]">Add Extension</h3>
                <button onclick="closeModal('extensionModal')" class="text-[var(--text-muted)] hover:text-[var(--text-primary)] cursor-pointer">✕</button>
            </div>
            <form id="extensionForm" onsubmit="saveExtension(event)">
                <input type="hidden" id="extEditMode" value="false">
                <div class="flex flex-col gap-4">
                    <div>
                        <label class="block text-xs font-bold text-[var(--text-secondary)] uppercase mb-1"><%= isRtl ? 'رقم التحويلة (User Extension ID) *' : 'User Extension ID *' %></label>
                        <input type="text" id="extNum" required placeholder="e.g. 105" class="config-input w-full font-mono">
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-[var(--text-secondary)] uppercase mb-1"><%= isRtl ? 'الاسم الظاهر (Display Name) *' : 'Display Name *' %></label>
                        <input type="text" id="extName" required placeholder="e.g. Sales Desk 1" class="config-input w-full">
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-[var(--text-secondary)] uppercase mb-1"><%= isRtl ? 'كلمة السر (Secret) *' : 'Secret (Password) *' %></label>
                        <input type="text" id="extSecret" required placeholder="e.g. P@ssword123!" class="config-input w-full font-mono">
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-[var(--text-secondary)] uppercase mb-1"><%= isRtl ? 'البريد الصوتي (Voicemail)' : 'Voicemail Option' %></label>
                        <select id="extVoicemail" class="config-input w-full font-semibold">
                            <option value="disabled"><%= isRtl ? 'معطل (Disabled / No Voicemail)' : 'Disabled (No Voicemail)' %></option>
                            <option value="enabled"><%= isRtl ? 'مفعل (Enabled / Active)' : 'Enabled (Voicemail Active)' %></option>
                        </select>
                    </div>
                    <!-- System Defaults Information Banner -->
                    <div class="p-3 bg-[var(--bg-card)] border border-[var(--border-primary)] rounded-xl text-xs space-y-1">
                        <div class="font-bold text-[var(--text-primary)] flex items-center gap-1.5">
                            <svg class="w-4 h-4 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                            <span><%= isRtl ? 'الإعدادات التلقائية للنظام:' : 'Automatic Extension Defaults:' %></span>
                        </div>
                        <ul class="text-[var(--text-muted)] list-disc list-inside text-[11px] space-y-0.5 font-medium">
                            <li><strong>Device Type:</strong> Generic SIP Device (Port 5060)</li>
                            <li><strong>NAT Setting:</strong> Enabled (nat = yes)</li>
                            <li><strong>Call Recording:</strong> ALWAYS (Inbound/Outbound Internal & External)</li>
                        </ul>
                    </div>
                </div>
                <div class="flex justify-end gap-3 mt-6 pt-4 border-t border-[var(--border-primary)]">
                    <button type="button" onclick="closeModal('extensionModal')" class="config-btn-secondary px-4 py-2 text-xs"><%= isRtl ? 'إلغاء' : 'Cancel' %></button>
                    <button type="submit" class="config-btn-primary px-5 py-2 text-xs"><%= isRtl ? 'حفظ التحويلة' : 'Save Extension' %></button>
                </div>
            </form>
        </div>
    </div>

    <!-- MODAL 2: RING GROUP FORM -->
    <div id="ringGroupModal" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center hidden p-4">
        <div class="bg-[var(--bg-secondary)] rounded-2xl border border-[var(--border-primary)] shadow-2xl max-w-xl w-full p-6 text-[var(--text-primary)] max-h-[90vh] overflow-y-auto">
            <div class="flex items-center justify-between mb-5 pb-3 border-b border-[var(--border-primary)]">
                <h3 id="rgModalTitle" class="text-base font-extrabold text-[var(--text-primary)]">Add Ring Group</h3>
                <button onclick="closeModal('ringGroupModal')" class="text-[var(--text-muted)] hover:text-[var(--text-primary)] cursor-pointer">✕</button>
            </div>
            <form id="ringGroupForm" onsubmit="saveRingGroup(event)">
                <input type="hidden" id="rgEditMode" value="false">
                <div class="flex flex-col gap-4">
                    <div>
                        <label class="block text-xs font-bold text-[var(--text-secondary)] uppercase mb-1"><%= isRtl ? 'رقم مجموعة الاتصال (Group #) *' : 'Ring Group Number *' %></label>
                        <input type="text" id="rgNum" required placeholder="e.g. 600" class="config-input w-full font-mono">
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-[var(--text-secondary)] uppercase mb-1"><%= isRtl ? 'وصف المجموعة (Group Description) *' : 'Group Description *' %></label>
                        <input type="text" id="rgDesc" required placeholder="e.g. Sales Support Team" class="config-input w-full">
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-[var(--text-secondary)] uppercase mb-1"><%= isRtl ? 'استراتيجية الاتصال (Ring Strategy)' : 'Ring Strategy' %></label>
                        <select id="rgStrategy" class="config-input w-full">
                            <option value="ringall">ringall (Ring all available channels)</option>
                            <option value="hunt">hunt (Take turns ringing)</option>
                            <option value="memoryhunt">memoryhunt (First extension, then first+second...)</option>
                            <option value="firstavailable">firstavailable (Ring first available channel only)</option>
                            <option value="firstnotonphone">firstnotonphone (Ring first channel not on phone)</option>
                            <option value="random">random (Ring random channel)</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-[var(--text-secondary)] uppercase mb-1"><%= isRtl ? 'إعلان الصوت الوارد (Announcement)' : 'Announcement Recording' %></label>
                        <select id="rgAnnMsg" class="config-input w-full">
                            <option value="0">None / No Announcement</option>
                        </select>
                    </div>
                    <div>
                        <div class="flex items-center justify-between mb-1">
                            <label class="block text-xs font-bold text-[var(--text-secondary)] uppercase"><%= isRtl ? 'قائمة التحويلات (Extension List) *' : 'Extension List *' %></label>
                            <span class="text-[11px] text-[var(--text-muted)]"><%= isRtl ? 'انقر على التحويلات أدناه للاختيار السريع' : 'Click pills below for Quick Pick' %></span>
                        </div>
                        <textarea id="rgList" required rows="3" placeholder="e.g. 101, 102, 103" class="config-input w-full font-mono text-sm"></textarea>
                        
                        <!-- Quick Pick Interactive Extension Pills -->
                        <div class="mt-2.5 p-3 bg-[var(--bg-card)] border border-[var(--border-primary)] rounded-xl space-y-1.5">
                            <div class="text-[11px] font-bold text-[var(--text-secondary)] flex items-center justify-between">
                                <span><%= isRtl ? 'الاختيار السريع للتحويلات (Quick Pick):' : 'Quick Pick Active Extensions:' %></span>
                                <button type="button" onclick="clearQuickPickExts()" class="text-[10px] text-red-400 hover:underline">Clear All</button>
                            </div>
                            <div id="rgQuickPickContainer" class="flex flex-wrap gap-1.5 pt-1">
                                <span class="text-[11px] text-[var(--text-muted)]">Loading active extensions...</span>
                            </div>
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-[var(--text-secondary)] uppercase mb-1"><%= isRtl ? 'زمن الرنين (ثواني)' : 'Ring Time (Seconds)' %></label>
                        <input type="number" id="rgTime" value="20" class="config-input w-full">
                    </div>
                    <!-- System Defaults Information Banner -->
                    <div class="p-3 bg-[var(--bg-card)] border border-[var(--border-primary)] rounded-xl text-xs space-y-1">
                        <div class="font-bold text-[var(--text-primary)] flex items-center gap-1.5">
                            <svg class="w-4 h-4 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                            <span><%= isRtl ? 'الإعدادات التلقائية المطبقة:' : 'Automatic Applied Defaults:' %></span>
                        </div>
                        <ul class="text-[var(--text-muted)] list-disc list-inside text-[11px] space-y-0.5 font-medium">
                            <li><strong>Skip Busy Agent:</strong> YES (cwignore = CHECKED)</li>
                            <li><strong>Record Calls:</strong> ALWAYS (recording = always)</li>
                            <li><strong>Destination if No Answer:</strong> Ring Group itself (postdest = ext-group,[Group#],1)</li>
                        </ul>
                    </div>
                </div>
                <div class="flex justify-end gap-3 mt-6 pt-4 border-t border-[var(--border-primary)]">
                    <button type="button" onclick="closeModal('ringGroupModal')" class="config-btn-secondary px-4 py-2 text-xs"><%= isRtl ? 'إلغاء' : 'Cancel' %></button>
                    <button type="submit" class="config-btn-primary px-5 py-2 text-xs"><%= isRtl ? 'حفظ مجموعة الاتصال' : 'Save Ring Group' %></button>
                </div>
            </form>
        </div>
    </div>

    <!-- MODAL 2.5: QUEUE FORM -->
    <div id="queueModal" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center hidden p-4">
        <div class="bg-[var(--bg-secondary)] rounded-2xl border border-[var(--border-primary)] shadow-2xl max-w-2xl w-full p-6 text-[var(--text-primary)] max-h-[90vh] overflow-y-auto">
            <div class="flex items-center justify-between mb-5 pb-3 border-b border-[var(--border-primary)]">
                <div class="flex items-center gap-2.5">
                    <div class="p-2 rounded-xl bg-gradient-to-br from-amber-500/20 to-orange-500/20 text-amber-500 border border-amber-500/30">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                        </svg>
                    </div>
                    <h3 id="queueModalTitle" class="text-base font-extrabold text-[var(--text-primary)]"><%= isRtl ? 'إضافة طابور انتظار' : 'Add Queue' %></h3>
                </div>
                <button onclick="closeModal('queueModal')" class="text-[var(--text-muted)] hover:text-[var(--text-primary)] cursor-pointer text-lg font-bold">✕</button>
            </div>
            <form id="queueForm" onsubmit="saveQueue(event)">
                <input type="hidden" id="queueEditMode" value="false">
                <div class="flex flex-col gap-4">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-bold text-[var(--text-secondary)] uppercase mb-1"><%= isRtl ? 'رقم طابور الانتظار (Queue #) *' : 'Queue Number *' %></label>
                            <input type="text" id="queueNum" required placeholder="e.g. 800" class="config-input w-full font-mono">
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-[var(--text-secondary)] uppercase mb-1"><%= isRtl ? 'اسم طابور الانتظار (Queue Name) *' : 'Queue Name *' %></label>
                            <input type="text" id="queueDesc" required placeholder="<%= isRtl ? 'مثال: طابور خدمة العملاء' : 'e.g. Support Queue' %>" class="config-input w-full">
                        </div>
                    </div>

                    <!-- Unified Queue Agents Checklist Card -->
                    <div class="border border-[var(--border-primary)] rounded-xl p-3.5 bg-[var(--bg-card)] shadow-sm">
                        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2 mb-3 pb-2.5 border-b border-[var(--border-primary)]">
                            <div class="flex items-center gap-2">
                                <div class="p-1.5 rounded-lg bg-gradient-to-r from-amber-500/20 to-indigo-500/20 border border-amber-500/30 text-amber-500">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                                    </svg>
                                </div>
                                <div>
                                    <h4 class="text-xs font-black text-[var(--text-primary)] uppercase"><%= isRtl ? 'قائمة وكلاء طابور الانتظار (Queue Agents)' : 'Queue Agents Checklist' %></h4>
                                    <p class="text-[11px] text-[var(--text-muted)]"><%= isRtl ? 'انقر على زر التحويلة للتبديل: (Off ➔ static + dyn)' : 'Click extension button to toggle: (Off ➔ static + dyn)' %></p>
                                </div>
                            </div>
                            <div class="flex items-center gap-2 shrink-0">
                                <input type="text" id="queueAgentSearch" oninput="filterQueueAgentChecklist()" placeholder="<%= isRtl ? 'بحث...' : 'Search...' %>" class="config-input py-1 px-2 text-xs w-32">
                                <button type="button" onclick="clearAllQueueAgents()" class="text-[11px] font-bold text-red-500 hover:text-red-600 dark:text-red-400 underline cursor-pointer whitespace-nowrap"><%= isRtl ? 'إعادة ضبط الكل' : 'Clear All' %></button>
                            </div>
                        </div>

                        <!-- Scrollable Single Agent Checklist Container -->
                        <div id="queueAgentsChecklistContainer" class="space-y-1.5 max-h-56 overflow-y-auto pr-1 mb-3">
                            <!-- Populated dynamically -->
                        </div>

                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 pt-2.5 border-t border-[var(--border-primary)]/50">
                            <div>
                                <label class="block text-[10px] font-bold text-amber-600 dark:text-amber-400 uppercase mb-0.5"><%= isRtl ? 'ملخص الوكلاء الثابتين (Static)' : 'Static Agents Summary' %></label>
                                <input type="text" id="queueStaticList" oninput="renderQueueAgentChecklist()" placeholder="e.g. 101, 102" class="config-input w-full font-mono text-xs">
                            </div>
                            <div>
                                <label class="block text-[10px] font-bold text-indigo-600 dark:text-indigo-400 uppercase mb-0.5"><%= isRtl ? 'ملخص الوكلاء الديناميكيين (Dynamic)' : 'Dynamic Agents Summary' %></label>
                                <input type="text" id="queueDynList" oninput="renderQueueAgentChecklist()" placeholder="e.g. 104, 105" class="config-input w-full font-mono text-xs">
                            </div>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 border border-sky-500/30 rounded-xl p-3.5 bg-sky-500/5 dark:bg-sky-950/10">
                        <div>
                            <label class="block text-xs font-black text-sky-600 dark:text-sky-400 uppercase mb-1"><%= isRtl ? 'استراتيجية الاتصال (Ring Strategy)' : 'Ring Strategy' %></label>
                            <select id="queueStrategy" class="config-input w-full font-medium">
                                <option value="rrmemory" selected><%= isRtl ? 'rrmemory (التدوير مع الذاكرة - موصى به)' : 'rrmemory (Round Robin Memory - Recommended)' %></option>
                                <option value="ringall"><%= isRtl ? 'ringall (رنين جميع الهواتف)' : 'ringall (Ring All)' %></option>
                                <option value="leastrecent"><%= isRtl ? 'leastrecent (الأقل استقبالاً مؤخراً)' : 'leastrecent (Least Recent)' %></option>
                                <option value="fewestcalls"><%= isRtl ? 'fewestcalls (الأقل في عدد المكالمات)' : 'fewestcalls (Fewest Calls)' %></option>
                                <option value="random"><%= isRtl ? 'random (رنين عشوائي)' : 'random (Random)' %></option>
                                <option value="linear"><%= isRtl ? 'linear (رنين خطي حسب الترتيب)' : 'linear (Linear)' %></option>
                                <option value="wrandom"><%= isRtl ? 'wrandom (عشوائي موزون)' : 'wrandom (Weighted Random)' %></option>
                            </select>
                        </div>

                        <div>
                            <label class="block text-xs font-black text-sky-600 dark:text-sky-400 uppercase mb-1"><%= isRtl ? 'موسيقى الانتظار (Music On Hold)' : 'Music On Hold' %></label>
                            <select id="queueMoh" class="config-input w-full font-medium">
                                <option value="default" selected><%= isRtl ? 'default (الموسيقى الافتراضية)' : 'default (Default MoH)' %></option>
                                <option value="none"><%= isRtl ? 'none (بدون موسيقى / صمت)' : 'none (Silence / No Music)' %></option>
                            </select>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 border border-purple-500/30 rounded-xl p-3.5 bg-purple-500/5 dark:bg-purple-950/10">
                        <div>
                            <label class="block text-xs font-black text-purple-600 dark:text-purple-400 uppercase mb-1"><%= isRtl ? 'رسالة الترحيب / الإعلان (Join Announcement)' : 'Join Announcement' %></label>
                            <select id="queueAnnMsg" class="config-input w-full font-medium">
                                <option value="0"><%= isRtl ? 'بدون إعلان / لا يوجد' : 'None / No Announcement' %></option>
                            </select>
                        </div>

                        <div>
                            <label class="block text-xs font-black text-purple-600 dark:text-purple-400 uppercase mb-1"><%= isRtl ? 'وضع تسجيل المكالمات (Call Recording)' : 'Call Recording' %></label>
                            <select id="queueRecording" class="config-input w-full font-medium">
                                <option value="yes" selected><%= isRtl ? 'نعم (تسجيل المكالمات في الخلفية)' : 'Yes (Background Recording)' %></option>
                                <option value="no"><%= isRtl ? 'لا (إيقاف التسجيل)' : 'No (Disable Recording)' %></option>
                            </select>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 border border-rose-500/30 rounded-xl p-3.5 bg-rose-500/5 dark:bg-rose-950/10">
                        <div>
                            <label class="block text-xs font-black text-rose-600 dark:text-rose-400 uppercase mb-1"><%= isRtl ? 'أقصى وقت انتظار (بالثواني)' : 'Max Wait Time (sec)' %></label>
                            <input type="number" id="queueMaxWait" min="0" value="0" placeholder="0 = Unlimited" class="config-input w-full font-mono">
                            <span class="text-[10px] text-[var(--text-muted)] font-semibold"><%= isRtl ? '0 = غير محدود' : '0 = Unlimited' %></span>
                        </div>
                        <div>
                            <label class="block text-xs font-black text-rose-600 dark:text-rose-400 uppercase mb-1"><%= isRtl ? 'مهلة رنين الوكيل (بالثواني)' : 'Agent Timeout (sec)' %></label>
                            <input type="number" id="queueAgentTimeout" min="1" value="15" class="config-input w-full font-mono">
                        </div>
                        <div>
                            <label class="block text-xs font-black text-rose-600 dark:text-rose-400 uppercase mb-1"><%= isRtl ? 'إعادة المحاولة (بالثواني)' : 'Retry Delay (sec)' %></label>
                            <input type="number" id="queueRetry" min="1" value="5" class="config-input w-full font-mono">
                        </div>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 border border-emerald-500/30 rounded-xl p-3.5 bg-emerald-500/5 dark:bg-emerald-950/10">
                        <div>
                            <label class="block text-xs font-black text-emerald-600 dark:text-emerald-400 uppercase mb-1"><%= isRtl ? 'التعبئة التلقائية (Autofill)' : 'Autofill' %></label>
                            <select id="queueAutofill" class="config-input w-full font-medium">
                                <option value="yes" selected><%= isRtl ? 'نعم (مفعل)' : 'Yes (Enabled)' %></option>
                                <option value="no"><%= isRtl ? 'لا (معطل)' : 'No (Disabled)' %></option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-xs font-black text-emerald-600 dark:text-emerald-400 uppercase mb-1"><%= isRtl ? 'تخطي الوكيل المشغول (Skip Busy)' : 'Skip Busy Agent' %></label>
                            <select id="queueSkipBusy" class="config-input w-full font-medium">
                                <option value="yes" selected><%= isRtl ? 'نعم (عدم الاتصال بالوكيل المشغول)' : 'Yes (Do not ring busy agents)' %></option>
                                <option value="no"><%= isRtl ? 'لا (الاتصال حتى لو كان مشغولاً)' : 'No (Ring even if busy)' %></option>
                            </select>
                        </div>
                    </div>

                    <!-- Fail Over Destination Picker -->
                    <div class="border border-blue-500/30 rounded-xl p-3.5 bg-blue-500/5 dark:bg-blue-950/10">
                        <label class="block text-xs font-black text-blue-600 dark:text-blue-400 uppercase mb-2"><%= isRtl ? 'الوجهة عند الإخفاق / انتهاء الوقت (Fail Over Destination) *' : 'Fail Over Destination *' %></label>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                            <select id="queueDestType" onchange="onQueueDestTypeChange()" class="config-input w-full font-medium" required>
                                <option value="terminate" selected><%= isRtl ? 'إنهاء المكالمة (Terminate Call)' : 'Terminate Call / Hangup' %></option>
                                <option value="extensions"><%= isRtl ? 'الهواتف الفرعية (Extensions)' : 'Extensions' %></option>
                                <option value="ringgroups"><%= isRtl ? 'مجموعات الرنين (Ring Groups)' : 'Ring Groups' %></option>
                                <option value="queues"><%= isRtl ? 'طوابير الانتظار (Queues)' : 'Queues' %></option>
                                <option value="voicemail"><%= isRtl ? 'البريد الصوتي (Voicemail)' : 'Voicemail' %></option>
                                <option value="custom"><%= isRtl ? 'تطبيق مخصص (Custom)' : 'Custom Application' %></option>
                            </select>
                            
                            <div id="queueDestTargetContainer">
                                <select id="queueDestTargetSelect" onchange="updateQueueDestinationValue()" class="config-input w-full hidden font-medium">
                                    <option value="">== choose target ==</option>
                                </select>
                                <input type="text" id="queueDestTargetInput" oninput="updateQueueDestinationValue()" placeholder="e.g. app-blackhole,hangup,1" class="config-input w-full font-mono text-xs hidden">
                            </div>
                        </div>
                        <input type="hidden" id="queueDestination" value="app-blackhole,hangup,1" required>
                    </div>
                </div>

                <div class="flex justify-end gap-3 mt-6 pt-4 border-t border-[var(--border-primary)]">
                    <button type="button" onclick="closeModal('queueModal')" class="config-btn-secondary px-4 py-2 text-xs"><%= isRtl ? 'إلغاء' : 'Cancel' %></button>
                    <button type="submit" class="config-btn-primary px-5 py-2 text-xs"><%= isRtl ? 'حفظ طابور الانتظار' : 'Save Queue' %></button>
                </div>
            </form>
        </div>
    </div>

    <!-- MODAL 3: TRUNK FORM -->
    <div id="trunkModal" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center hidden p-4">
        <div class="bg-[var(--bg-secondary)] rounded-2xl border border-[var(--border-primary)] shadow-2xl max-w-xl w-full p-6 text-[var(--text-primary)]">
            <div class="flex items-center justify-between mb-5 pb-3 border-b border-[var(--border-primary)]">
                <h3 id="trunkModalTitle" class="text-base font-extrabold text-[var(--text-primary)]">Add Custom Trunk</h3>
                <button onclick="closeModal('trunkModal')" class="text-[var(--text-muted)] hover:text-[var(--text-primary)] cursor-pointer">✕</button>
            </div>
            <form id="trunkForm" onsubmit="saveTrunk(event)">
                <input type="hidden" id="trunkEditId" value="">
                <div class="flex flex-col gap-4">
                    <div>
                        <label class="block text-xs font-bold text-[var(--text-secondary)] uppercase mb-1">Trunk Name *</label>
                        <input type="text" id="trunkName" required placeholder="e.g. vodafone_trunk" class="config-input w-full font-mono">
                    </div>
                    <div class="relative">
                        <label class="block text-xs font-bold text-[var(--text-secondary)] uppercase mb-1">Custom Dial String *</label>
                        <input type="text" id="trunkDialString" required placeholder="e.g. dongle/dongle0/$OUTNUM$" class="config-input w-full font-mono" autocomplete="off">
                        
                        <!-- DONGLE FLOATING POPUP -->
                        <div id="dongleInfoPopup" class="absolute left-0 top-[calc(100%+4px)] w-full bg-[var(--bg-secondary)] border border-[var(--border-primary)] rounded-xl shadow-2xl p-4 z-[60] hidden space-y-2">
                            <div class="text-[11px] font-bold text-[var(--text-secondary)] uppercase flex items-center justify-between">
                                <span><%= isRtl ? 'أجهزة Dongle المتصلة:' : 'Connected Dongles:' %></span>
                                <button type="button" onclick="loadDongleInfoPopup()" class="text-[10px] text-blue-400 hover:underline">Refresh</button>
                            </div>
                            <div id="dongleInfoList" class="text-xs space-y-1.5 max-h-[160px] overflow-y-auto pr-1">
                                <span class="text-[11px] text-[var(--text-muted)]">Loading...</span>
                            </div>
                        </div>

                        <p class="text-[11px] text-[var(--text-muted)] mt-1">
                            Format: <code>tech/dial_target/$OUTNUM$</code> or similar custom dialplan resource.
                        </p>
                    </div>
                </div>
                <div class="flex justify-end gap-3 mt-6 pt-4 border-t border-[var(--border-primary)]">
                    <button type="button" onclick="closeModal('trunkModal')" class="config-btn-secondary px-4 py-2 text-xs">Cancel</button>
                    <button type="submit" class="config-btn-primary px-5 py-2 text-xs">Save Trunk</button>
                </div>
            </form>
        </div>
    </div>

    <!-- MODAL 4: INBOUND ROUTE FORM -->
    <div id="inboundModal" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center hidden p-4">
        <div class="bg-[var(--bg-secondary)] rounded-2xl border border-[var(--border-primary)] shadow-2xl max-w-lg w-full p-6 text-[var(--text-primary)]">
            <div class="flex items-center justify-between mb-5 pb-3 border-b border-[var(--border-primary)]">
                <h3 id="inboundModalTitle" class="text-base font-extrabold text-[var(--text-primary)]">Add Inbound Route</h3>
                <button onclick="closeModal('inboundModal')" class="text-[var(--text-muted)] hover:text-[var(--text-primary)] cursor-pointer">✕</button>
            </div>
            <form id="inboundForm" onsubmit="saveInboundRoute(event)">
                <input type="hidden" id="inboundEditExt" value="">
                <input type="hidden" id="inboundEditDesc" value="">
                <div class="flex flex-col gap-4">
                    <div>
                        <label class="block text-xs font-bold text-[var(--text-secondary)] uppercase mb-1">Description *</label>
                        <input type="text" id="inDescription" required placeholder="e.g. Sales Inbound" class="config-input w-full">
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-[var(--text-secondary)] uppercase mb-1">DID Number</label>
                        <input type="text" id="inExtension" placeholder="e.g. 01012345678 or leave empty for ANY" class="config-input w-full font-mono">
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-[var(--text-secondary)] uppercase mb-1">Set Destination *</label>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 mb-2">
                            <select id="inDestType" onchange="onInboundDestTypeChange()" class="config-input w-full" required>
                                <option value="">== choose one ==</option>
                                <option value="extensions"><%= isRtl ? 'الهواتف الفرعية (Extensions)' : 'Extensions' %></option>
                                <option value="ringgroups"><%= isRtl ? 'مجموعات الرنين (Ring Groups)' : 'Ring Groups' %></option>
                                <option value="queues"><%= isRtl ? 'طوابير الانتظار (Queues)' : 'Queues' %></option>
                                <option value="custom"><%= isRtl ? 'تطبيق مخصص (Custom)' : 'Custom Application' %></option>
                            </select>
                            
                            <div id="inDestTargetContainer">
                                <select id="inDestTargetSelect" onchange="updateInboundDestinationValue()" class="config-input w-full hidden">
                                    <option value="">== choose target ==</option>
                                </select>
                                <input type="text" id="inDestTargetInput" oninput="updateInboundDestinationValue()" placeholder="e.g. custom-context,s,1" class="config-input w-full font-mono hidden">
                            </div>
                        </div>
                        <input type="hidden" id="inDestination" required>
                    </div>
                </div>
                <div class="flex justify-end gap-3 mt-6 pt-4 border-t border-[var(--border-primary)]">
                    <button type="button" onclick="closeModal('inboundModal')" class="config-btn-secondary px-4 py-2 text-xs">Cancel</button>
                    <button type="submit" class="config-btn-primary px-5 py-2 text-xs">Save Inbound Route</button>
                </div>
            </form>
        </div>
    </div>

    <!-- MODAL 5: OUTBOUND ROUTE FORM -->
    <div id="outboundModal" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center hidden p-4">
        <div class="bg-[var(--bg-secondary)] rounded-2xl border border-[var(--border-primary)] shadow-2xl max-w-xl w-full p-6 text-[var(--text-primary)]">
            <div class="flex items-center justify-between mb-5 pb-3 border-b border-[var(--border-primary)]">
                <h3 id="outboundModalTitle" class="text-base font-extrabold text-[var(--text-primary)]">Add Outbound Route</h3>
                <button onclick="closeModal('outboundModal')" class="text-[var(--text-muted)] hover:text-[var(--text-primary)] cursor-pointer">✕</button>
            </div>
            <form id="outboundForm" onsubmit="saveOutboundRoute(event)">
                <input type="hidden" id="outboundEditId" value="">
                <div class="flex flex-col gap-5 max-h-[70vh] overflow-y-auto pr-1">
                    <div>
                        <label class="block text-xs font-bold text-[var(--text-secondary)] uppercase mb-1">Route Name *</label>
                        <input type="text" id="outName" required placeholder="e.g. Outbound-All" class="config-input w-full">
                    </div>
                    
                    <!-- DIAL PATTERNS SECTION -->
                    <div class="border border-[var(--border-primary)] rounded-xl p-4 bg-[var(--bg-card)]/30">
                        <label class="block text-xs font-bold text-[var(--text-primary)] uppercase mb-2">Dial Patterns *</label>
                        
                        <div id="outboundPatternsList" class="space-y-2 mb-3">
                            <!-- Rendered dynamically -->
                        </div>
                        
                        <div class="grid grid-cols-4 gap-2 bg-[var(--bg-secondary)] p-3 border border-[var(--border-primary)] rounded-lg">
                            <div>
                                <label class="block text-[10px] text-[var(--text-secondary)] uppercase mb-0.5">Prepend</label>
                                <input type="text" id="patPrepend" placeholder="prepend" class="config-input w-full text-xs font-mono py-1 px-2">
                            </div>
                            <div>
                                <label class="block text-[10px] text-[var(--text-secondary)] uppercase mb-0.5">Prefix</label>
                                <input type="text" id="patPrefix" placeholder="prefix" class="config-input w-full text-xs font-mono py-1 px-2">
                            </div>
                            <div>
                                <label class="block text-[10px] text-[var(--text-secondary)] uppercase mb-0.5">Pattern *</label>
                                <input type="text" id="patPattern" placeholder="e.g. X." class="config-input w-full text-xs font-mono py-1 px-2">
                            </div>
                            <div>
                                <label class="block text-[10px] text-[var(--text-secondary)] uppercase mb-0.5">CallerID</label>
                                <input type="text" id="patCid" placeholder="CID" class="config-input w-full text-xs font-mono py-1 px-2">
                            </div>
                        </div>
                        <button type="button" onclick="addDialPatternToModalList()" class="mt-2 text-xs text-blue-400 font-semibold hover:underline flex items-center gap-1">
                            <span id="addPatternBtn">+ Add Pattern</span>
                        </button>
                    </div>
                    
                    <!-- TRUNK SEQUENCE SECTION -->
                    <div class="border border-[var(--border-primary)] rounded-xl p-4 bg-[var(--bg-card)]/30">
                        <label class="block text-xs font-bold text-[var(--text-primary)] uppercase mb-2">Trunk Sequence *</label>
                        
                        <div id="outboundTrunksSequenceList" class="space-y-2 mb-3">
                            <!-- Rendered dynamically -->
                        </div>
                        
                        <div class="flex items-center gap-2">
                            <select id="sequenceTrunkSelect" class="config-input w-full text-xs">
                                <option value="">-- Choose Trunk --</option>
                            </select>
                            <button type="button" onclick="addTrunkToModalSequence()" class="px-3 py-2 text-xs bg-emerald-500/10 hover:bg-emerald-500/20 text-emerald-400 border border-emerald-500/30 rounded cursor-pointer transition">
                                Add
                            </button>
                        </div>
                    </div>
                </div>
                <div class="flex justify-end gap-3 mt-6 pt-4 border-t border-[var(--border-primary)]">
                    <button type="button" onclick="closeModal('outboundModal')" class="config-btn-secondary px-4 py-2 text-xs">Cancel</button>
                    <button type="submit" class="config-btn-primary px-5 py-2 text-xs">Save Outbound Route</button>
                </div>
            </form>
        </div>
    </div>
    <!-- MODAL 8: TIME GROUP FORM -->
    <div id="timeGroupModal" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center hidden p-4">
        <div class="bg-[var(--bg-secondary)] rounded-2xl border border-[var(--border-primary)] shadow-2xl max-w-xl w-full p-6 text-[var(--text-primary)]">
            <div class="flex items-center justify-between mb-4 pb-3 border-b border-[var(--border-primary)]">
                <h3 id="timeGroupModalTitle" class="text-base font-extrabold text-[var(--text-primary)]">Add Time Group</h3>
                <button onclick="closeModal('timeGroupModal')" class="text-[var(--text-muted)] hover:text-[var(--text-primary)] cursor-pointer">✕</button>
            </div>
            <form id="timeGroupForm" onsubmit="saveTimeGroup(event)">
                <input type="hidden" id="tgEditMode" value="false">
                <input type="hidden" id="tgId" value="">
                
                <div class="flex flex-col gap-4">
                    <div>
                        <label class="block text-xs font-bold text-[var(--text-secondary)] uppercase mb-1">Group Description *</label>
                        <input type="text" id="tgDescription" required placeholder="e.g. Working Hours" class="config-input w-full">
                    </div>
                    
                    <div>
                        <label class="block text-xs font-bold text-[var(--text-primary)] uppercase mb-1">Configured Time Rules</label>
                        <p class="text-[10px] text-[var(--text-muted)] mb-2">Calls will route according to these rules. If multiple rules are defined, the condition matches if ANY rule matches.</p>
                        
                        <div id="timeGroupRulesListContainer" class="space-y-4 max-h-[320px] overflow-y-auto pr-1 mb-3">
                            <!-- Populated dynamically -->
                        </div>
                        
                        <button type="button" onclick="addTimeGroupRuleToModal()" class="w-full py-2 border border-dashed border-[var(--border-primary)] hover:border-blue-500/50 rounded-xl text-xs font-bold text-blue-400 bg-blue-500/5 hover:bg-blue-500/10 cursor-pointer transition flex items-center justify-center gap-1.5">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                            </svg>
                            Add Time Interval Rule
                        </button>
                    </div>
                </div>
                
                <div class="flex justify-end gap-3 mt-6 pt-4 border-t border-[var(--border-primary)]">
                    <button type="button" onclick="closeModal('timeGroupModal')" class="config-btn-secondary px-4 py-2 text-xs">Cancel</button>
                    <button type="submit" class="config-btn-primary px-5 py-2 text-xs">Save Time Group</button>
                </div>
            </form>
        </div>
    </div>

    <!-- MODAL 9: TIME CONDITION FORM -->
    <div id="timeConditionModal" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center hidden p-4">
        <div class="bg-[var(--bg-secondary)] rounded-2xl border border-[var(--border-primary)] shadow-2xl max-w-xl w-full p-6 text-[var(--text-primary)]">
            <div class="flex items-center justify-between mb-4 pb-3 border-b border-[var(--border-primary)]">
                <h3 id="timeConditionModalTitle" class="text-base font-extrabold text-[var(--text-primary)]">Add Time Condition</h3>
                <button onclick="closeModal('timeConditionModal')" class="text-[var(--text-muted)] hover:text-[var(--text-primary)] cursor-pointer">✕</button>
            </div>
            <form id="timeConditionForm" onsubmit="saveTimeCondition(event)">
                <input type="hidden" id="tcEditMode" value="false">
                <input type="hidden" id="tcId" value="">
                
                <div class="flex flex-col gap-4">
                    <div>
                        <label class="block text-xs font-bold text-[var(--text-secondary)] uppercase mb-1">Display Name *</label>
                        <input type="text" id="tcDisplayName" required placeholder="e.g. Office Hours Route" class="config-input w-full">
                    </div>
                    
                    <div>
                        <label class="block text-xs font-bold text-[var(--text-secondary)] uppercase mb-1">Time Group *</label>
                        <select id="tcTimeGroup" required class="config-input w-full">
                            <option value="">-- Choose Time Group --</option>
                        </select>
                    </div>
                    
                    <!-- Destination if MATCH (True) -->
                    <div class="border border-[var(--border-primary)]/50 rounded-xl p-4 bg-[var(--bg-card)]/10">
                        <label class="block text-xs font-black text-emerald-400 uppercase mb-2">Destination if matched (True / Open) *</label>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                            <div>
                                <label class="block text-[10px] text-[var(--text-secondary)] uppercase mb-1">Destination Type</label>
                                <select id="tcTrueType" onchange="onTcDestTypeChange('true')" class="config-input w-full" required>
                                    <option value="">-- choose type --</option>
                                    <option value="extensions"><%= isRtl ? 'الهواتف الفرعية (Extensions)' : 'Extensions' %></option>
                                    <option value="ringgroups"><%= isRtl ? 'مجموعات الرنين (Ring Groups)' : 'Ring Groups' %></option>
                                    <option value="voicemail"><%= isRtl ? 'البريد الصوتي (Voicemail)' : 'Voicemail Box' %></option>
                                    <option value="timeconditions"><%= isRtl ? 'شروط الوقت (Time Conditions)' : 'Time Conditions' %></option>
                                    <option value="terminate"><%= isRtl ? 'إنهاء المكالمة (Terminate Call)' : 'Terminate Call' %></option>
                                    <option value="custom"><%= isRtl ? 'تطبيق مخصص (Custom)' : 'Custom Application' %></option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-[10px] text-[var(--text-secondary)] uppercase mb-1">Target</label>
                                <div id="tcTrueTargetContainer">
                                    <select id="tcTrueTargetSelect" onchange="updateTcDestValue('true')" class="config-input w-full hidden">
                                        <option value="">-- choose target --</option>
                                    </select>
                                    <input type="text" id="tcTrueTargetInput" oninput="updateTcDestValue('true')" placeholder="e.g. custom-context,s,1" class="config-input w-full font-mono hidden">
                                </div>
                            </div>
                        </div>
                        <input type="hidden" id="tcTrueGoto" required>
                    </div>

                    <!-- Destination if NO MATCH (False) -->
                    <div class="border border-[var(--border-primary)]/50 rounded-xl p-4 bg-[var(--bg-card)]/10">
                        <label class="block text-xs font-black text-rose-400 uppercase mb-2">Destination if NOT matched (False / Closed) *</label>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                            <div>
                                <label class="block text-[10px] text-[var(--text-secondary)] uppercase mb-1">Destination Type</label>
                                <select id="tcFalseType" onchange="onTcDestTypeChange('false')" class="config-input w-full" required>
                                    <option value="">-- choose type --</option>
                                    <option value="extensions"><%= isRtl ? 'الهواتف الفرعية (Extensions)' : 'Extensions' %></option>
                                    <option value="ringgroups"><%= isRtl ? 'مجموعات الرنين (Ring Groups)' : 'Ring Groups' %></option>
                                    <option value="voicemail"><%= isRtl ? 'البريد الصوتي (Voicemail)' : 'Voicemail Box' %></option>
                                    <option value="timeconditions"><%= isRtl ? 'شروط الوقت (Time Conditions)' : 'Time Conditions' %></option>
                                    <option value="terminate"><%= isRtl ? 'إنهاء المكالمة (Terminate Call)' : 'Terminate Call' %></option>
                                    <option value="custom"><%= isRtl ? 'تطبيق مخصص (Custom)' : 'Custom Application' %></option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-[10px] text-[var(--text-secondary)] uppercase mb-1">Target</label>
                                <div id="tcFalseTargetContainer">
                                    <select id="tcFalseTargetSelect" onchange="updateTcDestValue('false')" class="config-input w-full hidden">
                                        <option value="">-- choose target --</option>
                                    </select>
                                    <input type="text" id="tcFalseTargetInput" oninput="updateTcDestValue('false')" placeholder="e.g. custom-context,s,1" class="config-input w-full font-mono hidden">
                                </div>
                            </div>
                        </div>
                        <input type="hidden" id="tcFalseGoto" required>
                    </div>
                </div>
                
                <div class="flex justify-end gap-3 mt-6 pt-4 border-t border-[var(--border-primary)]">
                    <button type="button" onclick="closeModal('timeConditionModal')" class="config-btn-secondary px-4 py-2 text-xs">Cancel</button>
                    <button type="submit" class="config-btn-primary px-5 py-2 text-xs">Save Time Condition</button>
                </div>
            </form>
        </div>
    </div>

    <!-- CLIENT SCRIPT -->
    <script>
        const isRtl = <%= isRtl ? 'true' : 'false' %>;
        let loadedTrunksList = [];
        let loadedRecordingsList = [];
        let loadedExtensionsList = [];
        let loadedRingGroupsList = [];
        let loadedQueuesList = [];
        let modalPatternsList = [];
        let modalTrunksSequence = [];
        let editingPatternIndex = -1;

        function showToast(message, type = 'info') {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            const bgClass = type === 'success' ? 'bg-emerald-600' : type === 'error' ? 'bg-red-600' : 'bg-slate-800';
            toast.className = `${bgClass} text-white text-xs font-bold px-4 py-3 rounded-lg shadow-xl flex items-center gap-2 border border-white/20 transition-all duration-300 transform translate-y-2 opacity-0`;
            toast.innerHTML = `<span>${message}</span>`;
            container.appendChild(toast);
            setTimeout(() => {
                toast.classList.remove('translate-y-2', 'opacity-0');
            }, 10);
            setTimeout(() => {
                toast.classList.add('opacity-0');
                setTimeout(() => toast.remove(), 300);
            }, 4000);
        }

        function switchTab(tabId) {
            document.querySelectorAll('.tab-section').forEach(el => el.classList.add('hidden'));
            document.querySelectorAll('.config-tab-btn').forEach(btn => {
                btn.classList.remove('config-tab-active');
                btn.classList.add('config-tab-inactive');
            });
            document.getElementById('section-' + tabId).classList.remove('hidden');
            const btn = document.getElementById('tab-btn-' + tabId);
            btn.classList.remove('config-tab-inactive');
            btn.classList.add('config-tab-active');

            if (tabId === 'extensions') fetchExtensions();
            if (tabId === 'ringgroups') { fetchRecordings(); fetchRingGroups(); fetchExtensions(); }
            if (tabId === 'queues') { fetchRecordings(); fetchExtensions(); fetchRingGroups(); fetchQueues(); }
            if (tabId === 'recordings') fetchRecordings();
            if (tabId === 'trunks') fetchTrunks();
            if (tabId === 'inbound') { fetchExtensions(); fetchRingGroups(); fetchQueues(); fetchInboundRoutes(); }
            if (tabId === 'outbound') fetchOutboundRoutes();
            if (tabId === 'voicemail') { fetchRecordings(); fetchVoicemailExtensions(); }
            if (tabId === 'diagram') fetchDiagramData();
            if (tabId === 'timegroups') fetchTimeGroups();
            if (tabId === 'timeconditions') { fetchExtensions(); fetchRingGroups(); fetchQueues(); fetchTimeGroups(); fetchTimeConditions(); }
        }

        function openModal(id) { document.getElementById(id).classList.remove('hidden'); }
        function closeModal(id) { document.getElementById(id).classList.add('hidden'); }

        // --- RELOAD PBX CONFIG ---
        function reloadPbxConfig() {
            const btn = document.getElementById('reloadPbxBtn');
            const icon = document.getElementById('reloadIcon');
            const btnText = document.getElementById('reloadBtnText');
            
            btn.disabled = true;
            icon.classList.add('animate-spin');
            btnText.textContent = isRtl ? 'جاري تطبيق التغييرات...' : 'Applying PBX Config...';

            fetch('/api/config/reload', { method: 'POST' })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        showToast(isRtl ? 'تم تطبيق إعدادات المقسم بنجاح!' : 'PBX Configuration applied successfully!', 'success');
                    } else {
                        showToast(isRtl ? 'فشل تطبيق الإعدادات: ' + (data.error || '') : 'PBX Reload Failed: ' + (data.error || ''), 'error');
                    }
                })
                .catch(err => showToast('Network Error: ' + err.message, 'error'))
                .finally(() => {
                    btn.disabled = false;
                    icon.classList.remove('animate-spin');
                    btnText.textContent = isRtl ? 'تطبيق تغييرات المقسم (Apply PBX Changes)' : 'Apply PBX Configuration';
                });
        }

        // --- 1. EXTENSIONS ---
        function fetchExtensions() {
            const tbody = document.getElementById('extensions-table-body');
            fetch('/api/config/extensions')
                .then(res => res.json())
                .then(data => {
                    if (!data.success || !data.extensions) return;
                    loadedExtensionsList = data.extensions;
                    renderQuickPickPills();
                    if (!tbody) return;
                    tbody.innerHTML = '';
                    if (data.extensions.length === 0) {
                        tbody.innerHTML = '<tr><td colspan="8" class="py-6 text-center text-[var(--text-muted)]">No extensions found.</td></tr>';
                        return;
                    }
                    data.extensions.forEach(ext => {
                        const tr = document.createElement('tr');
                        tr.className = 'hover:bg-[var(--bg-hover)] transition-colors';
                        const isVmOn = (ext.voicemail === 'default' || ext.voicemail === 'enabled');
                        const vmBadge = isVmOn 
                            ? `<span class="px-2 py-0.5 text-[11px] font-bold rounded bg-emerald-500/15 text-emerald-400 border border-emerald-500/20">Enabled</span>`
                            : `<span class="px-2 py-0.5 text-[11px] font-bold rounded bg-slate-500/15 text-slate-400 border border-slate-500/20">Disabled</span>`;

                        tr.innerHTML = `
                            <td class="py-3 px-4 font-mono font-bold text-[var(--text-primary)]">${ext.extension}</td>
                            <td class="py-3 px-4 font-bold text-[var(--text-primary)]">${ext.name || '-'}</td>
                            <td class="py-3 px-4 font-mono text-xs text-[var(--text-secondary)]">${ext.secret || '-'}</td>
                            <td class="py-3 px-4"><span class="px-2 py-0.5 text-[11px] font-bold rounded bg-slate-500/15 text-slate-300">Generic SIP Device</span></td>
                            <td class="py-3 px-4"><span class="px-2 py-0.5 text-[11px] font-bold rounded bg-emerald-500/15 text-emerald-400 border border-emerald-500/20">Yes</span></td>
                            <td class="py-3 px-4"><span class="px-2 py-0.5 text-[11px] font-bold rounded bg-purple-500/15 text-purple-400 border border-purple-500/20">Always</span></td>
                            <td class="py-3 px-4">${vmBadge}</td>
                            <td class="py-3 px-4 text-center">
                                <div class="flex items-center justify-center gap-2">
                                    <button onclick="editExtension('${ext.extension}', \`${(ext.name || '').replace(/`/g, '\\`')}\`, '${ext.secret}', '${ext.voicemail}')" class="px-2.5 py-1 text-xs font-semibold text-blue-400 hover:bg-blue-500/10 rounded border border-blue-500/30">Edit</button>
                                    <button onclick="deleteExtension('${ext.extension}')" class="px-2.5 py-1 text-xs font-semibold text-red-400 hover:bg-red-500/10 rounded border border-red-500/30">Delete</button>
                                </div>
                            </td>
                        `;
                        tbody.appendChild(tr);
                    });
                })
                .catch(err => console.error(err));
        }

        function openExtensionModal() {
            document.getElementById('extModalTitle').textContent = isRtl ? 'إضافة تحويلة جديدة (Generic SIP Device)' : 'Add Extension (Generic SIP Device)';
            document.getElementById('extEditMode').value = "false";
            document.getElementById('extNum').disabled = false;
            document.getElementById('extensionForm').reset();
            document.getElementById('extVoicemail').value = "disabled";
            openModal('extensionModal');
        }

        function editExtension(extNum, name, secret, voicemail) {
            document.getElementById('extModalTitle').textContent = (isRtl ? 'تعديل التحويلة ' : 'Edit Extension ') + extNum;
            document.getElementById('extEditMode').value = "true";
            document.getElementById('extNum').value = extNum;
            document.getElementById('extNum').disabled = true;
            document.getElementById('extName').value = name || '';
            document.getElementById('extSecret').value = secret || '';
            document.getElementById('extVoicemail').value = (voicemail === 'default' || voicemail === 'enabled') ? "enabled" : "disabled";
            openModal('extensionModal');
        }

        function saveExtension(e) {
            e.preventDefault();
            const isEdit = document.getElementById('extEditMode').value === "true";
            const extNum = document.getElementById('extNum').value.trim();
            const name = document.getElementById('extName').value.trim();
            const secret = document.getElementById('extSecret').value.trim();
            const voicemail = document.getElementById('extVoicemail').value;

            const url = isEdit ? '/api/config/extensions/' + extNum : '/api/config/extensions';
            const method = isEdit ? 'PUT' : 'POST';

            fetch(url, {
                method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ extension: extNum, name, secret, voicemail })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    showToast(data.message, 'success');
                    closeModal('extensionModal');
                    fetchExtensions();
                } else {
                    showToast(data.error || 'Failed to save extension', 'error');
                }
            })
            .catch(err => showToast(err.message, 'error'));
        }

        function deleteExtension(extNum) {
            if (!confirm(`Delete extension ${extNum}?`)) return;
            fetch('/api/config/extensions/' + extNum, { method: 'DELETE' })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        showToast(data.message, 'success');
                        fetchExtensions();
                    } else showToast(data.error, 'error');
                });
        }

        // --- 2. RING GROUPS ---
        function renderQuickPickPills() {
            const container = document.getElementById('rgQuickPickContainer');
            if (!container) return;
            container.innerHTML = '';
            if (loadedExtensionsList.length === 0) {
                container.innerHTML = '<span class="text-[11px] text-[var(--text-muted)]">No extensions available.</span>';
                return;
            }
            const currentSelected = parseRgListArray();

            loadedExtensionsList.forEach(ext => {
                const isSelected = currentSelected.includes(String(ext.extension));
                const pill = document.createElement('div');
                pill.className = `ext-pill text-xs px-2.5 py-1 rounded-lg border font-mono font-bold ${isSelected ? 'active' : 'bg-[var(--bg-secondary)] text-[var(--text-secondary)] border-[var(--border-primary)]'}`;
                pill.textContent = `${ext.extension} (${ext.name || 'Ext'})`;
                pill.onclick = () => toggleQuickPickExt(String(ext.extension));
                container.appendChild(pill);
            });
        }

        function parseRgListArray() {
            const val = document.getElementById('rgList').value || '';
            return val.split(/[\s\-,]+/).map(s => s.trim()).filter(Boolean);
        }

        function toggleQuickPickExt(extNum) {
            let list = parseRgListArray();
            if (list.includes(extNum)) {
                list = list.filter(e => e !== extNum);
            } else {
                list.push(extNum);
            }
            document.getElementById('rgList').value = list.join(', ');
            renderQuickPickPills();
        }

        function clearQuickPickExts() {
            document.getElementById('rgList').value = '';
            renderQuickPickPills();
        }

        function populateAnnouncementsDropdown() {
            const sel = document.getElementById('rgAnnMsg');
            if (!sel) return;
            sel.innerHTML = '<option value="0">None / No Announcement</option>';
            loadedRecordingsList.forEach(r => {
                const opt = document.createElement('option');
                opt.value = r.id;
                opt.textContent = `${r.displayname} (ID: ${r.id})`;
                sel.appendChild(opt);
            });
        }

        function fetchRingGroups() {
            const tbody = document.getElementById('ringgroups-table-body');
            if (!tbody) return;
            fetch('/api/config/ringgroups')
                .then(res => res.json())
                .then(data => {
                    if (!data.success || !data.ringgroups) return;
                    loadedRingGroupsList = data.ringgroups;
                    tbody.innerHTML = '';
                    if (data.ringgroups.length === 0) {
                        tbody.innerHTML = '<tr><td colspan="9" class="py-6 text-center text-[var(--text-muted)]">No ring groups found.</td></tr>';
                        return;
                    }
                    data.ringgroups.forEach(rg => {
                        const tr = document.createElement('tr');
                        tr.className = 'hover:bg-[var(--bg-hover)] transition-colors';
                        const recMatch = loadedRecordingsList.find(r => r.id == rg.annmsg_id);
                        const annText = recMatch ? recMatch.displayname : (rg.annmsg_id ? 'ID #' + rg.annmsg_id : 'None');

                        tr.innerHTML = `
                            <td class="py-3 px-4 font-mono font-bold text-[var(--text-primary)]">${rg.grpnum}</td>
                            <td class="py-3 px-4 font-bold text-[var(--text-primary)]">${rg.description || '-'}</td>
                            <td class="py-3 px-4 font-mono text-xs text-[var(--text-secondary)]">${rg.strategy || 'ringall'}</td>
                            <td class="py-3 px-4 font-mono text-xs text-[var(--text-secondary)]">${annText}</td>
                            <td class="py-3 px-4 font-mono text-xs text-[var(--text-secondary)]">${rg.grplist}</td>
                            <td class="py-3 px-4"><span class="px-2 py-0.5 text-[11px] font-bold rounded bg-emerald-500/15 text-emerald-400 border border-emerald-500/20">Yes</span></td>
                            <td class="py-3 px-4"><span class="px-2 py-0.5 text-[11px] font-bold rounded bg-purple-500/15 text-purple-400 border border-purple-500/20">Always</span></td>
                            <td class="py-3 px-4 font-mono text-xs text-blue-400 font-bold">${rg.postdest || '-'}</td>
                            <td class="py-3 px-4 text-center">
                                <div class="flex items-center justify-center gap-2">
                                    <button onclick="editRingGroup('${rg.grpnum}', \`${(rg.description || '').replace(/`/g, '\\`')}\`, '${rg.strategy}', '${rg.grptime}', '${rg.grplist}', '${rg.annmsg_id || 0}')" class="px-2.5 py-1 text-xs font-semibold text-blue-400 hover:bg-blue-500/10 rounded border border-blue-500/30">Edit</button>
                                    <button onclick="deleteRingGroup('${rg.grpnum}')" class="px-2.5 py-1 text-xs font-semibold text-red-400 hover:bg-red-500/10 rounded border border-red-500/30">Delete</button>
                                </div>
                            </td>
                        `;
                        tbody.appendChild(tr);
                    });
                })
                .catch(err => console.error(err));
        }

        function openRingGroupModal() {
            document.getElementById('rgModalTitle').textContent = isRtl ? 'إضافة مجموعة جديدة' : 'Add Ring Group';
            document.getElementById('rgEditMode').value = "false";
            document.getElementById('rgNum').disabled = false;
            document.getElementById('ringGroupForm').reset();
            populateAnnouncementsDropdown();
            renderQuickPickPills();
            openModal('ringGroupModal');
        }

        function editRingGroup(grpnum, description, strategy, grptime, grplist, annmsg_id) {
            document.getElementById('rgModalTitle').textContent = (isRtl ? 'تعديل المجموعة ' : 'Edit Ring Group ') + grpnum;
            document.getElementById('rgEditMode').value = "true";
            document.getElementById('rgNum').value = grpnum;
            document.getElementById('rgNum').disabled = true;
            document.getElementById('rgDesc').value = description || '';
            document.getElementById('rgStrategy').value = strategy || 'ringall';
            document.getElementById('rgTime').value = grptime || 20;
            document.getElementById('rgList').value = grplist || '';
            populateAnnouncementsDropdown();
            document.getElementById('rgAnnMsg').value = annmsg_id || 0;
            renderQuickPickPills();
            openModal('ringGroupModal');
        }

        function saveRingGroup(e) {
            e.preventDefault();
            const isEdit = document.getElementById('rgEditMode').value === "true";
            const grpnum = document.getElementById('rgNum').value.trim();
            const description = document.getElementById('rgDesc').value.trim();
            const strategy = document.getElementById('rgStrategy').value;
            const grptime = document.getElementById('rgTime').value;
            const grplist = document.getElementById('rgList').value.trim();
            const annmsg_id = document.getElementById('rgAnnMsg').value;

            const url = isEdit ? '/api/config/ringgroups/' + grpnum : '/api/config/ringgroups';
            const method = isEdit ? 'PUT' : 'POST';

            fetch(url, {
                method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ grpnum, description, strategy, grptime, grplist, annmsg_id })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    showToast(data.message, 'success');
                    closeModal('ringGroupModal');
                    fetchRingGroups();
                } else showToast(data.error, 'error');
            });
        }

        function deleteRingGroup(grpnum) {
            if (!confirm(`Delete ring group ${grpnum}?`)) return;
            fetch('/api/config/ringgroups/' + grpnum, { method: 'DELETE' })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        showToast(data.message, 'success');
                        fetchRingGroups();
                    } else showToast(data.error, 'error');
                });
        }

        // --- 2.5 QUEUES MANAGEMENT JS ---
        function renderQueueAgentChecklist() {
            const container = document.getElementById('queueAgentsChecklistContainer');
            if (!container) return;
            container.innerHTML = '';

            if (loadedExtensionsList.length === 0) {
                container.innerHTML = `<span class="text-xs text-[var(--text-muted)] italic">${isRtl ? 'لا توجد تحويلات مسجلة بالمجمّع' : 'No extensions found.'}</span>`;
                return;
            }

            const currentStatic = parseQueueExtArray('queueStaticList');
            const currentDyn = parseQueueExtArray('queueDynList');
            const filterTerm = (document.getElementById('queueAgentSearch')?.value || '').toLowerCase().trim();

            loadedExtensionsList.forEach(ext => {
                const extStr = String(ext.extension);
                const nameStr = String(ext.name || 'Ext');
                if (filterTerm && !extStr.toLowerCase().includes(filterTerm) && !nameStr.toLowerCase().includes(filterTerm)) {
                    return;
                }

                const isStatic = currentStatic.includes(extStr);
                const isDyn = currentDyn.includes(extStr);
                const isAssigned = isStatic || isDyn;

                let badgeStyle = 'bg-slate-200/80 text-slate-700 dark:bg-zinc-800/80 dark:text-zinc-400 border-slate-300 dark:border-zinc-700 hover:border-amber-500/50';
                let badgeText = 'Off';

                if (isAssigned) {
                    badgeStyle = 'bg-gradient-to-r from-amber-500 to-indigo-600 text-white font-black border-purple-600 shadow-md';
                    badgeText = 'static + dyn';
                }

                const item = document.createElement('div');
                item.className = 'flex items-center justify-between p-2 rounded-xl border border-[var(--border-primary)]/60 bg-[var(--bg-secondary)] hover:border-blue-500/40 transition-all gap-2';
                
                item.innerHTML = `
                    <div class="flex items-center gap-2 min-w-0">
                        <span class="px-2 py-0.5 rounded-md font-mono text-xs font-bold bg-[var(--bg-card)] border border-[var(--border-primary)] text-[var(--text-primary)] shrink-0">${extStr}</span>
                        <span class="text-xs font-semibold text-[var(--text-primary)] truncate">${nameStr}</span>
                    </div>
                    <button type="button" onclick="cycleQueueAgentRole('${extStr}')" class="px-3 py-1 text-xs rounded-lg border font-bold cursor-pointer transition-all shrink-0 ${badgeStyle}">
                        ${badgeText}
                    </button>
                `;
                container.appendChild(item);
            });
        }

        function filterQueueAgentChecklist() {
            renderQueueAgentChecklist();
        }

        function cycleQueueAgentRole(extStr) {
            let staticList = parseQueueExtArray('queueStaticList');
            let dynList = parseQueueExtArray('queueDynList');

            const isStatic = staticList.includes(extStr);
            const isDyn = dynList.includes(extStr);

            if (isStatic || isDyn) {
                // Currently ON -> Turn OFF (remove from both)
                staticList = staticList.filter(e => e !== extStr);
                dynList = dynList.filter(e => e !== extStr);
            } else {
                // Currently OFF -> Turn ON (add to static + dyn)
                staticList.push(extStr);
                dynList.push(extStr);
            }

            document.getElementById('queueStaticList').value = staticList.join(', ');
            document.getElementById('queueDynList').value = dynList.join(', ');
            renderQueueAgentChecklist();
        }

        function parseQueueExtArray(inputId) {
            const el = document.getElementById(inputId);
            if (!el) return [];
            const val = el.value || '';
            return val.split(/[\r\n\s\-,]+/).map(s => s.trim()).filter(Boolean);
        }

        function clearAllQueueAgents() {
            document.getElementById('queueStaticList').value = '';
            document.getElementById('queueDynList').value = '';
            renderQueueAgentChecklist();
        }

        function populateQueueAnnouncementsDropdown() {
            const sel = document.getElementById('queueAnnMsg');
            if (!sel) return;
            sel.innerHTML = '<option value="0">None / No Announcement</option>';
            loadedRecordingsList.forEach(r => {
                const opt = document.createElement('option');
                opt.value = r.id;
                opt.textContent = `${r.displayname} (ID: ${r.id})`;
                sel.appendChild(opt);
            });
        }

        function fetchQueues() {
            const tbody = document.getElementById('queues-table-body');
            if (!tbody) return;
            fetch('/api/config/queues')
                .then(res => res.json())
                .then(data => {
                    if (!data.success || !data.queues) return;
                    loadedQueuesList = data.queues;
                    tbody.innerHTML = '';
                    if (data.queues.length === 0) {
                        tbody.innerHTML = '<tr><td colspan="9" class="py-6 text-center text-[var(--text-muted)]">No queues found.</td></tr>';
                        return;
                    }
                    data.queues.forEach(q => {
                        const tr = document.createElement('tr');
                        tr.className = 'hover:bg-[var(--bg-hover)] transition-colors';
                        const recMatch = loadedRecordingsList.find(r => r.id == q.joinannounce_id);
                        const annText = recMatch ? recMatch.displayname : (q.joinannounce_id ? 'ID #' + q.joinannounce_id : 'None');
                        const staticStr = Array.isArray(q.static_members) ? q.static_members.join(', ') : '';
                        const maxWaitText = q.maxwait === '0' || !q.maxwait ? 'Unlimited' : q.maxwait + 's';

                        tr.innerHTML = `
                            <td class="py-3 px-4 font-mono font-bold text-amber-400">${q.extension}</td>
                            <td class="py-3 px-4 font-bold text-[var(--text-primary)]">${q.descr || '-'}</td>
                            <td class="py-3 px-4 font-mono text-xs text-[var(--text-secondary)]">${q.strategy || 'rrmemory'}</td>
                            <td class="py-3 px-4 font-mono text-xs text-[var(--text-secondary)]">${staticStr || '-'}</td>
                            <td class="py-3 px-4 font-mono text-xs text-[var(--text-secondary)]">${q.dynmembers || '-'}</td>
                            <td class="py-3 px-4 font-mono text-xs text-[var(--text-secondary)]">${annText}</td>
