                            <td class="py-3 px-4 text-center">
                                <div class="flex items-center justify-center gap-2">
                                    <button onclick="editTrunk(${t.trunkid}, '${t.name}', '${t.outcid}', '${t.maxchans}', \`${t.peerdetails.replace(/`/g, '\\`')}\`)" class="px-2.5 py-1 text-xs font-semibold text-blue-400 hover:bg-blue-500/10 rounded border border-blue-500/30">Edit</button>
                                    <button onclick="deleteTrunk(${t.trunkid})" class="px-2.5 py-1 text-xs font-semibold text-red-400 hover:bg-red-500/10 rounded border border-red-500/30">Delete</button>
                                </div>
                            </td>
                        `;
                        tbody.appendChild(tr);
                    });
                })
                .catch(err => console.error(err));
        }

        function openTrunkModal() {
            document.getElementById('trunkModalTitle').textContent = isRtl ? 'إضافة خط ربط جديد' : 'Add SIP Trunk';
            document.getElementById('trunkEditId').value = "";
            document.getElementById('trunkForm').reset();
            openModal('trunkModal');
        }

        function editTrunk(trunkid, name, outcid, maxchans, peerdetails) {
            document.getElementById('trunkModalTitle').textContent = (isRtl ? 'تعديل خط الربط ' : 'Edit Trunk ') + name;
            document.getElementById('trunkEditId').value = trunkid;
            document.getElementById('trunkName').value = name || '';
            document.getElementById('trunkCid').value = outcid || '';
            document.getElementById('trunkMaxChans').value = maxchans || '';
            document.getElementById('trunkPeerDetails').value = peerdetails || '';
            openModal('trunkModal');
        }

        function saveTrunk(e) {
            e.preventDefault();
            const editId = document.getElementById('trunkEditId').value;
            const name = document.getElementById('trunkName').value.trim();
            const outcid = document.getElementById('trunkCid').value.trim();
            const maxchans = document.getElementById('trunkMaxChans').value.trim();
            const peerdetails = document.getElementById('trunkPeerDetails').value;

            const url = editId ? '/api/config/trunks/' + editId : '/api/config/trunks';
            const method = editId ? 'PUT' : 'POST';

            fetch(url, {
                method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name, outcid, maxchans, peerdetails })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    showToast(data.message, 'success');
                    closeModal('trunkModal');
                    fetchTrunks();
                } else showToast(data.error, 'error');
            });
        }

        function deleteTrunk(trunkid) {
            if (!confirm(`Delete trunk ID ${trunkid}?`)) return;
            fetch('/api/config/trunks/' + trunkid, { method: 'DELETE' })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        showToast(data.message, 'success');
                        fetchTrunks();
                    } else showToast(data.error, 'error');
                });
        }

        // --- 5. INBOUND ROUTES ---
        function fetchInboundRoutes() {
            const tbody = document.getElementById('inbound-table-body');
            fetch('/api/config/routes/inbound')
                .then(res => res.json())
                .then(data => {
                    if (!data.success || !data.routes) return;
                    tbody.innerHTML = '';
                    if (data.routes.length === 0) {
                        tbody.innerHTML = '<tr><td colspan="5" class="py-6 text-center text-[var(--text-muted)]">No inbound routes found.</td></tr>';
                        return;
                    }
                    data.routes.forEach(r => {
                        const tr = document.createElement('tr');
                        tr.className = 'hover:bg-[var(--bg-hover)] transition-colors';
                        tr.innerHTML = `
                            <td class="py-3 px-4 font-bold text-[var(--text-primary)]">${r.description}</td>
                            <td class="py-3 px-4 font-mono text-xs text-[var(--text-secondary)]">${r.extension || '<span class="text-[var(--text-muted)]">ANY</span>'}</td>
                            <td class="py-3 px-4 font-mono text-xs text-[var(--text-secondary)]">${r.cidnum || '<span class="text-[var(--text-muted)]">ANY</span>'}</td>
                            <td class="py-3 px-4 font-mono text-xs text-blue-400 font-bold">${r.destination}</td>
                            <td class="py-3 px-4 text-center">
                                <button onclick="deleteInboundRoute('${r.extension || ''}', '${r.cidnum || ''}', '${r.description}')" class="px-2.5 py-1 text-xs font-semibold text-red-400 hover:bg-red-500/10 rounded border border-red-500/30">Delete</button>
                            </td>
                        `;
                        tbody.appendChild(tr);
                    });
                })
                .catch(err => console.error(err));
        }

        function openInboundModal() {
            document.getElementById('inboundForm').reset();
            openModal('inboundModal');
        }

        function saveInboundRoute(e) {
            e.preventDefault();
            const description = document.getElementById('inDescription').value.trim();
            const extension = document.getElementById('inExtension').value.trim();
            const cidnum = document.getElementById('inCidnum').value.trim();
            const destination = document.getElementById('inDestination').value.trim();

            fetch('/api/config/routes/inbound', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ description, extension, cidnum, destination })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    showToast(data.message, 'success');
                    closeModal('inboundModal');
                    fetchInboundRoutes();
                } else showToast(data.error, 'error');
            });
        }

        function deleteInboundRoute(extension, cidnum, description) {
            if (!confirm(`Delete inbound route '${description}'?`)) return;
            fetch('/api/config/routes/inbound', {
                method: 'DELETE',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ extension, cidnum, description })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    showToast(data.message, 'success');
                    fetchInboundRoutes();
                } else showToast(data.error, 'error');
            });
        }

        // --- 6. OUTBOUND ROUTES ---
        function updateOutboundTrunkSelect() {
            const sel = document.getElementById('outTrunkSelect');
            if (!sel) return;
            sel.innerHTML = '<option value="">-- Select Trunk --</option>';
            loadedTrunksList.forEach(t => {
                const opt = document.createElement('option');
                opt.value = t.trunkid;
                opt.textContent = `${t.name} (ID: ${t.trunkid})`;
                sel.appendChild(opt);
            });
        }

        function fetchOutboundRoutes() {
            const tbody = document.getElementById('outbound-table-body');
            fetch('/api/config/routes/outbound')
                .then(res => res.json())
                .then(data => {
                    if (!data.success || !data.routes) return;
                    tbody.innerHTML = '';
                    if (data.routes.length === 0) {
                        tbody.innerHTML = '<tr><td colspan="7" class="py-6 text-center text-[var(--text-muted)]">No outbound routes found.</td></tr>';
                        return;
                    }
                    data.routes.forEach(r => {
                        const tr = document.createElement('tr');
                        tr.className = 'hover:bg-[var(--bg-hover)] transition-colors';
                        tr.innerHTML = `
                            <td class="py-3 px-4 font-mono font-bold text-[var(--text-muted)]">${r.route_id}</td>
                            <td class="py-3 px-4 font-bold text-[var(--text-primary)]">${r.name}</td>
                            <td class="py-3 px-4 font-mono text-xs text-[var(--text-secondary)]">${r.match_pattern_prefix || '-'}</td>
                            <td class="py-3 px-4 font-mono text-xs text-blue-400 font-bold">${r.match_pattern_pass || '-'}</td>
                            <td class="py-3 px-4 font-mono text-xs text-[var(--text-secondary)]">${r.match_cid || '-'}</td>
                            <td class="py-3 px-4 font-mono text-xs text-emerald-400 font-bold">${r.trunk_name || r.trunk_id || '-'}</td>
                            <td class="py-3 px-4 text-center">
                                <button onclick="deleteOutboundRoute(${r.route_id})" class="px-2.5 py-1 text-xs font-semibold text-red-400 hover:bg-red-500/10 rounded border border-red-500/30">Delete</button>
                            </td>
                        `;
                        tbody.appendChild(tr);
                    });
                })
                .catch(err => console.error(err));
        }

        function openOutboundModal() {
            document.getElementById('outboundForm').reset();
            updateOutboundTrunkSelect();
            openModal('outboundModal');
        }

        function saveOutboundRoute(e) {
            e.preventDefault();
            const name = document.getElementById('outName').value.trim();
            const match_pattern_prefix = document.getElementById('outPrefix').value.trim();
            const match_pattern_pass = document.getElementById('outPattern').value.trim();
            const match_cid = document.getElementById('outCid').value.trim();
            const trunk_id = document.getElementById('outTrunkSelect').value;

            fetch('/api/config/routes/outbound', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name, match_pattern_prefix, match_pattern_pass, match_cid, trunk_id })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    showToast(data.message, 'success');
                    closeModal('outboundModal');
                    fetchOutboundRoutes();
                } else showToast(data.error, 'error');
            });
        }

        function deleteOutboundRoute(routeId) {
            if (!confirm(`Delete outbound route ID ${routeId}?`)) return;
            fetch('/api/config/routes/outbound/' + routeId, { method: 'DELETE' })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        showToast(data.message, 'success');
                        fetchOutboundRoutes();
                    } else showToast(data.error, 'error');
                });
        }

        // Initialize on load
        document.addEventListener('DOMContentLoaded', () => {
            fetchExtensions();
            fetchRecordings();
            fetchTrunks();
        });
    </script>
</body>
</html>
