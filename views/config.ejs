        // --- 5. INBOUND ROUTES ---
        function formatDestination(dest) {
            if (!dest) return '-';
            
            if (dest.startsWith('from-did-direct,')) {
                const parts = dest.split(',');
                const extNum = parts[1];
                const extMatch = loadedExtensionsList.find(e => e.extension == extNum);
                const nameStr = extMatch ? ` - ${extMatch.name}` : '';
                return `Extension: ${extNum}${nameStr}`;
            }
            
            if (dest.startsWith('ext-group,')) {
                const parts = dest.split(',');
                const grpNum = parts[1];
                const rgMatch = loadedRingGroupsList.find(rg => rg.grpnum == grpNum);
                const descStr = rgMatch ? ` - ${rgMatch.description}` : '';
                return `Ring Group: ${grpNum}${descStr}`;
            }
            
            return dest; // Fallback to raw string
        }

        function fetchInboundRoutes() {
            const tbody = document.getElementById('inbound-table-body');
            fetch('/api/config/routes/inbound')
                .then(res => res.json())
                .then(data => {
                    if (!data.success || !data.routes) return;
                    tbody.innerHTML = '';
                    if (data.routes.length === 0) {
                        tbody.innerHTML = '<tr><td colspan="4" class="py-6 text-center text-[var(--text-muted)]">No inbound routes found.</td></tr>';
                        return;
                    }
                    data.routes.forEach(r => {
                        const tr = document.createElement('tr');
                        tr.className = 'hover:bg-[var(--bg-hover)] transition-colors';
                        tr.innerHTML = `
                            <td class="py-3 px-4 font-bold text-[var(--text-primary)]">${r.description}</td>
                            <td class="py-3 px-4 font-mono text-xs text-[var(--text-secondary)]">${r.extension || '<span class="text-[var(--text-muted)]">ANY</span>'}</td>
                            <td class="py-3 px-4 font-mono text-xs text-blue-400 font-bold">${formatDestination(r.destination)}</td>
                            <td class="py-3 px-4 text-center">
                                <div class="flex items-center justify-center gap-2">
                                    <button onclick="editInboundRoute('${r.extension || ''}', '${r.description}', '${r.destination}')" class="px-2.5 py-1 text-xs font-semibold text-blue-400 hover:bg-blue-500/10 rounded border border-blue-500/30">Edit</button>
                                    <button onclick="deleteInboundRoute('${r.extension || ''}', '${r.description}')" class="px-2.5 py-1 text-xs font-semibold text-red-400 hover:bg-red-500/10 rounded border border-red-500/30">Delete</button>
                                </div>
