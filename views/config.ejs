        function editOutboundRoute(routeId, name, patternsJson, trunksJson) {
            document.getElementById('outboundModalTitle').textContent = (isRtl ? 'تعديل المسار الصادر ' : 'Edit Outbound Route ') + name;
            document.getElementById('outboundEditId').value = routeId;
            document.getElementById('outName').value = name || '';

            try {
                modalPatternsList = JSON.parse(patternsJson) || [];
            } catch(e) {
                modalPatternsList = [];
            }

            try {
                const trs = JSON.parse(trunksJson) || [];
                trs.sort((a,b) => a.seq - b.seq);
                modalTrunksSequence = trs.map(t => String(t.trunk_id));
            } catch(e) {
                modalTrunksSequence = [];
            }

            const sel = document.getElementById('sequenceTrunkSelect');
            if (sel) {
                sel.innerHTML = '<option value="">-- Choose Trunk --</option>';
                loadedTrunksList.forEach(t => {
                    const opt = document.createElement('option');
                    opt.value = t.trunkid;
                    opt.textContent = `${t.name} (${t.tech})`;
                    sel.appendChild(opt);
                });
            }

            renderModalPatterns();
            renderModalTrunksSequence();
            openModal('outboundModal');
        }

        function saveOutboundRoute(e) {
            e.preventDefault();
            const editId = document.getElementById('outboundEditId').value;
            const name = document.getElementById('outName').value.trim();

            if (modalPatternsList.length === 0) {
                showToast(isRtl ? 'يرجى إضافة نمط اتصال واحد على الأقل.' : 'Please add at least one Dial Pattern.', 'error');
                return;
            }
            if (modalTrunksSequence.length === 0) {
                showToast(isRtl ? 'يرجى تحديد خط ربط واحد على الأقل في التسلسل.' : 'Please select at least one Trunk in the sequence.', 'error');
                return;
            }

            const url = editId ? '/api/config/routes/outbound/' + editId : '/api/config/routes/outbound';
            const method = editId ? 'PUT' : 'POST';

            fetch(url, {
                method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    name,
                    patterns: modalPatternsList,
                    trunks: modalTrunksSequence
                })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    showToast(data.message, 'success');
                    closeModal('outboundModal');
                    fetchOutboundRoutes();
                } else showToast(data.error, 'error');
            });
        }

        function deleteOutboundRoute(routeId) {
            if (!confirm(`Delete outbound route ID ${routeId}?`)) return;
            fetch('/api/config/routes/outbound/' + routeId, { method: 'DELETE' })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        showToast(data.message, 'success');
                        fetchOutboundRoutes();
                    } else showToast(data.error, 'error');
                });
        }

