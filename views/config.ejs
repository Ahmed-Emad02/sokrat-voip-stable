        function loadInboundDestOptions() {
            const destType = document.getElementById('inDestType').value;
            const selectEl = document.getElementById('inDestTargetSelect');
            const inputEl = document.getElementById('inDestTargetInput');
            const actualInput = document.getElementById('inDestination');

            selectEl.classList.add('hidden');
            inputEl.classList.add('hidden');
            selectEl.required = false;
            inputEl.required = false;
            
            if (destType === 'extensions') {
                selectEl.innerHTML = '<option value="">== choose extension ==</option>';
                selectEl.classList.remove('hidden');
                selectEl.required = true;
                
                loadedExtensionsList.forEach(ext => {
                    const opt = document.createElement('option');
                    opt.value = `from-did-direct,${ext.extension},1`;
                    opt.textContent = `${ext.extension} - ${ext.name || ''}`;
                    selectEl.appendChild(opt);
                });
                if (actualInput.value.startsWith('from-did-direct,')) {
                    selectEl.value = actualInput.value;
                }
            } else if (destType === 'ringgroups') {
                selectEl.innerHTML = '<option value="">== choose ring group ==</option>';
                selectEl.classList.remove('hidden');
                selectEl.required = true;
                
                loadedRingGroupsList.forEach(rg => {
                    const opt = document.createElement('option');
                    opt.value = `ext-group,${rg.grpnum},1`;
                    opt.textContent = `${rg.grpnum} - ${rg.description || ''}`;
                    selectEl.appendChild(opt);
                });
                if (actualInput.value.startsWith('ext-group,')) {
                    selectEl.value = actualInput.value;
                }
            } else if (destType === 'custom') {
                inputEl.classList.remove('hidden');
                inputEl.required = true;
                if (actualInput.value && !actualInput.value.startsWith('from-did-direct,') && !actualInput.value.startsWith('ext-group,')) {
                    inputEl.value = actualInput.value;
                } else {
                    inputEl.value = '';
                }
            }
        }

        function onInboundDestTypeChange() {
            loadInboundDestOptions();
            updateInboundDestinationValue();
        }

        function updateInboundDestinationValue() {
            const destType = document.getElementById('inDestType').value;
            const selectEl = document.getElementById('inDestTargetSelect');
            const inputEl = document.getElementById('inDestTargetInput');
            const actualInput = document.getElementById('inDestination');
            
            if (destType === 'extensions' || destType === 'ringgroups') {
                actualInput.value = selectEl.value;
            } else if (destType === 'custom') {
                actualInput.value = inputEl.value.trim();
            } else {
                actualInput.value = '';
            }
        }

