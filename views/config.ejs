        async function uploadSystemRecording(e) {
            e.preventDefault();
            const nameInput = document.getElementById('sysRecName');
            const fileInput = document.getElementById('sysRecFile');
            const submitBtn = document.getElementById('sysRecSubmitBtn');
            const progressWrap = document.getElementById('sysRecProgressWrap');
            const progressBar = document.getElementById('sysRecProgressBar');
            const percentText = document.getElementById('sysRecPercent');
            const statusText = document.getElementById('sysRecStatus');

            if (!fileInput.files.length) {
                showToast('Please select an audio file.', 'error');
                return;
            }

            const formData = new FormData();
            formData.append('file', fileInput.files[0]);
            formData.append('name', nameInput.value.trim());

            submitBtn.disabled = true;
            progressWrap.classList.remove('hidden');
            progressBar.style.width = '0%';
            percentText.textContent = '0%';
            statusText.textContent = 'Uploading & converting...';

            try {
                const xhr = new XMLHttpRequest();
                const result = await new Promise((resolve, reject) => {
                    xhr.upload.addEventListener('progress', (ev) => {
                        if (ev.lengthComputable) {
                            const pct = Math.round((ev.loaded / ev.total) * 100);
                            progressBar.style.width = pct + '%';
                            percentText.textContent = pct + '%';
                        }
                    });
                    xhr.addEventListener('load', () => {
                        if (xhr.status >= 200 && xhr.status < 300) {
                            resolve(JSON.parse(xhr.responseText));
                        } else {
                            try { reject(JSON.parse(xhr.responseText)); }
                            catch (err) { reject({ error: 'HTTP ' + xhr.status }); }
                        }
                    });
                    xhr.addEventListener('error', () => reject({ error: 'Network error' }));
                    xhr.open('POST', '/api/settings/recordings/upload');
                    xhr.send(formData);
                });

                if (result.success) {
                    showToast(result.message, 'success');
                    document.getElementById('systemRecordingUploadForm').reset();
                    fetchRecordings();
                } else {
                    showToast(result.error || 'Upload failed', 'error');
                }
            } catch (err) {
                showToast(err.error || err.message || 'Upload failed', 'error');
            } finally {
                submitBtn.disabled = false;
                setTimeout(() => {
                    progressWrap.classList.add('hidden');
                    progressBar.style.width = '0%';
                }, 3000);
            }
        }

        let activeRecordingAudio = null;
        let activeRecordingBtn = null;

        function togglePlayRecording(id, btn) {
            const url = `/api/config/recordings/audio/${id}`;
            
            if (activeRecordingAudio && activeRecordingBtn === btn) {
                if (activeRecordingAudio.paused) {
                    activeRecordingAudio.play();
                    setPlayBtnState(btn, true);
                } else {
                    activeRecordingAudio.pause();
                    setPlayBtnState(btn, false);
                }
                return;
            }

            if (activeRecordingAudio) {
                activeRecordingAudio.pause();
                if (activeRecordingBtn) setPlayBtnState(activeRecordingBtn, false);
            }

            activeRecordingAudio = new Audio(url);
            activeRecordingBtn = btn;

            activeRecordingAudio.addEventListener('play', () => setPlayBtnState(btn, true));
            activeRecordingAudio.addEventListener('pause', () => setPlayBtnState(btn, false));
            activeRecordingAudio.addEventListener('ended', () => {
                setPlayBtnState(btn, false);
                activeRecordingAudio = null;
                activeRecordingBtn = null;
            });

            activeRecordingAudio.play().catch(err => {
                showToast("Playback error: " + err.message, "error");
                setPlayBtnState(btn, false);
            });
        }

        function setPlayBtnState(btn, isPlaying) {
            if (!btn) return;
            const span = btn.querySelector('span');
            const svg = btn.querySelector('svg');
            const isRtl = '<%= isRtl %>' === 'true';
            
            if (isPlaying) {
                if (span) span.textContent = isRtl ? 'إيقاف' : 'Pause';
                if (svg) {
                    svg.innerHTML = '<path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>';
                    svg.setAttribute('class', 'w-3 h-3 fill-emerald-400');
                    svg.setAttribute('viewBox', '0 0 24 24');
                }
            } else {
                if (span) span.textContent = isRtl ? 'تشغيل' : 'Play';
                if (svg) {
                    svg.innerHTML = '<path d="M8 5v14l11-7z"/>';
                    svg.setAttribute('class', 'w-3 h-3 fill-emerald-400');
                    svg.setAttribute('viewBox', '0 0 24 24');
                }
            }
        }

