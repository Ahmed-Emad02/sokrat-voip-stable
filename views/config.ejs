        function editQueue(extNum) {
            const q = loadedQueuesList.find(item => String(item.extension) === String(extNum));
            if (!q) return;

            document.getElementById('queueModalTitle').textContent = (isRtl ? 'تعديل طابور الانتظار ' : 'Edit Queue ') + q.extension;
            document.getElementById('queueEditMode').value = "true";
            document.getElementById('queueNum').value = q.extension;
            document.getElementById('queueNum').disabled = true;
            document.getElementById('queueDesc').value = q.descr || '';
            document.getElementById('queueStrategy').value = q.strategy || 'rrmemory';
            document.getElementById('queueMoh').value = q.musicclass || 'default';
            document.getElementById('queueRecording').value = (q.monitor_type === 'bgrnd' || q.monitor_type === 'yes') ? 'yes' : (q.monitor_type === '' ? 'no' : 'yes');
            document.getElementById('queueMaxWait').value = q.maxwait || 0;
            document.getElementById('queueAgentTimeout').value = q.timeout || 15;
            document.getElementById('queueRetry').value = q.retry || 5;
            document.getElementById('queueAutofill').value = q.autofill || 'yes';
            document.getElementById('queueSkipBusy').value = (q.cwignore == 1 || q.cwignore === '1') ? 'yes' : 'no';

            const staticArr = Array.isArray(q.static_members) ? q.static_members : (q.static_members ? String(q.static_members).split(/[\r\n, ]+/) : []);
            const dynArr = Array.isArray(q.dynmembers) ? q.dynmembers : (q.dynmembers ? String(q.dynmembers).split(/[\r\n, ]+/) : []);
            const allAgents = Array.from(new Set([...staticArr, ...dynArr].map(e => String(e).trim()).filter(Boolean)));
            const agentsStr = allAgents.join(', ');

            document.getElementById('queueStaticList').value = agentsStr;
            document.getElementById('queueDynList').value = agentsStr;

            populateQueueAnnouncementsDropdown();
            document.getElementById('queueAnnMsg').value = q.joinannounce_id || 0;

            const dest = q.dest || 'app-blackhole,hangup,1';
            const destTypeSelect = document.getElementById('queueDestType');
            if (dest.startsWith('from-did-direct,') || dest.startsWith('ext-local,')) {
                destTypeSelect.value = 'extensions';
            } else if (dest.startsWith('ext-group,')) {
                destTypeSelect.value = 'ringgroups';
            } else if (dest.startsWith('ext-queues,')) {
                destTypeSelect.value = 'queues';
            } else if (dest.startsWith('ext-local,vmu')) {
                destTypeSelect.value = 'voicemail';
            } else if (dest.startsWith('app-blackhole,')) {
                destTypeSelect.value = 'terminate';
            } else {
                destTypeSelect.value = 'custom';
            }
            onQueueDestTypeChange();
            document.getElementById('queueDestination').value = dest;
            if (['extensions', 'ringgroups', 'queues', 'voicemail'].includes(destTypeSelect.value)) {
                document.getElementById('queueDestTargetSelect').value = dest;
            } else if (destTypeSelect.value === 'custom') {
                document.getElementById('queueDestTargetInput').value = dest;
            }

            renderQueueAgentChecklist();
            openModal('queueModal');
        }

        function onQueueDestTypeChange() {
            const destType = document.getElementById('queueDestType').value;
            const selectEl = document.getElementById('queueDestTargetSelect');
            const inputEl = document.getElementById('queueDestTargetInput');
            const actualInput = document.getElementById('queueDestination');

            selectEl.classList.add('hidden');
            inputEl.classList.add('hidden');
            selectEl.required = false;
            inputEl.required = false;
            selectEl.innerHTML = '<option value="">== choose target ==</option>';

            if (destType === 'extensions') {
                selectEl.classList.remove('hidden');
                selectEl.required = true;
                loadedExtensionsList.forEach(ext => {
                    const opt = document.createElement('option');
                    opt.value = `from-did-direct,${ext.extension},1`;
                    opt.textContent = `${ext.extension} - ${ext.name || ''}`;
                    selectEl.appendChild(opt);
                });
            } else if (destType === 'ringgroups') {
                selectEl.classList.remove('hidden');
                selectEl.required = true;
                loadedRingGroupsList.forEach(rg => {
                    const opt = document.createElement('option');
                    opt.value = `ext-group,${rg.grpnum},1`;
                    opt.textContent = `${rg.grpnum} - ${rg.description || ''}`;
                    selectEl.appendChild(opt);
                });
            } else if (destType === 'queues') {
                selectEl.classList.remove('hidden');
                selectEl.required = true;
                loadedQueuesList.forEach(q => {
                    const opt = document.createElement('option');
                    opt.value = `ext-queues,${q.extension},1`;
                    opt.textContent = `${q.extension} - ${q.descr || ''}`;
                    selectEl.appendChild(opt);
                });
            } else if (destType === 'voicemail') {
                selectEl.classList.remove('hidden');
                selectEl.required = true;
                loadedExtensionsList.forEach(ext => {
                    const opt = document.createElement('option');
                    opt.value = `ext-local,vmu${ext.extension},1`;
                    opt.textContent = `Voicemail: ${ext.extension} (${ext.name || ''})`;
                    selectEl.appendChild(opt);
                });
            } else if (destType === 'terminate') {
                actualInput.value = 'app-blackhole,hangup,1';
            } else if (destType === 'custom') {
                inputEl.classList.remove('hidden');
                inputEl.required = true;
            }
            updateQueueDestinationValue();
        }

        function updateQueueDestinationValue() {
            const destType = document.getElementById('queueDestType').value;
            const selectEl = document.getElementById('queueDestTargetSelect');
            const inputEl = document.getElementById('queueDestTargetInput');
            const actualInput = document.getElementById('queueDestination');

            if (['extensions', 'ringgroups', 'queues', 'voicemail'].includes(destType)) {
                actualInput.value = selectEl.value;
            } else if (destType === 'terminate') {
                actualInput.value = 'app-blackhole,hangup,1';
            } else if (destType === 'custom') {
                actualInput.value = inputEl.value.trim();
            }
        }

