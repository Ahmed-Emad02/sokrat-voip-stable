<%
var activeLang = (typeof currentLang !== 'undefined' && currentLang) ? currentLang : 'en';
var isRtl = (typeof isRtl !== 'undefined') ? isRtl : (activeLang === 'ar');
%>
<!DOCTYPE html>
<html lang="<%= activeLang %>" dir="<%= isRtl ? 'rtl' : 'ltr' %>">
<head>
    <script>
        (function() {
            const theme = localStorage.getItem('theme') || 'dark';
            if (theme === 'light') {
                document.documentElement.classList.add('light-theme');
            } else {
                document.documentElement.classList.remove('light-theme');
            }
        })();
    </script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sokrat VOIP — <%= isRtl ? 'إعدادات المقسم' : 'PBX Configuration' %></title>
    <link rel="icon" type="image/png" href="/favicon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <style>
        :root {
            --bg-primary: #09090b;
            --bg-secondary: #121212;
            --bg-card: #18181b;
            --bg-hover: #27272a;
            --border-primary: #27272a;
            --border-accent: #3f3f46;
            --text-primary: #ffffff;
            --text-secondary: #a1a1aa;
            --text-muted: #71717a;
            --accent-color: #ef4444;
            --accent-hover: #dc2626;
        }
        html.light-theme {
            --bg-primary: #f8fafc;
            --bg-secondary: #ffffff;
            --bg-card: #f1f5f9;
            --bg-hover: #e2e8f0;
            --border-primary: #cbd5e1;
            --border-accent: #94a3b8;
            --text-primary: #0f172a;
            --text-secondary: #334155;
            --text-muted: #64748b;
        }
        body {
            background-color: var(--bg-primary);
            color: var(--text-primary);
            font-family: 'Plus Jakarta Sans', 'Cairo', sans-serif;
            min-height: 100vh;
        }
        .config-card {
            background-color: var(--bg-secondary) !important;
            border: 1px solid var(--border-primary) !important;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.25) !important;
            border-radius: 1rem !important;
        }
        .config-input {
            background-color: var(--bg-card) !important;
            border: 1px solid var(--border-primary) !important;
            color: var(--text-primary) !important;
            font-size: 0.875rem !important;
            border-radius: 0.5rem !important;
            padding: 0.5rem 0.75rem !important;
        }
        .config-input:focus {
            outline: none !important;
            border-color: var(--accent-color) !important;
        }
        .config-btn-primary {
            background-color: var(--accent-color) !important;
            color: #ffffff !important;
            font-weight: 700 !important;
            border-radius: 0.5rem !important;
            transition: all 150ms ease-in-out !important;
        }
        .config-btn-primary:hover {
            background-color: var(--accent-hover, #dc2626) !important;
        }
        .config-btn-secondary {
            background-color: var(--bg-card) !important;
            color: var(--text-secondary) !important;
            border: 1px solid var(--border-primary) !important;
            font-weight: 600 !important;
            border-radius: 0.5rem !important;
            transition: all 150ms ease-in-out !important;
        }
        .config-btn-secondary:hover {
            background-color: var(--bg-hover) !important;
            color: var(--text-primary) !important;
        }
        .config-tab-btn {
            font-weight: 700;
            font-size: 0.875rem;
            padding: 0.625rem 1.25rem;
            border-radius: 0.5rem;
            transition: all 150ms ease;
            cursor: pointer;
        }
        .config-tab-active {
            background-color: var(--accent-color) !important;
            color: #ffffff !important;
            box-shadow: 0 2px 8px rgba(239, 68, 68, 0.3) !important;
        }
        .config-tab-inactive {
            background-color: var(--bg-secondary) !important;
            color: var(--text-secondary) !important;
            border: 1px solid var(--border-primary) !important;
        }
        .config-tab-inactive:hover {
            background-color: var(--bg-hover) !important;
            color: var(--text-primary) !important;
        }
        .ext-pill {
            cursor: pointer;
            user-select: none;
            transition: all 0.15s ease;
        }
        .ext-pill.active {
            background-color: rgba(239, 68, 68, 0.2);
            color: var(--accent-color);
            border-color: rgba(239, 68, 68, 0.4);
        }
    </style>
</head>
<body class="flex flex-col md:flex-row min-h-screen m-0 p-0">

    <%- include('sidebar') %>

    <!-- Toast Container -->
    <div id="toast-container" class="fixed top-20 right-5 z-50 flex flex-col gap-2 pointer-events-none"></div>

    <div class="flex-1 min-w-0 p-6 md:p-8 max-w-[1600px] w-full">

        <!-- Page Header & Global PBX Reload Action -->
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8 bg-[var(--bg-secondary)] p-6 rounded-2xl border border-[var(--border-primary)] shadow-lg">
            <div>
                <div class="flex items-center gap-3">
                    <div class="p-2.5 bg-red-500/10 text-red-500 rounded-xl border border-red-500/20">
                        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                    </div>
                    <div>
                        <h1 class="text-2xl font-black text-[var(--text-primary)] tracking-tight">
                            <%= isRtl ? 'إدارة إعدادات المقسم (PBX Manager)' : 'PBX Configuration Manager' %>
                        </h1>
                        <p class="text-sm text-[var(--text-secondary)] font-medium mt-0.5">
                            <%= isRtl ? 'التحكم المباشر في قاعدة بيانات Issabel/FreePBX وتطبيق التغييرات فوريًا' : 'Direct FreePBX/Issabel Database Controller & Core Reload Engine' %>
                        </p>
                    </div>
                </div>
            </div>

            <!-- Apply PBX Configuration Button -->
            <button id="reloadPbxBtn" onclick="reloadPbxConfig()" class="config-btn-primary px-5 py-3 flex items-center gap-2.5 text-sm cursor-pointer shadow-md hover:shadow-lg">
                <svg id="reloadIcon" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
                <span id="reloadBtnText"><%= isRtl ? 'تطبيق تغييرات المقسم (Apply PBX Changes)' : 'Apply PBX Configuration' %></span>
            </button>
        </div>

        <!-- Sub-Navigation Bar -->
        <div class="flex items-center gap-2 mb-6 border-b border-[var(--border-primary)] pb-4 overflow-x-auto">
            <button onclick="switchTab('extensions')" id="tab-btn-extensions" class="config-tab-btn config-tab-active flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                <span><%= isRtl ? 'التحويلات (Extensions)' : 'Extensions' %></span>
            </button>
            <button onclick="switchTab('ringgroups')" id="tab-btn-ringgroups" class="config-tab-btn config-tab-inactive flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
                <span><%= isRtl ? 'مجموعات الاتصال (Ring Groups)' : 'Ring Groups' %></span>
            </button>
            <button onclick="switchTab('recordings')" id="tab-btn-recordings" class="config-tab-btn config-tab-inactive flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" /></svg>
                <span><%= isRtl ? 'التسجيلات الصوتية (System Recordings)' : 'System Recordings' %></span>
            </button>
            <button onclick="switchTab('trunks')" id="tab-btn-trunks" class="config-tab-btn config-tab-inactive flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                <span><%= isRtl ? 'خطوط الربط (Trunks)' : 'Trunks' %></span>
            </button>
            <button onclick="switchTab('inbound')" id="tab-btn-inbound" class="config-tab-btn config-tab-inactive flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1" /></svg>
                <span><%= isRtl ? 'المسارات الواردة (Inbound Routes)' : 'Inbound Routes' %></span>
            </button>
            <button onclick="switchTab('outbound')" id="tab-btn-outbound" class="config-tab-btn config-tab-inactive flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" /></svg>
                <span><%= isRtl ? 'المسارات الصادرة (Outbound Routes)' : 'Outbound Routes' %></span>
            </button>
        </div>

        <!-- TAB 1: EXTENSIONS MANAGEMENT -->
        <div id="section-extensions" class="tab-section">
            <div class="config-card p-6">
                <div class="flex flex-col sm:flex-row items-center justify-between gap-4 mb-6">
                    <div>
                        <h2 class="text-lg font-extrabold text-[var(--text-primary)]"><%= isRtl ? 'إدارة التحويلات (SIP Extensions)' : 'SIP Extensions' %></h2>
                        <p class="text-xs text-[var(--text-muted)]"><%= isRtl ? 'إنشاء وتعديل واستعراض التحويلات المسجلة في المقسم' : 'Manage extensions directly in Issabel/FreePBX MySQL database' %></p>
                    </div>
                    <button onclick="openExtensionModal()" class="config-btn-primary px-4 py-2 flex items-center gap-2 text-xs cursor-pointer">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
                        <span><%= isRtl ? 'إضافة تحويلة جديدة' : 'Add New Extension' %></span>
                    </button>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-[var(--bg-card)] border-b border-[var(--border-primary)] text-xs font-bold text-[var(--text-secondary)] uppercase tracking-wider">
                                <th class="py-3 px-4"><%= isRtl ? 'رقم التحويلة' : 'User Extension ID' %></th>
                                <th class="py-3 px-4"><%= isRtl ? 'الاسم الظاهر' : 'Display Name' %></th>
                                <th class="py-3 px-4"><%= isRtl ? 'كلمة السر' : 'Secret' %></th>
                                <th class="py-3 px-4"><%= isRtl ? 'نوع الجهاز' : 'Device Type' %></th>
                                <th class="py-3 px-4"><%= isRtl ? 'NAT' : 'NAT' %></th>
                                <th class="py-3 px-4"><%= isRtl ? 'التسجيل' : 'Recording' %></th>
                                <th class="py-3 px-4"><%= isRtl ? 'البريد الصوتي' : 'Voicemail' %></th>
                                <th class="py-3 px-4 text-center"><%= isRtl ? 'الإجراءات' : 'Actions' %></th>
                            </tr>
                        </thead>
                        <tbody id="extensions-table-body" class="divide-y divide-[var(--border-primary)] text-sm font-medium text-[var(--text-primary)]">
                            <tr><td colspan="8" class="py-8 text-center text-[var(--text-muted)]">Loading extensions...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- TAB 2: RING GROUPS MANAGEMENT -->
        <div id="section-ringgroups" class="tab-section hidden">
            <div class="config-card p-6">
                <div class="flex flex-col sm:flex-row items-center justify-between gap-4 mb-6">
                    <div>
                        <h2 class="text-lg font-extrabold text-[var(--text-primary)]"><%= isRtl ? 'مجموعات الاتصال (Ring Groups)' : 'Ring Groups' %></h2>
                        <p class="text-xs text-[var(--text-muted)]"><%= isRtl ? 'تحديد مجموعات الاتصال وإجراءات توزيع المكالمات' : 'Create and configure ring groups for incoming call distribution' %></p>
                    </div>
                    <button onclick="openRingGroupModal()" class="config-btn-primary px-4 py-2 flex items-center gap-2 text-xs cursor-pointer">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
                        <span><%= isRtl ? 'إضافة مجموعة جديدة' : 'Add Ring Group' %></span>
                    </button>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-[var(--bg-card)] border-b border-[var(--border-primary)] text-xs font-bold text-[var(--text-secondary)] uppercase tracking-wider">
                                <th class="py-3 px-4"><%= isRtl ? 'رقم المجموعة' : 'Group #' %></th>
                                <th class="py-3 px-4"><%= isRtl ? 'الوصف' : 'Description' %></th>
                                <th class="py-3 px-4"><%= isRtl ? 'استراتيجية الاتصال' : 'Strategy' %></th>
                                <th class="py-3 px-4"><%= isRtl ? 'الإعلان' : 'Announcement' %></th>
                                <th class="py-3 px-4"><%= isRtl ? 'قائمة التحويلات' : 'Extension List' %></th>
                                <th class="py-3 px-4"><%= isRtl ? 'تخطي المشغول' : 'Skip Busy' %></th>
                                <th class="py-3 px-4"><%= isRtl ? 'التسجيل' : 'Recording' %></th>
                                <th class="py-3 px-4"><%= isRtl ? 'الوجهة عند عدم الرد' : 'Destination if no answer' %></th>
                                <th class="py-3 px-4 text-center"><%= isRtl ? 'الإجراءات' : 'Actions' %></th>
                            </tr>
                        </thead>
                        <tbody id="ringgroups-table-body" class="divide-y divide-[var(--border-primary)] text-sm font-medium text-[var(--text-primary)]">
                            <tr><td colspan="9" class="py-8 text-center text-[var(--text-muted)]">Loading ring groups...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- TAB 3: SYSTEM RECORDINGS MANAGEMENT -->
        <div id="section-recordings" class="tab-section hidden">
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                
                <!-- Upload New Recording Card -->
                <div class="config-card p-6 lg:col-span-1 h-fit">
                    <div class="mb-5 pb-3 border-b border-[var(--border-primary)]">
                        <h2 class="text-lg font-extrabold text-[var(--text-primary)] flex items-center gap-2">
                            <svg class="w-5 h-5 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
                            <span><%= isRtl ? 'رفع تسجيل صوتي جديد' : 'Upload System Recording' %></span>
                        </h2>
                        <p class="text-xs text-[var(--text-muted)] mt-1"><%= isRtl ? 'صيغ الملفات المقبولة: MP3, WAV, M4A, OGG, FLAC (سيتم تحويلها تلقائيًا)' : 'Accepted formats: MP3, WAV, M4A, OGG, FLAC (auto-converted to 8kHz WAV)' %></p>
                    </div>
                    <form id="systemRecordingUploadForm" onsubmit="uploadSystemRecording(event)" class="space-y-4">
                        <div>
                            <label class="block text-xs font-bold text-[var(--text-secondary)] uppercase mb-1"><%= isRtl ? 'اسم التسجيل (Display Name) *' : 'Recording Name *' %></label>
                            <input type="text" id="sysRecName" required placeholder="e.g. Welcome Announcement" class="config-input w-full">
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-[var(--text-secondary)] uppercase mb-1"><%= isRtl ? 'ملف الصوت *' : 'Audio File *' %></label>
                            <input type="file" id="sysRecFile" accept="audio/*,.mpeg,.mpg" required class="w-full text-xs text-[var(--text-secondary)] file:mr-3 rtl:file:mr-0 rtl:file:ml-3 file:py-2 file:px-3 file:rounded-lg file:border file:border-[var(--border-primary)] file:bg-[var(--bg-card)] file:text-xs file:font-bold file:text-[var(--text-primary)] hover:file:bg-[var(--bg-hover)] file:cursor-pointer transition cursor-pointer">
                        </div>
                        <!-- Upload Progress Bar -->
                        <div id="sysRecProgressWrap" class="hidden space-y-1">
                            <div class="flex justify-between text-[11px] font-semibold text-[var(--text-muted)]">
                                <span id="sysRecStatus">Uploading & converting...</span>
                                <span id="sysRecPercent">0%</span>
                            </div>
                            <div class="w-full h-1.5 bg-[var(--bg-card)] rounded-full overflow-hidden">
                                <div id="sysRecProgressBar" class="h-full bg-[var(--accent-color)] rounded-full transition-all duration-300" style="width:0%"></div>
                            </div>
                        </div>
                        <button type="submit" id="sysRecSubmitBtn" class="config-btn-primary w-full py-2.5 text-xs flex items-center justify-center gap-2 cursor-pointer">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" /></svg>
                            <span><%= isRtl ? 'رفع وحفظ التسجيل' : 'Upload Recording' %></span>
                        </button>
                    </form>
                </div>

                <!-- Existing Recordings List Table -->
                <div class="config-card p-6 lg:col-span-2">
                    <div class="mb-5 pb-3 border-b border-[var(--border-primary)]">
                        <h2 class="text-lg font-extrabold text-[var(--text-primary)]"><%= isRtl ? 'التسجيلات الصوتية المسجلة في المقسم' : 'System Recordings List' %></h2>
                        <p class="text-xs text-[var(--text-muted)]"><%= isRtl ? 'قائمة التسجيلات المستخدمة في مجموعات الاتصال والمسارات الواردة' : 'List of custom sound recordings available for Ring Groups & Inbound Routes' %></p>
                    </div>

                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="bg-[var(--bg-card)] border-b border-[var(--border-primary)] text-xs font-bold text-[var(--text-secondary)] uppercase tracking-wider">
                                    <th class="py-3 px-4">ID</th>
                                    <th class="py-3 px-4"><%= isRtl ? 'اسم التسجيل' : 'Recording Name' %></th>
                                    <th class="py-3 px-4"><%= isRtl ? 'مسار الملف' : 'System Filename' %></th>
                                    <th class="py-3 px-4 text-center"><%= isRtl ? 'الإجراءات' : 'Actions' %></th>
                                </tr>
                            </thead>
                            <tbody id="recordings-table-body" class="divide-y divide-[var(--border-primary)] text-sm font-medium text-[var(--text-primary)]">
                                <tr><td colspan="4" class="py-8 text-center text-[var(--text-muted)]">Loading recordings...</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </div>

        <!-- TAB 4: TRUNKS MANAGEMENT -->
        <div id="section-trunks" class="tab-section hidden">
            <div class="config-card p-6">
                <div class="flex flex-col sm:flex-row items-center justify-between gap-4 mb-6">
                    <div>
                        <h2 class="text-lg font-extrabold text-[var(--text-primary)]"><%= isRtl ? 'خطوط الربط (SIP Trunks)' : 'SIP Trunks' %></h2>
                        <p class="text-xs text-[var(--text-muted)]"><%= isRtl ? 'إعداد خطوط الربط الخارجي وتفاصيل PEER' : 'Manage SIP trunks and PEER configurations' %></p>
                    </div>
                    <button onclick="openTrunkModal()" class="config-btn-primary px-4 py-2 flex items-center gap-2 text-xs cursor-pointer">
