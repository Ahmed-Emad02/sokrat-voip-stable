                            </tr>
                        </thead>
                        <tbody id="outbound-table-body" class="divide-y divide-[var(--border-primary)] text-sm font-medium text-[var(--text-primary)]">
                            <tr><td colspan="5" class="py-8 text-center text-[var(--text-muted)]">Loading outbound routes...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <% } %>

        <!-- TAB 7: VOICEMAIL GREETINGS -->
        <% if (isTabAllowed('voicemail')) { %>
        <div id="section-voicemail" class="tab-section hidden">
            <div class="config-card p-6">
                <div class="flex flex-col sm:flex-row items-center justify-between gap-4 mb-6">
                    <div>
                        <h2 class="text-lg font-extrabold text-[var(--text-primary)]"><%= isRtl ? 'رسائل البريد الصوتي (Voicemail Greetings)' : 'Voicemail Greetings' %></h2>
                        <p class="text-xs text-[var(--text-muted)]"><%= isRtl ? 'تخصيص رسالة ترحيب البريد الصوتي للتحويلات' : 'Configure custom voicemail greetings (.gsm) for extensions' %></p>
                    </div>
                </div>

                <form onsubmit="saveVoicemailGreeting(event)" class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <!-- Left card: Select Greeting -->
                        <div class="border border-[var(--border-primary)] rounded-xl p-5 bg-[var(--bg-card)]/20 space-y-4">
                            <h3 class="text-xs font-bold text-[var(--text-secondary)] uppercase tracking-wider"><%= isRtl ? '١. اختر تسجيل الترحيب' : '1. Choose Greeting Recording' %></h3>
                            <div>
                                <label class="block text-xs font-semibold text-[var(--text-secondary)] mb-1"><%= isRtl ? 'تسجيل النظام *' : 'System Recording *' %></label>
                                <select id="vmGreetingSelect" class="config-input w-full" required>
                                    <option value=""><%= isRtl ? '-- اختر التسجيل --' : '-- Choose Recording --' %></option>
                                </select>
                            </div>
                        </div>

                        <!-- Right card: Apply to Mailboxes -->
                        <div class="border border-[var(--border-primary)] rounded-xl p-5 bg-[var(--bg-card)]/20 space-y-4">
                            <h3 class="text-xs font-bold text-[var(--text-secondary)] uppercase tracking-wider"><%= isRtl ? '٢. حدد صناديق البريد الصوتي' : '2. Select Mailboxes' %></h3>
                            
                            <div class="flex items-center gap-4">
                                <label class="flex items-center gap-2 cursor-pointer text-xs font-bold text-[var(--text-secondary)]">
                                    <input type="checkbox" id="vmAllMailboxes" onchange="toggleVmAllMailboxes()" class="tab-checkbox">
                                    <span><%= isRtl ? 'تحديد الكل (المفعل بها البريد الصوتي)' : 'Select All (voicemail-enabled)' %></span>
                                </label>
                            </div>

                            <div class="border border-[var(--border-primary)] rounded-lg p-3 bg-[var(--bg-secondary)] max-h-48 overflow-y-auto space-y-2" id="vmMailboxChecklist">
                                <!-- Prepopulated checklist of voicemail enabled extensions -->
