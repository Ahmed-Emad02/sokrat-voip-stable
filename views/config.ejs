                        <input type="text" id="rgNum" required placeholder="e.g. 600" class="config-input w-full font-mono">
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-[var(--text-secondary)] uppercase mb-1"><%= isRtl ? 'وصف المجموعة (Group Description) *' : 'Group Description *' %></label>
                        <input type="text" id="rgDesc" required placeholder="e.g. Sales Support Team" class="config-input w-full">
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-[var(--text-secondary)] uppercase mb-1"><%= isRtl ? 'استراتيجية الاتصال (Ring Strategy)' : 'Ring Strategy' %></label>
                        <select id="rgStrategy" class="config-input w-full">
                            <option value="ringall">ringall (Ring all available channels)</option>
                            <option value="hunt">hunt (Take turns ringing)</option>
                            <option value="memoryhunt">memoryhunt (First extension, then first+second...)</option>
                            <option value="firstavailable">firstavailable (Ring first available channel only)</option>
                            <option value="firstnotonphone">firstnotonphone (Ring first channel not on phone)</option>
                            <option value="random">random (Ring random channel)</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-[var(--text-secondary)] uppercase mb-1"><%= isRtl ? 'إعلان الصوت الوارد (Announcement)' : 'Announcement Recording' %></label>
