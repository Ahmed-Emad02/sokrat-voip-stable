        function openTimeConditionModal() {
            document.getElementById('tcEditMode').value = 'false';
            document.getElementById('tcId').value = '';
            document.getElementById('tcDisplayName').value = '';
            document.getElementById('tcTimeGroup').value = '';
            
            document.getElementById('tcTrueType').value = '';
            onTcDestTypeChange('true');
            document.getElementById('tcTrueGoto').value = '';

            document.getElementById('tcFalseType').value = '';
            onTcDestTypeChange('false');
            document.getElementById('tcFalseGoto').value = '';

            document.getElementById('timeConditionModalTitle').textContent = isRtl ? 'إضافة شرط وقت جديد' : 'Add Time Condition';
            openModal('timeConditionModal');
        }

        function onTcDestTypeChange(prefix) {
            const type = document.getElementById(`tc${prefix === 'true' ? 'True' : 'False'}Type`).value;
            const select = document.getElementById(`tc${prefix === 'true' ? 'True' : 'False'}TargetSelect`);
            const input = document.getElementById(`tc${prefix === 'true' ? 'True' : 'False'}TargetInput`);

            select.innerHTML = '<option value="">-- choose target --</option>';
            select.classList.add('hidden');
            input.classList.add('hidden');
            select.required = false;
            input.required = false;

            if (type === 'extensions') {
                select.classList.remove('hidden');
                select.required = true;
                loadedExtensionsList.forEach(ext => {
                    const opt = document.createElement('option');
                    opt.value = ext.extension;
                    opt.textContent = `${ext.name} (Ext: ${ext.extension})`;
                    select.appendChild(opt);
                });
            } else if (type === 'ringgroups') {
                select.classList.remove('hidden');
                select.required = true;
                loadedRingGroupsList.forEach(rg => {
                    const opt = document.createElement('option');
                    opt.value = rg.grpnum;
                    opt.textContent = `${rg.description} (Group: ${rg.grpnum})`;
                    select.appendChild(opt);
                });
            } else if (type === 'queues') {
                select.classList.remove('hidden');
                select.required = true;
                loadedQueuesList.forEach(q => {
                    const opt = document.createElement('option');
                    opt.value = q.extension;
                    opt.textContent = `${q.descr} (Queue: ${q.extension})`;
                    select.appendChild(opt);
                });
            } else if (type === 'voicemail') {
                select.classList.remove('hidden');
                select.required = true;
                loadedExtensionsList.forEach(ext => {
                    if (ext.voicemail !== 'novm') {
                        const opt = document.createElement('option');
                        opt.value = ext.extension;
                        opt.textContent = `${ext.name} (Voicemail: ${ext.extension})`;
                        select.appendChild(opt);
                    }
                });
            } else if (type === 'timeconditions') {
                select.classList.remove('hidden');
                select.required = true;
                const currTcId = document.getElementById('tcId').value;
                loadedTimeConditionsList.forEach(tc => {
                    if (tc.timeconditions_id != currTcId) {
                        const opt = document.createElement('option');
                        opt.value = tc.timeconditions_id;
                        opt.textContent = `${tc.displayname} (ID: ${tc.timeconditions_id})`;
                        select.appendChild(opt);
                    }
                });
            } else if (type === 'terminate') {
                select.classList.remove('hidden');
                select.required = true;
                
                const terminateTargets = [
                    { value: 'hangup', label: 'Hangup Call' },
                    { value: 'congestion', label: 'Play Congestion Tone' },
                    { value: 'busy', label: 'Play Busy Tone' }
                ];
                terminateTargets.forEach(tgt => {
                    const opt = document.createElement('option');
                    opt.value = tgt.value;
                    opt.textContent = tgt.label;
                    select.appendChild(opt);
                });
            } else if (type === 'custom') {
                input.classList.remove('hidden');
                input.required = true;
            }
            
            updateTcDestValue(prefix);
        }

        function updateTcDestValue(prefix) {
            const type = document.getElementById(`tc${prefix === 'true' ? 'True' : 'False'}Type`).value;
            const select = document.getElementById(`tc${prefix === 'true' ? 'True' : 'False'}TargetSelect`);
            const input = document.getElementById(`tc${prefix === 'true' ? 'True' : 'False'}TargetInput`);
            const hidden = document.getElementById(`tc${prefix === 'true' ? 'True' : 'False'}Goto`);

            let val = '';
            if (type === 'extensions' && select.value) {
                val = `from-did-direct,${select.value},1`;
            } else if (type === 'ringgroups' && select.value) {
                val = `ext-group,${select.value},1`;
            } else if (type === 'queues' && select.value) {
                val = `ext-queues,${select.value},1`;
            } else if (type === 'voicemail' && select.value) {
                val = `ext-local,vmu${select.value},1`;
            } else if (type === 'timeconditions' && select.value) {
                val = `timeconditions,${select.value},1`;
            } else if (type === 'terminate' && select.value) {
                val = `app-blackhole,${select.value},1`;
            } else if (type === 'custom' && input.value.trim()) {
                val = input.value.trim();
            }
            hidden.value = val;
        }

        function editTimeCondition(id) {
            const tc = loadedTimeConditionsList.find(c => c.timeconditions_id === id);
            if (!tc) return;
            
            document.getElementById('tcEditMode').value = 'true';
            document.getElementById('tcId').value = tc.timeconditions_id;
            document.getElementById('tcDisplayName').value = tc.displayname;
            document.getElementById('tcTimeGroup').value = tc.timegroup_id;
            
            const parsedTrue = parseTcDestination(tc.truegoto);
            document.getElementById('tcTrueType').value = parsedTrue.type;
            onTcDestTypeChange('true');
            if (parsedTrue.type === 'custom') {
                document.getElementById('tcTrueTargetInput').value = parsedTrue.target;
            } else {
                document.getElementById('tcTrueTargetSelect').value = parsedTrue.target;
            }
            document.getElementById('tcTrueGoto').value = tc.truegoto || '';

            const parsedFalse = parseTcDestination(tc.falsegoto);
            document.getElementById('tcFalseType').value = parsedFalse.type;
            onTcDestTypeChange('false');
            if (parsedFalse.type === 'custom') {
                document.getElementById('tcFalseTargetInput').value = parsedFalse.target;
            } else {
                document.getElementById('tcFalseTargetSelect').value = parsedFalse.target;
            }
            document.getElementById('tcFalseGoto').value = tc.falsegoto || '';

            document.getElementById('timeConditionModalTitle').textContent = (isRtl ? 'تعديل شرط الوقت: ' : 'Edit Time Condition: ') + tc.displayname;
            openModal('timeConditionModal');
        }

        function saveTimeCondition(e) {
            e.preventDefault();
            const editMode = document.getElementById('tcEditMode').value === 'true';
            const id = document.getElementById('tcId').value;
            const displayname = document.getElementById('tcDisplayName').value.trim();
            const timegroup_id = document.getElementById('tcTimeGroup').value;
            const truegoto = document.getElementById('tcTrueGoto').value;
            const falsegoto = document.getElementById('tcFalseGoto').value;

            if (!truegoto || !falsegoto) {
                showToast('Please select valid destinations for both matched and unmatched conditions.', 'error');
                return;
            }

            const method = editMode ? 'PUT' : 'POST';
            const url = editMode ? `/api/config/timeconditions/${id}` : '/api/config/timeconditions';

            fetch(url, {
                method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ displayname, timegroup_id, truegoto, falsegoto })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    closeModal('timeConditionModal');
                    showToast(editMode ? 'Time Condition updated successfully.' : 'Time Condition added successfully.', 'success');
                    fetchTimeConditions();
                } else {
                    showToast(data.error || 'Failed to save Time Condition.', 'error');
                }
            })
            .catch(err => {
                showToast('Failed to connect to server.', 'error');
            });
        }

        function deleteTimeCondition(id) {
            if (!confirm(isRtl ? 'هل أنت متأكد من حذف شرط الوقت هذا؟' : 'Are you sure you want to delete this Time Condition?')) return;
            fetch(`/api/config/timeconditions/${id}`, { method: 'DELETE' })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        showToast('Time Condition deleted successfully.', 'success');
                        fetchTimeConditions();
                    } else {
                        showToast(data.error || 'Failed to delete Time Condition.', 'error');
                    }
                });
        }

        function parseTcDestination(gotoStr) {
            if (!gotoStr) return { type: '', target: '' };
            if (gotoStr.startsWith('from-did-direct,')) {
                const parts = gotoStr.split(',');
                return { type: 'extensions', target: parts[1] };
            }
            if (gotoStr.startsWith('ext-group,')) {
                const parts = gotoStr.split(',');
                return { type: 'ringgroups', target: parts[1] };
            }
            if (gotoStr.startsWith('ext-queues,')) {
                const parts = gotoStr.split(',');
                return { type: 'queues', target: parts[1] };
            }
            if (gotoStr.startsWith('ext-local,vmu')) {
                const ext = gotoStr.substring(13).split(',')[0];
                return { type: 'voicemail', target: ext };
            }
            if (gotoStr.startsWith('timeconditions,')) {
                const parts = gotoStr.split(',');
                return { type: 'timeconditions', target: parts[1] };
            }
            if (gotoStr.startsWith('app-blackhole,')) {
                const parts = gotoStr.split(',');
                return { type: 'terminate', target: parts[1] };
            }
            return { type: 'custom', target: gotoStr };
        }
    </script>
</body>
</html>
