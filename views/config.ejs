            <div class="flex items-center justify-between mb-5 pb-3 border-b border-[var(--border-primary)]">
                <h3 id="trunkModalTitle" class="text-base font-extrabold text-[var(--text-primary)]">Add SIP Trunk</h3>
                <button onclick="closeModal('trunkModal')" class="text-[var(--text-muted)] hover:text-[var(--text-primary)] cursor-pointer">✕</button>
            </div>
            <form id="trunkForm" onsubmit="saveTrunk(event)">
                <input type="hidden" id="trunkEditId" value="">
                <div class="flex flex-col gap-4">
                    <div>
                        <label class="block text-xs font-bold text-[var(--text-secondary)] uppercase mb-1">Trunk Name *</label>
                        <input type="text" id="trunkName" required placeholder="e.g. vodafone_trunk" class="config-input w-full font-mono">
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-[var(--text-secondary)] uppercase mb-1">Outbound CallerID</label>
                        <input type="text" id="trunkCid" placeholder="e.g. 01012345678" class="config-input w-full">
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-[var(--text-secondary)] uppercase mb-1">Maximum Channels</label>
                        <input type="number" id="trunkMaxChans" placeholder="e.g. 10" class="config-input w-full">
