                    </div>
                </div>
                <div class="flex justify-end gap-3 mt-6 pt-4 border-t border-[var(--border-primary)]">
                    <button type="button" onclick="closeModal('trunkModal')" class="config-btn-secondary px-4 py-2 text-xs">Cancel</button>
                    <button type="submit" class="config-btn-primary px-5 py-2 text-xs">Save Trunk</button>
                </div>
            </form>
        </div>
    </div>

    <!-- MODAL 4: INBOUND ROUTE FORM -->
