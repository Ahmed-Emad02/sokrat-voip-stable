        function renderModalTrunksSequence() {
            const listEl = document.getElementById('outboundTrunksSequenceList');
            if (!listEl) return;
            listEl.innerHTML = '';
            if (modalTrunksSequence.length === 0) {
                listEl.innerHTML = '<span class="text-xs text-[var(--text-muted)] italic">No trunks in sequence yet.</span>';
                return;
            }
            modalTrunksSequence.forEach((trunkId, idx) => {
                const trunkMatch = loadedTrunksList.find(t => t.trunkid == trunkId);
                const trunkName = trunkMatch ? trunkMatch.name : `Trunk ID #${trunkId}`;
                const div = document.createElement('div');
                div.className = 'flex items-center justify-between bg-[var(--bg-secondary)] border border-[var(--border-primary)] px-3 py-1.5 rounded-lg text-xs';
                div.innerHTML = `
                    <span class="font-bold text-[var(--text-primary)] font-mono">${idx + 1}. ${trunkName}</span>
                    <div class="flex items-center gap-2">
                        <button type="button" onclick="moveTrunkInSequence(${idx}, -1)" ${idx === 0 ? 'disabled' : ''} class="text-blue-400 hover:text-blue-500 disabled:opacity-35 disabled:cursor-not-allowed text-[11px] cursor-pointer">▲</button>
                        <button type="button" onclick="moveTrunkInSequence(${idx}, 1)" ${idx === modalTrunksSequence.length - 1 ? 'disabled' : ''} class="text-blue-400 hover:text-blue-500 disabled:opacity-35 disabled:cursor-not-allowed text-[11px] cursor-pointer">▼</button>
                        <button type="button" onclick="removeTrunkFromModalSequence(${idx})" class="text-red-400 hover:text-red-500 ml-2 cursor-pointer">✕</button>
                    </div>
                `;
                listEl.appendChild(div);
            });
        }

        function addTrunkToModalSequence() {
            const selectEl = document.getElementById('sequenceTrunkSelect');
            const trunkId = selectEl.value;
            if (!trunkId) return;
            if (modalTrunksSequence.includes(trunkId)) {
                showToast(isRtl ? 'خط الربط موجود بالفعل في التسلسل.' : 'Trunk is already in the sequence.', 'error');
                return;
            }
            modalTrunksSequence.push(trunkId);
            renderModalTrunksSequence();
            selectEl.value = '';
        }

        function moveTrunkInSequence(idx, dir) {
            const targetIdx = idx + dir;
            if (targetIdx < 0 || targetIdx >= modalTrunksSequence.length) return;
            const temp = modalTrunksSequence[idx];
            modalTrunksSequence[idx] = modalTrunksSequence[targetIdx];
            modalTrunksSequence[targetIdx] = temp;
            renderModalTrunksSequence();
        }

        function removeTrunkFromModalSequence(idx) {
            modalTrunksSequence.splice(idx, 1);
            renderModalTrunksSequence();
        }

        function fetchOutboundRoutes() {
            const tbody = document.getElementById('outbound-table-body');
            fetch('/api/config/routes/outbound')
                .then(res => res.json())
                .then(data => {
                    if (!data.success || !data.routes) return;
                    tbody.innerHTML = '';
                    if (data.routes.length === 0) {
                        tbody.innerHTML = '<tr><td colspan="5" class="py-6 text-center text-[var(--text-muted)]">No outbound routes found.</td></tr>';
                        return;
                    }
                    data.routes.forEach(r => {
                        const tr = document.createElement('tr');
                        tr.className = 'hover:bg-[var(--bg-hover)] transition-colors';
                        
                        const patHtml = r.patterns.map(p => {
                            let text = '';
                            if (p.prepend) text += `(${p.prepend})`;
                            if (p.prefix) text += `${p.prefix}|`;
                            text += p.pattern;
                            if (p.cid) text += `/${p.cid}`;
                            return `<div class="font-mono text-xs bg-[var(--bg-card)] px-2 py-0.5 rounded border border-[var(--border-primary)]/40 w-fit inline-block mr-1 mb-1">${text}</div>`;
                        }).join(' ') || '<span class="text-[var(--text-muted)]">-</span>';
                        
                        const trunkHtml = r.trunks.map(t => {
                            return `<div class="font-mono text-xs text-emerald-400 font-semibold bg-emerald-500/10 px-2 py-0.5 rounded border border-emerald-500/20 w-fit inline-block mr-1 mb-1">${t.trunk_name}</div>`;
                        }).join(' ➔ ') || '<span class="text-[var(--text-muted)]">-</span>';
                        
                        const patternsJson = JSON.stringify(r.patterns).replace(/"/g, '&quot;');
                        const trunksJson = JSON.stringify(r.trunks).replace(/"/g, '&quot;');

                        tr.innerHTML = `
                            <td class="py-3 px-4 font-mono font-bold text-[var(--text-muted)]">${r.route_id}</td>
                            <td class="py-3 px-4 font-bold text-[var(--text-primary)]">${r.name}</td>
                            <td class="py-3 px-4">${patHtml}</td>
                            <td class="py-3 px-4">${trunkHtml}</td>
                            <td class="py-3 px-4 text-center">
                                <div class="flex items-center justify-center gap-2">
                                    <button onclick="editOutboundRoute(${r.route_id}, '${r.name}', '${patternsJson}', '${trunksJson}')" class="px-2.5 py-1 text-xs font-semibold text-blue-400 hover:bg-blue-500/10 rounded border border-blue-500/30">Edit</button>
                                    <button onclick="deleteOutboundRoute(${r.route_id})" class="px-2.5 py-1 text-xs font-semibold text-red-400 hover:bg-red-500/10 rounded border border-red-500/30">Delete</button>
                                </div>
                            </td>
                        `;
                        tbody.appendChild(tr);
                    });
                })
                .catch(err => console.error(err));
        }

