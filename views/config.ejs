                        </div>
                    </div>

                    <div class="flex justify-end gap-3 pt-4 border-t border-[var(--border-primary)]">
                        <button type="button" onclick="resetVoicemailGreetings()" class="px-4 py-2 text-xs font-semibold text-red-400 hover:bg-red-500/10 rounded border border-red-500/30 transition cursor-pointer">
                            <%= isRtl ? 'إعادة ضبط للافتراضي' : 'Reset to Default' %>
                        </button>
                        <button type="submit" class="config-btn-primary px-5 py-2.5 text-xs flex items-center gap-2">
                            <span><%= isRtl ? 'حفظ ترحيب البريد الصوتي' : 'Save Voicemail Greeting' %></span>
                        </button>
                    </div>
                </form>
            </div>
        </div>
        <% } %>
        
        <!-- TAB 8: CONFIG DIAGRAM -->
        <% if (isTabAllowed('diagram')) { %>
        <div id="section-diagram" class="tab-section hidden">
            <style>
                /* Light theme override styling for Config Diagram */
                .light-theme #diagramCanvasContainer {
                    background-color: #f8fafc !important;
                    border-color: #cbd5e1 !important;
                }
                .light-theme #grid-pattern circle {
                    fill: #94a3b8 !important;
                    fill-opacity: 0.35 !important;
                }
                
                /* Cards styling in Light Theme */
                .light-theme .diagram-card {
                    background-color: rgba(255, 255, 255, 0.95) !important;
