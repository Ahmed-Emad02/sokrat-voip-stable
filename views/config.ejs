                                    <button onclick="deleteTimeGroup(${tg.id})" class="px-2.5 py-1 text-xs font-semibold text-red-400 hover:bg-red-500/10 rounded border border-red-500/30 transition cursor-pointer">Delete</button>
                                </div>
                            </td>
                        `;
                        tbody.appendChild(tr);
                    });
                });
        }

        function openTimeGroupModal() {
            document.getElementById('tgEditMode').value = 'false';
            document.getElementById('tgId').value = '';
            document.getElementById('tgDescription').value = '';
            document.getElementById('timeGroupRulesListContainer').innerHTML = '';
            document.getElementById('timeGroupModalTitle').textContent = isRtl ? 'إضافة مجموعة وقت جديدة' : 'Add Time Group';
            addTimeGroupRuleToModal(); // start with one blank rule
            openModal('timeGroupModal');
        }

        function addTimeGroupRuleToModal(data = null) {
            const container = document.getElementById('timeGroupRulesListContainer');
            if (!container) return;

            const card = document.createElement('div');
            card.className = 'rule-card p-4 border border-[var(--border-primary)] rounded-xl bg-[var(--bg-card)]/40 relative flex flex-col gap-3.5';
            
            // Build weekday selector options
            const weekdays = ['mon', 'tue', 'wed', 'thu', 'fri', 'sat', 'sun'];
            const weekdayLabels = { mon: 'Mon', tue: 'Tue', wed: 'Wed', thu: 'Thu', fri: 'Fri', sat: 'Sat', sun: 'Sun' };
            
            let weekdayButtons = '';
            weekdays.forEach(day => {
                let isActive = false;
                if (data && data.weekday) {
                    const wParts = data.weekday.split(',');
                    // check if ranges mon-fri, etc.
                    if (data.weekday.includes('-')) {
                        // resolve simple range
                        const [start, end] = data.weekday.split('-');
                        const startIdx = weekdays.indexOf(start);
                        const endIdx = weekdays.indexOf(end);
                        const currIdx = weekdays.indexOf(day);
                        if (startIdx !== -1 && endIdx !== -1 && currIdx >= startIdx && currIdx <= endIdx) {
                            isActive = true;
                        }
                    } else if (wParts.includes(day)) {
                        isActive = true;
                    }
                }
                const activeClasses = isActive ? 'bg-blue-600 text-white' : 'bg-[var(--bg-secondary)] text-[var(--text-secondary)]';
                weekdayButtons += `
                    <button type="button" data-val="${day}" class="weekday-pill px-2.5 py-1 text-[10px] font-bold rounded-lg border border-[var(--border-primary)] ${activeClasses} hover:text-white cursor-pointer transition">
                        ${weekdayLabels[day]}
                    </button>
                `;
            });

            // Build month selector options
            const months = ['jan', 'feb', 'mar', 'apr', 'may', 'jun', 'jul', 'aug', 'sep', 'oct', 'nov', 'dec'];
            const monthLabels = { jan: 'Jan', feb: 'Feb', mar: 'Mar', apr: 'Apr', may: 'May', jun: 'Jun', jul: 'Jul', aug: 'Aug', sep: 'Sep', oct: 'Oct', nov: 'Nov', dec: 'Dec' };
            
            let monthButtons = '';
            months.forEach(m => {
                let isActive = false;
                if (data && data.month) {
                    const mParts = data.month.split(',');
                    if (data.month.includes('-')) {
                        const [start, end] = data.month.split('-');
                        const startIdx = months.indexOf(start);
                        const endIdx = months.indexOf(end);
                        const currIdx = months.indexOf(m);
                        if (startIdx !== -1 && endIdx !== -1 && currIdx >= startIdx && currIdx <= endIdx) {
                            isActive = true;
                        }
                    } else if (mParts.includes(m)) {
                        isActive = true;
                    }
                }
                const activeClasses = isActive ? 'bg-blue-600 text-white' : 'bg-[var(--bg-secondary)] text-[var(--text-secondary)]';
                monthButtons += `
                    <button type="button" data-val="${m}" class="month-pill px-2 py-1 text-[9px] font-bold rounded-lg border border-[var(--border-primary)] ${activeClasses} hover:text-white cursor-pointer transition">
                        ${monthLabels[m]}
                    </button>
                `;
            });

            // Parse time range
            let startTime = '';
            let endTime = '';
            if (data && data.time && data.time !== '*') {
                const parts = data.time.split('-');
                startTime = parts[0] || '';
                endTime = parts[1] || '';
            }

            // Monthdays range parse
            let startMonthday = '';
            let endMonthday = '';
            if (data && data.monthday && data.monthday !== '*') {
                const parts = data.monthday.split('-');
                startMonthday = parts[0] || '';
                endMonthday = parts[1] || '';
            }

            // Options 1-31 helper
            let dayOptions = '<option value="">Any</option>';
            for (let d = 1; d <= 31; d++) {
                dayOptions += `<option value="${d}">${d}</option>`;
            }

            card.innerHTML = `
                <button type="button" onclick="removeTimeGroupRuleFromModal(this)" class="absolute top-3 right-3 text-red-400 hover:text-red-600 text-xs font-bold cursor-pointer transition">Remove</button>
                <div class="text-xs font-bold text-white mb-1 flex items-center gap-1.5">
                    <span class="w-2 h-2 rounded-full bg-blue-500"></span>
                    Time Rule Window
                </div>
                
                <!-- Time range controls -->
                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <label class="block text-[10px] text-[var(--text-secondary)] uppercase mb-1">Start Time</label>
                        <input type="time" value="${startTime}" class="rule-start-time config-input w-full py-1 text-xs">
                    </div>
                    <div>
                        <label class="block text-[10px] text-[var(--text-secondary)] uppercase mb-1">End Time</label>
                        <input type="time" value="${endTime}" class="rule-end-time config-input w-full py-1 text-xs">
                    </div>
                </div>
                
                <!-- Weekdays multi-select buttons -->
                <div>
                    <label class="block text-[10px] text-[var(--text-secondary)] uppercase mb-1">Days of Week (cont. or specific)</label>
                    <div class="flex flex-wrap gap-1 mb-1.5">
                        ${weekdayButtons}
                    </div>
                    <div class="flex items-center gap-2">
                        <button type="button" onclick="setWeekdayPreset(this, 'all')" class="text-[9px] text-blue-400 font-bold hover:underline cursor-pointer">All Week</button>
                        <span class="text-zinc-600 text-[9px]">•</span>
                        <button type="button" onclick="setWeekdayPreset(this, 'workdays')" class="text-[9px] text-blue-400 font-bold hover:underline cursor-pointer">Mon-Fri</button>
                        <span class="text-zinc-600 text-[9px]">•</span>
                        <button type="button" onclick="setWeekdayPreset(this, 'weekend')" class="text-[9px] text-blue-400 font-bold hover:underline cursor-pointer">Sat-Sun</button>
                    </div>
                </div>
                
                <!-- Days of Month range select -->
                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <label class="block text-[10px] text-[var(--text-secondary)] uppercase mb-1">Start Day of Month</label>
                        <select class="rule-start-monthday config-input w-full py-1 text-xs">
                            ${dayOptions}
                        </select>
                    </div>
                    <div>
                        <label class="block text-[10px] text-[var(--text-secondary)] uppercase mb-1">End Day of Month</label>
                        <select class="rule-end-monthday config-input w-full py-1 text-xs">
                            ${dayOptions}
                        </select>
                    </div>
                </div>
                
                <!-- Months multi-select pills -->
                <div>
                    <label class="block text-[10px] text-[var(--text-secondary)] uppercase mb-1">Months</label>
                    <div class="flex flex-wrap gap-1 mb-1.5">
                        ${monthButtons}
                    </div>
                    <div class="flex items-center gap-2">
                        <button type="button" onclick="setMonthPreset(this, 'all')" class="text-[9px] text-blue-400 font-bold hover:underline cursor-pointer">All Year</button>
                    </div>
                </div>
            `;
            
            container.appendChild(card);
            
            // Set values on newly created selects
            const startSelect = card.querySelector('.rule-start-monthday');
            const endSelect = card.querySelector('.rule-end-monthday');
            if (startMonthday) startSelect.value = startMonthday;
            if (endMonthday) endSelect.value = endMonthday;
        }

        function removeTimeGroupRuleFromModal(btn) {
            const card = btn.closest('.rule-card');
            if (card) card.remove();
        }

        function setWeekdayPreset(btn, preset) {
            const card = btn.closest('.rule-card');
            const pills = card.querySelectorAll('.weekday-pill');
            const workdays = ['mon', 'tue', 'wed', 'thu', 'fri'];
            const weekend = ['sat', 'sun'];
            
            pills.forEach(pill => {
                const val = pill.getAttribute('data-val');
                let active = false;
                if (preset === 'all') active = true;
                else if (preset === 'workdays' && workdays.includes(val)) active = true;
                else if (preset === 'weekend' && weekend.includes(val)) active = true;
                
                if (active) {
                    pill.className = 'weekday-pill px-2.5 py-1 text-[10px] font-bold rounded-lg border border-[var(--border-primary)] bg-blue-600 text-white hover:text-white cursor-pointer transition';
                } else {
                    pill.className = 'weekday-pill px-2.5 py-1 text-[10px] font-bold rounded-lg border border-[var(--border-primary)] bg-[var(--bg-secondary)] text-[var(--text-secondary)] hover:text-white cursor-pointer transition';
                }
            });
        }

        function setMonthPreset(btn, preset) {
            const card = btn.closest('.rule-card');
            const pills = card.querySelectorAll('.month-pill');
            pills.forEach(pill => {
                if (preset === 'all') {
                    pill.className = 'month-pill px-2 py-1 text-[9px] font-bold rounded-lg border border-[var(--border-primary)] bg-blue-600 text-white hover:text-white cursor-pointer transition';
                }
            });
        }

        // Global delegate listener to toggle pills on click
        document.addEventListener('click', function(e) {
            if (e.target.classList.contains('weekday-pill') || e.target.classList.contains('month-pill')) {
                e.target.classList.toggle('bg-blue-600');
                e.target.classList.toggle('text-white');
                e.target.classList.toggle('bg-[var(--bg-secondary)]');
                e.target.classList.toggle('text-[var(--text-secondary)]');
            }
        });

        function editTimeGroup(id) {
            const tg = loadedTimeGroupsList.find(g => g.id === id);
            if (!tg) return;
            
            document.getElementById('tgEditMode').value = 'true';
            document.getElementById('tgId').value = tg.id;
            document.getElementById('tgDescription').value = tg.description;
            
            const container = document.getElementById('timeGroupRulesListContainer');
            container.innerHTML = '';
            
            if (tg.rules && tg.rules.length > 0) {
                tg.rules.forEach(rule => {
                    addTimeGroupRuleToModal(rule);
                });
            } else {
                addTimeGroupRuleToModal();
            }
            
            document.getElementById('timeGroupModalTitle').textContent = (isRtl ? 'تعديل مجموعة الوقت: ' : 'Edit Time Group: ') + tg.description;
            openModal('timeGroupModal');
        }

        function saveTimeGroup(e) {
            e.preventDefault();
            const editMode = document.getElementById('tgEditMode').value === 'true';
            const id = document.getElementById('tgId').value;
            const description = document.getElementById('tgDescription').value.trim();
            
            const rules = [];
            const ruleCards = document.querySelectorAll('#timeGroupRulesListContainer .rule-card');
            
            ruleCards.forEach(card => {
                const startTime = card.querySelector('.rule-start-time').value;
                const endTime = card.querySelector('.rule-end-time').value;
                
                let timeVal = '';
                if (startTime && endTime) {
                    timeVal = `${startTime}-${endTime}`;
                }
                
                const activeWeekdays = [];
                card.querySelectorAll('.weekday-pill.bg-blue-600').forEach(p => {
                    activeWeekdays.push(p.getAttribute('data-val'));
                });
                
                const startMonthday = card.querySelector('.rule-start-monthday').value;
                const endMonthday = card.querySelector('.rule-end-monthday').value;
                let monthdayVal = '';
                if (startMonthday && endMonthday) {
                    monthdayVal = `${startMonthday}-${endMonthday}`;
                } else if (startMonthday) {
                    monthdayVal = startMonthday;
                }
                
                const activeMonths = [];
                card.querySelectorAll('.month-pill.bg-blue-600').forEach(p => {
                    activeMonths.push(p.getAttribute('data-val'));
                });
                
                rules.push({
                    time: timeVal,
                    weekday: activeWeekdays.join(','),
                    monthday: monthdayVal,
                    month: activeMonths.join(',')
                });
            });
            
            const method = editMode ? 'PUT' : 'POST';
            const url = editMode ? `/api/config/timegroups/${id}` : '/api/config/timegroups';
            
            fetch(url, {
                method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ description, rules })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    closeModal('timeGroupModal');
                    showToast(editMode ? 'Time Group updated successfully.' : 'Time Group added successfully.', 'success');
                    fetchTimeGroups();
                } else {
                    showToast(data.error || 'Failed to save Time Group.', 'error');
                }
            })
            .catch(err => {
                showToast('Failed to connect to server.', 'error');
            });
        }

        function deleteTimeGroup(id) {
            if (!confirm(isRtl ? 'هل أنت متأكد من حذف مجموعة الوقت هذه؟' : 'Are you sure you want to delete this Time Group?')) return;
            fetch(`/api/config/timegroups/${id}`, { method: 'DELETE' })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        showToast('Time Group deleted successfully.', 'success');
                        fetchTimeGroups();
                    } else {
                        showToast(data.error || 'Failed to delete Time Group.', 'error');
                    }
                });
        }


        // --- TIME CONDITIONS CLIENT LOGIC ---

        function fetchTimeConditions() {
            fetch('/api/config/timeconditions')
                .then(res => res.json())
                .then(data => {
                    if (!data.success || !data.timeconditions) return;
                    loadedTimeConditionsList = data.timeconditions;
                    
                    const tbody = document.getElementById('timeconditions-table-body');
                    if (!tbody) return;
                    tbody.innerHTML = '';
                    if (data.timeconditions.length === 0) {
                        tbody.innerHTML = '<tr><td colspan="6" class="py-6 text-center text-[var(--text-muted)]">No time conditions found.</td></tr>';
                        return;
                    }

                    data.timeconditions.forEach(tc => {
                        const tr = document.createElement('tr');
                        tr.className = 'hover:bg-[var(--bg-hover)] transition-colors border-b border-[var(--border-primary)]/40 text-xs';
                        
                        tr.innerHTML = `
                            <td class="py-3 px-4 font-mono font-bold text-[var(--text-primary)]">${tc.timeconditions_id}</td>
                            <td class="py-3 px-4 font-bold text-[var(--text-primary)]">${tc.displayname}</td>
                            <td class="py-3 px-4 font-semibold text-blue-400">${tc.timegroup_name || 'None (ID: ' + tc.timegroup_id + ')'}</td>
                            <td class="py-3 px-4 font-mono text-xs text-emerald-400 font-bold">${formatDestination(tc.truegoto)}</td>
                            <td class="py-3 px-4 font-mono text-xs text-rose-400 font-bold">${formatDestination(tc.falsegoto)}</td>
                            <td class="py-3 px-4 text-center">
                                <div class="flex items-center justify-center gap-2">
                                    <button onclick="editTimeCondition(${tc.timeconditions_id})" class="px-2.5 py-1 text-xs font-semibold text-blue-400 hover:bg-blue-500/10 rounded border border-blue-500/30 transition cursor-pointer">Edit</button>
                                    <button onclick="deleteTimeCondition(${tc.timeconditions_id})" class="px-2.5 py-1 text-xs font-semibold text-red-400 hover:bg-red-500/10 rounded border border-red-500/30 transition cursor-pointer">Delete</button>
                                </div>
                            </td>
                        `;
                        tbody.appendChild(tr);
