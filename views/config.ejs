                /* Details box overrides in Light Theme */
                .light-theme .diagram-card div.font-mono {
                    background-color: #f1f5f9 !important; /* Slate-100 */
                    border-color: #cbd5e1 !important; /* Slate-300 */
                    color: #475569 !important; /* Slate-600 */
                }
                .light-theme .diagram-card div.font-mono span {
                    color: #475569 !important; /* Label text (e.g. :Context, :CID) */
                }
                .light-theme .diagram-card div.font-mono span.text-white {
                    color: #0f172a !important; /* Value text (e.g. from-internal) */
                }
                .light-theme .diagram-card div.font-mono span.text-emerald-400 {
                    color: #047857 !important;
                }
                .light-theme .diagram-card div.font-mono span.text-purple-400 {
                    color: #6d28d9 !important;
                }
                .light-theme .diagram-card div.font-mono span.text-red-400 {
                    color: #b91c1c !important;
                }
                .light-theme .diagram-card div.font-mono span.text-cyan-400 {
                    color: #0e7490 !important;
                }
                .light-theme .diagram-card div.font-mono span.text-orange-400 {
                    color: #c2410c !important;
                }
                .light-theme .diagram-card div.font-mono span.text-yellow-400 {
                    color: #a16207 !important;
