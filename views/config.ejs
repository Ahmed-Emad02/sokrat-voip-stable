                        </div>
                        <button onclick="zoomDiagram(1.2)" class="px-2.5 py-1.5 bg-[var(--bg-card)] border border-[var(--border-primary)] hover:bg-[var(--bg-hover)] text-xs font-bold rounded-lg cursor-pointer transition">
