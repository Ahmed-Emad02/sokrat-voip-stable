                    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.04), 0 1px 3px rgba(0, 0, 0, 0.03) !important;
                }
                .light-theme .diagram-card:hover {
                    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.08) !important;
                }
                
                /* Text colors overrides inside card */
                .light-theme .diagram-card span.text-white {
                    color: #0f172a !important; /* Slate-900 */
                }
                .light-theme .diagram-card .text-gray-400,
                .light-theme .diagram-card div.text-\[10px\] {
                    color: #334155 !important; /* Slate-700 (Subtitle) */
