        <div class="h-4 w-[2px] bg-[var(--border-primary)] hidden md:block"></div>

        <!-- Current User -->
        <span class="text-xs font-semibold text-[var(--text-secondary)] hidden md:block"><%= typeof currentUser !== 'undefined' ? currentUser : '' %></span>

