<%
const sidebarWords = {
    en: { dashLink: "Dashboard", cdrLink: "CDR Analytics", empLink: "Employee Metrics", extLink: "Extension Statistics", opLink: "Live Operator", dongleLink: "GSM Dongles", usersLink: "Users", liveClock: "System Clock", themeLabel: "Theme", langLabel: "Language", settingsTitle: "Settings", rowsLabel: "Rows per page" },
    ar: { dashLink: "لوحة التحكم", cdrLink: "تحليلات المكالمات", empLink: "مقاييس الموظفين", extLink: "إحصائيات التحويلة", opLink: "لوحة المراقبة المباشرة", dongleLink: "شرائح GSM", usersLink: "المستخدمين", liveClock: "ساعة النظام", themeLabel: "المظهر", langLabel: "اللغة", settingsTitle: "الإعدادات", rowsLabel: "عدد الصفوف" }
};
const sbT = sidebarWords[currentLang] || sidebarWords['en'];
const isRtl = currentLang === 'ar';
const allowed = typeof allowedTabs !== 'undefined' ? allowedTabs : [];
const isSuper = typeof isSuperAdmin !== 'undefined' && isSuperAdmin;
function can(tab) { return allowed.includes(tab); }
%>

<!-- Light Theme Override Styles -->
<style>
    body.light-theme {
        --bg-primary: #f4f4f5 !important;
        --bg-secondary: #ffffff !important;
        --bg-card: #e4e4e7 !important;
        --bg-hover: #f4f4f5 !important;
        --border-primary: #e4e4e7 !important;
        --border-accent: #d4d4d8 !important;
        --text-primary: #09090b !important;
        --text-secondary: #27272a !important;
        --text-muted: #71717a !important;
    }
    body.light-theme::before {
        background: 
            radial-gradient(circle at 10% 20%, rgba(255, 59, 48, 0.04) 0%, transparent 40%),
            radial-gradient(circle at 90% 80%, rgba(0, 0, 0, 0.02) 0%, transparent 45%) !important;
    }
    
    /* Global classes mapped to theme custom properties */
    body.light-theme .text-white {
        color: #09090b !important;
    }
    body.light-theme select, body.light-theme input {
        background-color: #ffffff !important;
        color: #09090b !important;
        border-color: #e4e4e7 !important;
    }
    body.light-theme select:focus, body.light-theme input:focus {
        border-color: #ff3b30 !important;
    }
    body.light-theme .text-slate-100 {
        color: #18181b !important;
    }
    body.light-theme .text-zinc-300 {
        color: #27272a !important;
    }
    body.light-theme .text-zinc-400 {
        color: #71717a !important;
    }
    body.light-theme .text-zinc-500 {
        color: #71717a !important;
    }
    body.light-theme .text-slate-400 {
        color: #71717a !important;
    }
    body.light-theme .nav-item {
        color: #71717a !important;
    }
    body.light-theme .nav-item:hover {
        color: #ff3b30 !important;
    }
    body.light-theme .ext-card.active {
        background-color: #e4e4e7 !important;
    }
    body.light-theme .ext-card:hover {
        background-color: #f4f4f5 !important;
    }
    body.light-theme #switchboardGrid .panel-surface {
        background-color: #ffffff !important;
        border-color: #e4e4e7 !important;
    }
    body.light-theme #switchboardGrid .bg-gradient-to-br {
        background-image: linear-gradient(to bottom right, #ffffff, rgba(255, 59, 48, 0.05)) !important;
    }
</style>

<!-- Theme Handler Script -->
<script>
    // Prevent theme flickering
    (function() {
        const theme = localStorage.getItem('theme');
        if (theme === 'light') {
            document.documentElement.classList.add('light-theme');
            document.addEventListener('DOMContentLoaded', () => {
                document.body.classList.add('light-theme');
                updateThemeUI(true);
            });
        } else {
            document.addEventListener('DOMContentLoaded', () => {
                updateThemeUI(false);
            });
        }
    })();

    function updateThemeUI(isLight) {
        const thumb = document.getElementById('themeThumb');
        const track = document.getElementById('themeToggleBtn');
        const logo = document.getElementById('brandLogo');
        if (thumb) {
            thumb.classList.toggle('translate-x-5', isLight);
            thumb.classList.toggle('translate-x-0', !isLight);
        }
        if (track) {
            track.classList.toggle('bg-[#e4e4e7]', isLight);
            track.classList.toggle('bg-[#ff3b30]/30', !isLight);
        }
        if (logo) {
            logo.src = isLight ? '/logo.png' : '/logo_dark.png';
        }
    }

    function toggleTheme() {
        const isLight = document.body.classList.toggle('light-theme');
        document.documentElement.classList.toggle('light-theme', isLight);
        localStorage.setItem('theme', isLight ? 'light' : 'dark');
        updateThemeUI(isLight);
        
        if (window.pieChart) {
            location.reload();
        }
        if (window.location.pathname === '/ext-stats') {
            if (window.currentExtension) {
                window.loadStats(window.currentExtension);
            } else {
                window.loadOverview();
            }
        }
    }

    // Settings dropdown
    document.addEventListener('DOMContentLoaded', () => {
        updateThemeUI(localStorage.getItem('theme') === 'light');

        const settingsBtn = document.getElementById('settingsBtn');
        const settingsMenu = document.getElementById('settingsMenu');
        if (settingsBtn && settingsMenu) {
            function positionMenu() {
                settingsMenu.style.width = ''; // reset to auto first
                const rect = settingsBtn.getBoundingClientRect();
                const gap = 6;
                let left = rect.right - settingsMenu.offsetWidth;
                if (left < gap) left = gap;
                if (left + settingsMenu.offsetWidth > window.innerWidth - gap) {
                    left = window.innerWidth - settingsMenu.offsetWidth - gap;
                }
                settingsMenu.style.left = left + 'px';
                let top = rect.bottom + gap;
                if (top + settingsMenu.offsetHeight > window.innerHeight - gap) {
                    top = window.innerHeight - settingsMenu.offsetHeight - gap;
                }
                if (top < gap) top = gap;
                settingsMenu.style.top = top + 'px';
            }
            settingsBtn.addEventListener('click', (e) => {
                e.stopPropagation();
                const isOpen = !settingsMenu.classList.contains('visible');
                if (isOpen) positionMenu();
                settingsMenu.classList.toggle('visible', isOpen);
                settingsMenu.classList.toggle('invisible', !isOpen);
                settingsMenu.classList.toggle('opacity-0', !isOpen);
                settingsMenu.classList.toggle('scale-95', !isOpen);
                settingsMenu.classList.toggle('opacity-100', isOpen);
                settingsMenu.classList.toggle('scale-100', isOpen);
                settingsMenu.style.pointerEvents = isOpen ? 'auto' : 'none';
            });
            document.addEventListener('click', () => {
                settingsMenu.classList.remove('visible', 'opacity-100', 'scale-100');
                settingsMenu.classList.add('invisible', 'opacity-0', 'scale-95');
                settingsMenu.style.pointerEvents = 'none';
            });
            settingsMenu.addEventListener('click', (e) => e.stopPropagation());
            window.addEventListener('scroll', () => {
                if (settingsMenu.classList.contains('visible')) positionMenu();
            });
            window.addEventListener('resize', () => {
                if (settingsMenu.classList.contains('visible')) positionMenu();
            });
        }
    });
</script>

<div class="w-full bg-[var(--bg-secondary)] border-b border-[var(--border-primary)] flex flex-row items-center justify-between px-8 py-4 shadow-lg shrink-0 sticky top-0 z-50 <%= isRtl ? 'flex-row-reverse' : '' %>">
    <!-- Brand Logo and Title -->
    <div class="flex items-center space-x-3 <%= isRtl ? 'space-x-reverse' : '' %>">
        <img id="brandLogo" src="/logo_dark.png" alt="SPT Logo" class="w-14 h-14 object-contain rounded-lg">
        <div>
            <h1 class="text-base font-black text-[var(--text-primary)] tracking-wider font-vibrant-display leading-none">
                SPT-<span class="text-[#ff3b30]">ANALYTICS</span>
            </h1>
            <span class="text-[9px] text-[var(--text-secondary)] uppercase tracking-widest block mt-1 font-bold">Telemetry Console</span>
        </div>
    </div>

    <!-- Center Navigation Links -->
    <nav class="flex items-center space-x-1 md:space-x-2 <%= isRtl ? 'space-x-reverse' : '' %>">
        <a href="/?lang=<%= currentLang %>" 
           class="nav-item flex items-center px-4 py-2.5 rounded-lg transition-all duration-150 text-sm font-semibold relative
           <%= currentPage === '/' ? 'bg-[var(--bg-card)] text-[var(--text-primary)] border border-[var(--border-primary)] shadow-sm' : 'text-[var(--text-secondary)] hover:bg-[var(--bg-hover)]/50 hover:text-[var(--text-primary)]' %>">
            <svg class="w-4 h-4 <%= isRtl ? 'ml-2' : 'mr-2' %>" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            <span class="hidden sm:inline"><%= sbT.dashLink %></span>
            <% if (currentPage === '/') { %>
                <div class="absolute bottom-0 left-4 right-4 h-[2px] bg-[#ff3b30] rounded-t"></div>
            <% } %>
        </a>

        <% if (can('cdr')) { %>
        <a href="/cdr?lang=<%= currentLang %>" 
           class="nav-item flex items-center px-4 py-2.5 rounded-lg transition-all duration-150 text-sm font-semibold relative
           <%= currentPage === '/cdr' ? 'bg-[var(--bg-card)] text-[var(--text-primary)] border border-[var(--border-primary)] shadow-sm' : 'text-[var(--text-secondary)] hover:bg-[var(--bg-hover)]/50 hover:text-[var(--text-primary)]' %>">
            <svg class="w-4 h-4 <%= isRtl ? 'ml-2' : 'mr-2' %>" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
            <span class="hidden sm:inline"><%= sbT.cdrLink %></span>
            <% if (currentPage === '/cdr') { %>
                <div class="absolute bottom-0 left-4 right-4 h-[2px] bg-[#ff3b30] rounded-t"></div>
            <% } %>
        </a>
        <% } %>

        <% if (can('ext-stats')) { %>
        <a href="/ext-stats?lang=<%= currentLang %>" 
           class="nav-item flex items-center px-4 py-2.5 rounded-lg transition-all duration-150 text-sm font-semibold relative
           <%= currentPage === '/ext-stats' ? 'bg-[var(--bg-card)] text-[var(--text-primary)] border border-[var(--border-primary)] shadow-sm' : 'text-[var(--text-secondary)] hover:bg-[var(--bg-hover)]/50 hover:text-[var(--text-primary)]' %>">
            <svg class="w-4 h-4 <%= isRtl ? 'ml-2' : 'mr-2' %>" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            <span class="hidden sm:inline"><%= sbT.extLink %></span>
            <% if (currentPage === '/ext-stats') { %>
                <div class="absolute bottom-0 left-4 right-4 h-[2px] bg-[#ff3b30] rounded-t"></div>
            <% } %>
        </a>
        <% } %>

        <% if (can('operator')) { %>
        <a href="/operator?lang=<%= currentLang %>" 
           class="nav-item flex items-center px-4 py-2.5 rounded-lg transition-all duration-150 text-sm font-semibold relative
           <%= currentPage === '/operator' ? 'bg-[var(--bg-card)] text-[var(--text-primary)] border border-[var(--border-primary)] shadow-sm' : 'text-[var(--text-secondary)] hover:bg-[var(--bg-hover)]/50 hover:text-[var(--text-primary)]' %>">
            <div class="relative flex items-center justify-center <%= isRtl ? 'ml-2' : 'mr-2' %>">
                <span class="animate-ping absolute inline-flex h-2 w-2 rounded-full bg-[#ff3b30] opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-[#ff3b30]"></span>
            </div>
            <span class="hidden sm:inline"><%= sbT.opLink %></span>
            <% if (currentPage === '/operator') { %>
                <div class="absolute bottom-0 left-4 right-4 h-[2px] bg-[#ff3b30] rounded-t"></div>
            <% } %>
        </a>
        <% } %>
        
        <% if (can('gsm-dongles')) { %>
        <a href="/gsm-dongles?lang=<%= currentLang %>" 
           class="nav-item flex items-center px-4 py-2.5 rounded-lg transition-all duration-150 text-sm font-semibold relative
           <%= currentPage === '/gsm-dongles' ? 'bg-[var(--bg-card)] text-[var(--text-primary)] border border-[var(--border-primary)] shadow-sm' : 'text-[var(--text-secondary)] hover:bg-[var(--bg-hover)]/50 hover:text-[var(--text-primary)]' %>">
            <svg class="w-4 h-4 <%= isRtl ? 'ml-2' : 'mr-2' %>" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect>
                <line x1="12" y1="18" x2="12.01" y2="18"></line>
            </svg>
            <span class="hidden sm:inline"><%= sbT.dongleLink %></span>
            <% if (currentPage === '/gsm-dongles') { %>
                <div class="absolute bottom-0 left-4 right-4 h-[2px] bg-[#ff3b30] rounded-t"></div>
            <% } %>
        </a>
        <% } %>

        <% if (isSuper) { %>
        <a href="/users?lang=<%= currentLang %>" 
           class="nav-item flex items-center px-4 py-2.5 rounded-lg transition-all duration-150 text-sm font-semibold relative
           <%= currentPage === '/users' ? 'bg-[var(--bg-card)] text-[var(--text-primary)] border border-[var(--border-primary)] shadow-sm' : 'text-[var(--text-secondary)] hover:bg-[var(--bg-hover)]/50 hover:text-[var(--text-primary)]' %>">
            <svg class="w-4 h-4 <%= isRtl ? 'ml-2' : 'mr-2' %>" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            <span class="hidden sm:inline"><%= sbT.usersLink %></span>
            <% if (currentPage === '/users') { %>
                <div class="absolute bottom-0 left-4 right-4 h-[2px] bg-[#ff3b30] rounded-t"></div>
            <% } %>
        </a>
        <% } %>

    </nav>

    <!-- Right Side: Clock & Settings -->
    <div class="flex items-center space-x-4 <%= isRtl ? 'space-x-reverse' : '' %>">
        <!-- Digital Clock -->
        <div class="text-right hidden md:block">
            <span class="text-[9px] font-black uppercase text-[var(--text-secondary)] tracking-widest block"><%= sbT.liveClock %></span>
            <div id="digitalClock" class="text-sm font-mono font-bold text-[#ff3b30] tracking-widest">00:00:00</div>
        </div>
        
        <div class="h-4 w-[2px] bg-[var(--border-primary)] hidden md:block"></div>

        <!-- Settings Dropdown -->
        <div class="relative" id="settingsDropdown">
            <button id="settingsBtn" class="bg-[var(--bg-secondary)] hover:bg-[var(--bg-hover)] text-[var(--text-primary)] border border-[var(--border-primary)] rounded-lg p-1.5 flex items-center justify-center cursor-pointer transition shadow-sm h-8 w-8" title="Settings">
                <svg class="w-4 h-4 text-[var(--text-secondary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
            </button>

            <!-- Dropdown Menu -->
            <div id="settingsMenu" class="fixed min-w-[14rem] w-auto bg-[var(--bg-secondary)] border border-[var(--border-primary)] rounded-xl shadow-2xl shadow-black/40 opacity-0 invisible scale-95 transition-all duration-150 z-50 overflow-hidden" style="pointer-events:none">
                <!-- Theme Toggle -->
                <div class="flex items-center justify-between px-4 py-3 border-b border-[var(--border-primary)]">
                    <span class="text-xs font-bold text-[var(--text-secondary)] uppercase tracking-wider"><%= sbT.themeLabel %></span>
                    <button id="themeToggleBtn" onclick="toggleTheme()" class="relative w-10 h-5 rounded-full transition-colors duration-200 cursor-pointer bg-[#ff3b30]/30" title="Toggle Light/Dark Theme">
                        <span id="themeThumb" class="absolute top-0.5 left-0.5 w-4 h-4 rounded-full bg-[var(--text-primary)] shadow transition-transform duration-200 translate-x-0"></span>
                    </button>
                </div>
                <!-- Rows per Page -->
                <div class="px-4 py-3 border-b border-[var(--border-primary)]">
                    <span class="block text-xs font-bold text-[var(--text-secondary)] uppercase tracking-wider mb-2"><%= sbT.rowsLabel %></span>
                    <div class="flex space-x-2 <%= isRtl ? 'space-x-reverse' : '' %>">
                        <% [10, 25, 50, 100].forEach(n => { %>
                            <button onclick="localStorage.setItem('cdrPerPage','<%= n %>'); if(window.location.pathname==='/cdr'){window.location.search=window.location.search.replace(/perPage=\d+/,'')+'&perPage=<%= n %>&page=1'}else{this.classList.add('bg-[#ff3b30]','text-white','shadow-sm')}" class="flex-1 px-3 py-1.5 rounded-lg text-xs font-black uppercase tracking-wider transition cursor-pointer bg-[var(--bg-card)] text-[var(--text-secondary)] hover:bg-[var(--bg-hover)] hover:text-[var(--text-primary)]"><%= n %></button>
                        <% }) %>
                    </div>
                </div>
                <!-- Language Selector -->
                <div class="px-4 py-3">
                    <span class="block text-xs font-bold text-[var(--text-secondary)] uppercase tracking-wider mb-2"><%= sbT.langLabel %></span>
                    <div class="flex space-x-2 <%= isRtl ? 'space-x-reverse' : '' %>">
                        <button onclick="location.href=window.location.pathname + '?lang=en'" class="flex-1 px-3 py-1.5 rounded-lg text-xs font-black uppercase tracking-wider transition cursor-pointer <%= currentLang === 'en' ? 'bg-[#ff3b30] text-white shadow-sm' : 'bg-[var(--bg-card)] text-[var(--text-secondary)] hover:bg-[var(--bg-hover)] hover:text-[var(--text-primary)]' %>">EN</button>
                        <button onclick="location.href=window.location.pathname + '?lang=ar'" class="flex-1 px-3 py-1.5 rounded-lg text-xs font-black uppercase tracking-wider transition cursor-pointer <%= currentLang === 'ar' ? 'bg-[#ff3b30] text-white shadow-sm' : 'bg-[var(--bg-card)] text-[var(--text-secondary)] hover:bg-[var(--bg-hover)] hover:text-[var(--text-primary)]' %>">AR</button>
                    </div>
                </div>
                <div class="border-t border-[var(--border-primary)] px-4 py-2">
                    <a href="/logout" class="flex items-center gap-2 text-xs font-bold text-[var(--text-secondary)] hover:text-[#ff3b30] transition py-1.5">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                        Sign Out
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
