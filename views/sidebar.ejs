            <h3 class="text-sm font-black uppercase tracking-wider text-[var(--text-primary)]">Add a Recording</h3>
            <button onclick="closeRecordingModal()" class="text-[var(--text-muted)] hover:text-[var(--text-primary)] transition p-1">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <form id="recordingForm" onsubmit="return submitRecording(event)" class="p-5 space-y-4">
            <div>
                <label class="block text-xs font-bold text-[var(--text-secondary)] uppercase tracking-wider mb-1.5">Recording Name</label>
                <input type="text" id="recordingName" name="name" required placeholder="e.g. welcome_greeting" class="w-full px-3 py-2 rounded-lg text-sm bg-[var(--bg-card)] text-[var(--text-primary)] border border-[var(--border-primary)] placeholder:text-[var(--text-muted)] focus:outline-none focus:border-[var(--accent-color)] transition">
            </div>
            <div>
                <label class="block text-xs font-bold text-[var(--text-secondary)] uppercase tracking-wider mb-1.5">Audio File</label>
                <div class="relative">
                    <input type="file" id="recordingFile" name="file" accept="audio/*,.mpeg,.mpg" required class="w-full text-xs text-[var(--text-secondary)] file:mr-3 file:py-1.5 file:px-3 file:rounded-lg file:border file:border-[var(--border-primary)] file:bg-[var(--bg-card)] file:text-xs file:font-bold file:text-[var(--text-primary)] hover:file:bg-[var(--bg-hover)] file:cursor-pointer file:transition cursor-pointer">
                </div>
                <p class="text-[10px] text-[var(--text-muted)] mt-1">Accepted: MP3, M4A, WAV, OGG, FLAC, AAC, MPEG (max 50MB)</p>
            </div>
            <!-- Progress Bar -->
            <div id="uploadProgressWrap" class="hidden space-y-1">
                <div class="flex justify-between text-[10px] font-semibold text-[var(--text-muted)]">
                    <span id="uploadStatus">Uploading...</span>
                    <span id="uploadPercent">0%</span>
                </div>
                <div class="w-full h-1.5 bg-[var(--bg-card)] rounded-full overflow-hidden">
                    <div id="uploadProgressBar" class="h-full bg-[var(--accent-color)] rounded-full transition-all duration-300" style="width:0%"></div>
                </div>
            </div>
            <div class="flex justify-end gap-2 pt-2">
                <button type="button" onclick="closeRecordingModal()" class="px-4 py-2 rounded-lg text-xs font-bold text-[var(--text-secondary)] bg-[var(--bg-card)] hover:bg-[var(--bg-hover)] transition cursor-pointer">Cancel</button>
                <button type="submit" id="recordingSubmitBtn" class="px-4 py-2 rounded-lg text-xs font-bold text-white bg-[var(--accent-color)] hover:bg-[#e0352b] transition cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed">
                    Upload
                </button>
            </div>
        </form>
    </div>
</div>

<!-- SMTP Settings Modal -->
<div id="smtpModal" class="fixed inset-0 z-[200] flex items-center justify-center bg-black/60 backdrop-blur-sm opacity-0 invisible transition-all duration-200" style="pointer-events:none">
    <div class="bg-[var(--bg-secondary)] border border-[var(--border-primary)] rounded-2xl shadow-2xl shadow-black/50 w-full max-w-md mx-4 overflow-hidden">
        <div class="flex items-center justify-between px-5 py-4 border-b border-[var(--border-primary)]">
            <h3 class="text-sm font-black uppercase tracking-wider text-[var(--text-primary)]">Password Reset Email</h3>
            <button onclick="closeSmtpModal()" class="text-[var(--text-muted)] hover:text-[var(--text-primary)] transition p-1">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <form id="smtpSettingsForm" onsubmit="return saveSmtpSettings(event)" class="p-5 space-y-4">
            <div>
                <label class="block text-xs font-bold text-[var(--text-secondary)] uppercase tracking-wider mb-1.5">Email Address</label>
                <input type="email" id="smtpEmail" name="email" required placeholder="smtp@gmail.com" class="w-full px-3 py-2 rounded-lg text-sm bg-[var(--bg-card)] text-[var(--text-primary)] border border-[var(--border-primary)] placeholder:text-[var(--text-muted)] focus:outline-none focus:border-[var(--accent-color)] transition">
                <p class="text-[10px] text-[var(--text-muted)] mt-1">Gmail or any SMTP email address</p>
            </div>
            <div>
                <label class="block text-xs font-bold text-[var(--text-secondary)] uppercase tracking-wider mb-1.5">App Password</label>
                <input type="password" id="smtpPassword" name="password" placeholder="App Password" class="w-full px-3 py-2 rounded-lg text-sm bg-[var(--bg-card)] text-[var(--text-primary)] border border-[var(--border-primary)] placeholder:text-[var(--text-muted)] focus:outline-none focus:border-[var(--accent-color)] transition">
                <p class="text-[10px] text-[var(--text-muted)] mt-1">Leave blank to keep existing password</p>
            </div>
            <div id="smtpStatusMsg" class="text-xs hidden text-center"></div>
            <div class="flex justify-end gap-2 pt-2">
                <button type="button" onclick="closeSmtpModal()" class="px-4 py-2 rounded-lg text-xs font-bold text-[var(--text-secondary)] bg-[var(--bg-card)] hover:bg-[var(--bg-hover)] transition cursor-pointer">Cancel</button>
                <button type="submit" class="px-4 py-2 rounded-lg text-xs font-bold text-white bg-[var(--accent-color)] hover:bg-[#e0352b] transition cursor-pointer">Save Settings</button>
            </div>
        </form>
    </div>
</div>

<!-- Network Info Modal -->
<div id="networkModal" class="fixed inset-0 z-[200] flex items-center justify-center bg-black/60 backdrop-blur-sm opacity-0 invisible transition-all duration-200" style="pointer-events:none">
    <div class="bg-[var(--bg-secondary)] border border-[var(--border-primary)] rounded-2xl shadow-2xl shadow-black/50 w-full max-w-lg mx-4 overflow-hidden">
        <div class="flex items-center justify-between px-5 py-4 border-b border-[var(--border-primary)]">
            <h3 class="text-sm font-black uppercase tracking-wider text-[var(--text-primary)]">Network Interfaces</h3>
            <button onclick="closeNetworkModal()" class="text-[var(--text-muted)] hover:text-[var(--text-primary)] transition p-1">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <div class="p-5" id="networkInfoContent">
            <div class="text-center text-[var(--text-muted)] text-xs py-8">
                <svg class="animate-spin inline-block w-5 h-5 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" stroke-dasharray="31.4 31.4" stroke-linecap="round"/></svg>
                Loading network info...
            </div>
        </div>
        <div class="flex justify-end px-5 py-4 border-t border-[var(--border-primary)]">
            <button onclick="closeNetworkModal()" class="px-4 py-2 rounded-lg text-xs font-bold text-[var(--text-secondary)] bg-[var(--bg-card)] hover:bg-[var(--bg-hover)] transition cursor-pointer">Close</button>
        </div>
    </div>
</div>

<!-- Toast Notification -->
<div id="toastContainer" class="fixed bottom-6 right-6 z-[100] flex flex-col gap-2 pointer-events-none" style="min-width:280px;max-width:420px"></div>

<div id="flashData" data-success="<%= typeof success !== 'undefined' ? success : '' %>" data-error="<%= typeof error !== 'undefined' ? error : '' %>" style="display:none"></div>

<style>
.success-msg, .error-msg { display: none !important; }
</style>

<script>
function openRecordingModal() {
    document.getElementById('recordingModal').classList.remove('opacity-0', 'invisible');
    document.getElementById('recordingModal').style.pointerEvents = 'auto';
    document.getElementById('settingsMenu').classList.remove('visible', 'opacity-100', 'scale-100');
    document.getElementById('settingsMenu').classList.add('invisible', 'opacity-0', 'scale-95');
    document.getElementById('settingsMenu').style.pointerEvents = 'none';
}

function closeRecordingModal() {
    document.getElementById('recordingModal').classList.add('opacity-0', 'invisible');
    document.getElementById('recordingModal').style.pointerEvents = 'none';
    document.getElementById('recordingForm').reset();
    document.getElementById('uploadProgressWrap').classList.add('hidden');
    document.getElementById('uploadProgressBar').style.width = '0%';
}

function showToast(msg, type) {
    var toastContainer = document.getElementById('toastContainer');
    if (!toastContainer) return;
    var el = document.createElement('div');
    el.className = 'pointer-events-auto px-5 py-3 rounded-xl text-sm font-semibold shadow-2xl shadow-black/40';
    el.style.transform = 'translateX(120%)';
    el.style.opacity = '0';
    el.style.transition = 'all 0.3s';
    if (type === 'error') {
        el.style.backgroundColor = 'rgba(255,59,48,0.15)';
        el.style.border = '1px solid rgba(255,59,48,0.35)';
        el.style.color = '#ff6b6b';
    } else {
        el.style.backgroundColor = 'rgba(34,197,94,0.15)';
        el.style.border = '1px solid rgba(34,197,94,0.35)';
        el.style.color = '#4ade80';
    }
    el.textContent = msg;
    toastContainer.appendChild(el);
    requestAnimationFrame(function() {
        el.style.transform = 'translateX(0)';
        el.style.opacity = '1';
    });
    setTimeout(function() {
        el.style.transform = 'translateX(120%)';
        el.style.opacity = '0';
        setTimeout(function() { if (el.parentNode) el.parentNode.removeChild(el); }, 300);
    }, 5000);
}

async function submitRecording(event) {
    event.preventDefault();
    var fileInput = document.getElementById('recordingFile');
    var nameInput = document.getElementById('recordingName');
    var submitBtn = document.getElementById('recordingSubmitBtn');
    var progressWrap = document.getElementById('uploadProgressWrap');
    var progressBar = document.getElementById('uploadProgressBar');
    var progressPercent = document.getElementById('uploadPercent');
    var uploadStatus = document.getElementById('uploadStatus');

    if (!fileInput.files.length) { showToast('Please select a file', 'error'); return; }
    if (!nameInput.value.trim()) { showToast('Please enter a recording name', 'error'); return; }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Uploading...';
    progressWrap.classList.remove('hidden');

    var formData = new FormData();
    formData.append('file', fileInput.files[0]);
    formData.append('name', nameInput.value.trim());

    try {
        var xhr = new XMLHttpRequest();
        var result = await new Promise(function(resolve, reject) {
            xhr.upload.addEventListener('progress', function(e) {
                if (e.lengthComputable) {
                    var pct = Math.round((e.loaded / e.total) * 100);
                    progressBar.style.width = pct + '%';
                    progressPercent.textContent = pct + '%';
                }
            });
            xhr.addEventListener('load', function() {
                if (xhr.status >= 200 && xhr.status < 300) {
                    resolve(JSON.parse(xhr.responseText));
                } else {
                    try { reject(JSON.parse(xhr.responseText)); }
                    catch(e) { reject({ error: 'Upload failed (HTTP ' + xhr.status + ')' }); }
                }
            });
            xhr.addEventListener('error', function() { reject({ error: 'Network error' }); });
            xhr.open('POST', '/api/settings/recordings/upload');
            xhr.send(formData);
        });

        progressBar.style.width = '100%';
        uploadStatus.textContent = 'Complete!';
        if (result.success) {
            showToast(result.message, 'success');
            setTimeout(closeRecordingModal, 1000);
        } else {
            showToast(result.error || 'Upload failed', 'error');
        }
    } catch (err) {
        showToast(err.error || 'Upload failed', 'error');
        uploadStatus.textContent = 'Failed';
    } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Upload';
        setTimeout(function() {
            progressWrap.classList.add('hidden');
            progressBar.style.width = '0%';
        }, 3000);
    }
    return false;
}

document.addEventListener('DOMContentLoaded', function() {
    var toastContainer = document.getElementById('toastContainer');
    if (!toastContainer) return;

    var flash = document.getElementById('flashData');
    var msg = flash ? (flash.dataset.success || flash.dataset.error) : '';
    var type = flash && flash.dataset.error ? 'error' : 'success';
    if (!msg) return;

    function showToast(msg, type) {
        var el = document.createElement('div');
        el.className = 'pointer-events-auto px-5 py-3 rounded-xl text-sm font-semibold shadow-2xl shadow-black/40';
        el.style.transform = 'translateX(120%)';
        el.style.opacity = '0';
        el.style.transition = 'all 0.3s';
        if (type === 'error') {
            el.style.backgroundColor = 'rgba(255,59,48,0.15)';
            el.style.border = '1px solid rgba(255,59,48,0.35)';
            el.style.color = '#ff6b6b';
        } else {
            el.style.backgroundColor = 'rgba(34,197,94,0.15)';
            el.style.border = '1px solid rgba(34,197,94,0.35)';
            el.style.color = '#4ade80';
        }
        el.textContent = msg;
        toastContainer.appendChild(el);

        requestAnimationFrame(function() {
            el.style.transform = 'translateX(0)';
            el.style.opacity = '1';
        });

        setTimeout(function() {
            el.style.transform = 'translateX(120%)';
            el.style.opacity = '0';
            setTimeout(function() { if (el.parentNode) el.parentNode.removeChild(el); }, 300);
        }, 5000);
    }

    window.showToast = showToast;
    showToast(msg, type);
});
</script>

<script>

function copyAddr(btn) {
    var span = btn.parentElement.querySelector('span.font-mono');
    if (!span) return;
    var text = span.textContent.trim();
    if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(text).catch(function(){});
    }
    var range = document.createRange();
    range.selectNodeContents(span);
    var sel = window.getSelection();
    sel.removeAllRanges();
    sel.addRange(range);
    var orig = btn.innerHTML;
    btn.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>';
    setTimeout(function() { btn.innerHTML = orig; }, 1500);
}

function addrRow(label, value) {
    var copySvg = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
    return '<div class="flex items-center gap-2 text-xs text-[var(--text-muted)] pl-5 py-1">' +
        '<span class="text-[11px] uppercase tracking-wider font-bold text-[var(--text-muted)]">' + label + ':</span>' +
        '<span class="text-sm font-mono text-[var(--text-secondary)] tracking-tight">' + value + '</span>' +
        '<button onclick="copyAddr(this)" class="ml-auto p-0.5 rounded hover:bg-[var(--bg-hover)] transition cursor-pointer opacity-40 hover:opacity-100" title="Copy ' + label + '">' + copySvg + '</button></div>';
}

function openSmtpModal() {
    document.getElementById('settingsMenu').classList.remove('visible', 'opacity-100', 'scale-100');
    document.getElementById('settingsMenu').classList.add('invisible', 'opacity-0', 'scale-95');
    document.getElementById('settingsMenu').style.pointerEvents = 'none';
    document.getElementById('smtpModal').classList.remove('opacity-0', 'invisible');
    document.getElementById('smtpModal').style.pointerEvents = 'auto';
    loadSmtpSettings();
}

function closeSmtpModal() {
    document.getElementById('smtpModal').classList.add('opacity-0', 'invisible');
    document.getElementById('smtpModal').style.pointerEvents = 'none';
}

async function loadSmtpSettings() {
    try {
        const resp = await fetch('/api/settings/smtp');
        const data = await resp.json();
        if (data.success) {
            if (data.email) {
                document.getElementById('smtpEmail').value = data.email;
            }
            if (data.hasPassword) {
                document.getElementById('smtpPassword').placeholder = '\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022 (Saved)';
                document.getElementById('smtpPassword').value = '';
                document.getElementById('smtpPassword').required = false;
            } else {
                document.getElementById('smtpPassword').placeholder = 'App Password';
                document.getElementById('smtpPassword').required = true;
            }
        }
    } catch (e) {
        console.error('Failed to load SMTP settings:', e);
    }
}

async function saveSmtpSettings(event) {
    event.preventDefault();
    const email = document.getElementById('smtpEmail').value;
    const password = document.getElementById('smtpPassword').value;
    const msgEl = document.getElementById('smtpStatusMsg');
    
    msgEl.classList.remove('hidden');
    msgEl.className = 'text-xs text-zinc-400 text-center';
    msgEl.textContent = 'Saving...';
    
    try {
        const resp = await fetch('/api/settings/smtp', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, password })
        });
        const data = await resp.json();
        if (data.success) {
            msgEl.className = 'text-xs text-green-400 text-center';
            msgEl.textContent = 'Saved successfully!';
            document.getElementById('smtpPassword').value = '';
            document.getElementById('smtpPassword').placeholder = '\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022 (Saved)';
            document.getElementById('smtpPassword').required = false;
            if (typeof window.showToast === 'function') {
                window.showToast('SMTP settings saved', 'success');
            }
            setTimeout(closeSmtpModal, 1200);
        } else {
            msgEl.className = 'text-xs text-red-400 text-center';
            msgEl.textContent = data.error || 'Failed to save settings.';
        }
    } catch (e) {
        msgEl.className = 'text-xs text-red-400 text-center';
        msgEl.textContent = 'Error saving settings.';
    }
}

function openNetworkModal() {
    document.getElementById('networkModal').classList.remove('opacity-0', 'invisible');
    document.getElementById('networkModal').style.pointerEvents = 'auto';
    document.getElementById('settingsMenu').classList.remove('visible', 'opacity-100', 'scale-100');
    document.getElementById('settingsMenu').classList.add('invisible', 'opacity-0', 'scale-95');
    document.getElementById('settingsMenu').style.pointerEvents = 'none';
    loadNetworkInfo();
}

function closeNetworkModal() {
    document.getElementById('networkModal').classList.add('opacity-0', 'invisible');
    document.getElementById('networkModal').style.pointerEvents = 'none';
}

async function loadNetworkInfo() {
    var container = document.getElementById('networkInfoContent');
    try {
        var resp = await fetch('/api/network-info');
        var data = await resp.json();
        if (!data.success) throw new Error(data.error);
        if (!data.interfaces || data.interfaces.length === 0) {
            container.innerHTML = '<div class="text-center text-[var(--text-muted)] text-sm py-8">No network interfaces found</div>';
            return;
        }
        var html = '';
        if (data.gateway) {
            html += '<div class="flex items-center gap-2.5 px-3 py-2.5 mb-3 rounded-lg bg-[var(--bg-card)] border border-[var(--border-primary)]">';
            html += '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--accent-color)" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>';
            html += '<span class="text-[11px] font-bold text-[var(--text-muted)] uppercase tracking-wider">Gateway:</span>';
            html += '<span class="text-sm font-mono text-[var(--text-primary)] tracking-tight">' + data.gateway + '</span>';
            html += '<button onclick="copyAddr(this)" class="ml-auto p-0.5 rounded hover:bg-[var(--bg-hover)] transition cursor-pointer opacity-40 hover:opacity-100" title="Copy gateway"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg></button></div>';
        }
        html += '<div class="space-y-2.5">';
        for (var i = 0; i < data.interfaces.length; i++) {
            var iface = data.interfaces[i];
            html += '<div class="px-3 py-3 rounded-lg bg-[var(--bg-card)] border border-[var(--border-primary)]">';
            html += '<div class="flex items-center justify-between mb-2">';
            html += '<div class="flex items-center gap-2.5">';
            html += '<span class="w-2.5 h-2.5 rounded-full z-10 ' + (iface.state === 'up' ? 'bg-green-400' : 'bg-red-400') + '"></span>';
            html += '<span class="text-sm font-bold text-[var(--text-primary)] font-mono">' + iface.name + '</span>';
            html += '<span class="text-[11px] ' + (iface.state === 'up' ? 'text-green-400' : 'text-red-400') + ' uppercase font-bold">' + iface.state + '</span>';
            html += '</div></div>';
            if (iface.mac) html += addrRow('MAC', iface.mac);
            if (iface.ip4) html += addrRow('IPv4', iface.ip4);
            if (iface.ip6) html += addrRow('IPv6', iface.ip6);
            html += '</div>';
        }
        html += '</div>';
        container.innerHTML = html;
    } catch (e) {
        container.innerHTML = '<div class="text-center text-red-400 text-sm py-8">Failed to load network info: ' + e.message + '</div>';
    }
}
</script>



