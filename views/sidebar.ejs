<%
const sidebarWords = {
    en: { dashLink: "Dashboard", cdrLink: "CDR Analytics", empLink: "Employee Metrics", extLink: "Extension Statistics", opLink: "Live Operator", dongleLink: "GSM Dongles", liveClock: "System Clock" },
    ar: { dashLink: "لوحة التحكم", cdrLink: "تحليلات المكالمات", empLink: "مقاييس الموظفين", extLink: "إحصائيات التحويلة", opLink: "لوحة المراقبة المباشرة", dongleLink: "شرائح GSM", liveClock: "ساعة النظام" }
};
const sbT = sidebarWords[currentLang] || sidebarWords['en'];
const isRtl = currentLang === 'ar';
%>

<div class="w-64 min-h-screen bg-[#2E113C] border-purple-900 flex flex-col justify-between p-6 shadow-2xl shrink-0 <%= isRtl ? 'border-l' : 'border-r' %>">
    <div>
        <div class="mb-10 text-center">
            <h1 class="text-xl font-black text-white tracking-wider font-vibrant-display">
                ISSABEL <span class="accent-orange">ANALYTICS</span>
            </h1>
            <div class="h-1 w-12 bg-[#FF8700] mx-auto mt-2 rounded"></div>
        </div>

        <nav class="space-y-3">
            <a href="/?lang=<%= currentLang %>" 
               class="flex items-center px-4 py-3 rounded-xl transition font-medium tracking-wide text-sm
               <%= currentPage === '/' ? 'bg-[#FF8700] text-white font-bold shadow-lg shadow-orange-500/10' : 'text-purple-300 hover:bg-purple-950/40 hover:text-white' %>">
                <span>🏠</span>
                <span class="<%= isRtl ? 'mr-3' : 'ml-3' %>"><%= sbT.dashLink %></span>
            </a>

            <a href="/cdr?lang=<%= currentLang %>" 
               class="flex items-center px-4 py-3 rounded-xl transition font-medium tracking-wide text-sm
               <%= currentPage === '/cdr' ? 'bg-[#FF8700] text-white font-bold shadow-lg shadow-orange-500/10' : 'text-purple-300 hover:bg-purple-950/40 hover:text-white' %>">
                <span>📊</span>
                <span class="<%= isRtl ? 'mr-3' : 'ml-3' %>"><%= sbT.cdrLink %></span>
            </a>

            <a href="/employees?lang=<%= currentLang %>" 
               class="flex items-center px-4 py-3 rounded-xl transition font-medium tracking-wide text-sm
               <%= currentPage === '/employees' ? 'bg-[#FF8700] text-white font-bold shadow-lg shadow-orange-500/10' : 'text-purple-300 hover:bg-purple-950/40 hover:text-white' %>">
                <span>👥</span>
                <span class="<%= isRtl ? 'mr-3' : 'ml-3' %>"><%= sbT.empLink %></span>
            </a>

            <a href="/ext-stats?lang=<%= currentLang %>" 
               class="flex items-center px-4 py-3 rounded-xl transition font-medium tracking-wide text-sm
               <%= currentPage === '/ext-stats' ? 'bg-[#FF8700] text-white font-bold shadow-lg shadow-orange-500/10' : 'text-purple-300 hover:bg-purple-950/40 hover:text-white' %>">
                <span>📈</span>
                <span class="<%= isRtl ? 'mr-3' : 'ml-3' %>"><%= sbT.extLink %></span>
            </a>

            <a href="/operator?lang=<%= currentLang %>" 
               class="flex items-center px-4 py-3 rounded-xl transition font-medium tracking-wide text-sm
               <%= currentPage === '/operator' ? 'bg-[#FF8700] text-white font-bold shadow-lg shadow-orange-500/10' : 'text-purple-300 hover:bg-purple-950/40 hover:text-white' %>">
                <span class="relative flex h-2 w-2 items-center justify-center">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
                </span>
                <span class="<%= isRtl ? 'mr-3' : 'ml-3' %>"><%= sbT.opLink %></span>
            </a>

            <a href="/dongles?lang=<%= currentLang %>" 
               class="flex items-center px-4 py-3 rounded-xl transition font-medium tracking-wide text-sm
               <%= currentPage === '/dongles' ? 'bg-[#FF8700] text-white font-bold shadow-lg shadow-orange-500/10' : 'text-purple-300 hover:bg-purple-950/40 hover:text-white' %>">
                <span>📶</span>
                <span class="<%= isRtl ? 'mr-3' : 'ml-3' %>"><%= sbT.dongleLink %></span>
            </a>
        </nav>
    </div>

    <div class="border-t border-purple-900/60 pt-4 text-center bg-black/20 rounded-xl p-3">
        <span class="text-[10px] font-black uppercase text-purple-400 tracking-widest block mb-1"><%= sbT.liveClock %></span>
        <div id="digitalClock" class="text-lg font-mono font-bold text-white tracking-widest">00:00:00</div>
    </div>
</div>
