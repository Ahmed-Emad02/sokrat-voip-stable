<% const isRtl = currentLang === 'ar'; %>
<!DOCTYPE html>
<html lang="<%= currentLang === 'ar' ? 'ar' : 'en' %>" dir="<%= currentLang === 'ar' ? 'rtl' : 'ltr' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sokrat VOIP - Reset Password</title>
    <link rel="icon" type="image/png" href="/favicon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <style>
        :root {
            --bg-primary: #050507;
            --bg-secondary: #0b0b0e;
            --accent-color: #cc090c;
            --accent-hover: #e62629;
            --accent-dark: #7b0002;
        }
        body {
            font-family: 'Plus Jakarta Sans', 'Cairo', sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            margin: 0;
            padding: 0;
            overflow-x: hidden;
        }
        
        /* Logo breathing and spinning animation */
        @keyframes float-breathing {
            0%, 100% { transform: translateY(0) scale(1); }
            50% { transform: translateY(-6px) scale(1.04); }
        }
        @keyframes spin-clockwise {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
        .logo-float-animation {
            animation: float-breathing 4s ease-in-out infinite;
        }
        .logo-outer-spin {
            animation: spin-clockwise 25s linear infinite;
        }

        .login-card {
            background: rgba(11, 11, 14, 0.45);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 1.5rem;
            padding: 2.25rem 2rem;
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.4);
        }
        
        /* Language specific overrides */
        [dir="rtl"] {
            font-family: 'Cairo', sans-serif;
        }
        [dir="rtl"] .border-r {
            border-right-width: 0px;
            border-left-width: 1px;
        }
    </style>
</head>
<body class="bg-white">
    <!-- Top Half: Brand & Static Logo -->
    <div class="h-[50vh] min-h-[340px] bg-white flex flex-col items-center justify-center relative shrink-0 select-none">
        <!-- Brand Logo Container -->
        <div class="flex flex-col items-center gap-4">
            <!-- Large static brand logo -->
            <img src="/logo_dark.png" alt="Sokrat VOIP" class="w-72 h-72 object-contain logo-float-animation">
            
            <!-- Brand Title -->
            <h1 class="text-3xl font-extrabold tracking-[0.15em] text-[#121215] uppercase mt-2">
                Sokrat <span class="text-[var(--accent-color)]">VOIP</span>
            </h1>
        </div>
        
        <!-- Downward triangle arrow dividing the sections -->
        <div class="absolute bottom-0 left-1/2 -translate-x-1/2 translate-y-px z-20">
            <div class="w-8 h-4 bg-white" style="clip-path: polygon(0 0, 100% 0, 50% 100%);"></div>
        </div>
    </div>

    <!-- Bottom Half: Deep crimson gradient and reset password container -->
    <div class="flex-1 bg-gradient-to-b from-[#cc090c] to-[#7b0002] flex items-center justify-center p-6 relative">
        <div class="w-full max-w-[420px] flex flex-col items-center">
            
            <div id="errorMsg" class="w-full mb-4 text-center text-xs font-bold text-red-600 bg-red-50 border border-red-200 rounded-xl px-4 py-3 shadow-sm <%= (typeof error !== 'undefined' && error) ? '' : 'hidden' %>">
                <%= typeof error !== 'undefined' ? error : '' %>
            </div>

            <!-- Form White Card Container -->
            <div class="bg-white rounded-2xl shadow-2xl w-full p-8 border border-gray-100 flex flex-col">
                <div class="text-center mb-6">
                    <h2 class="text-gray-900 font-bold text-base uppercase tracking-wider">Reset Password</h2>
                </div>

                <form id="resetForm" onsubmit="executeReset(event)" class="space-y-4">
                    <input type="hidden" id="token" value="<%= token %>">
                    
                    <!-- New Password -->
                    <div class="space-y-1.5">
                        <label class="block text-sm font-semibold text-gray-700 mb-2 uppercase tracking-wide <%= isRtl ? 'text-right' : 'text-left' %>">
                            New Password
                        </label>
                        <div class="relative flex items-center bg-gray-50 border border-gray-300 rounded-lg focus-within:ring-2 focus-within:ring-red-600 focus-within:border-transparent transition-all overflow-hidden">
                            <div class="w-11 h-11 flex items-center justify-center text-gray-400 border-e border-gray-300 shrink-0">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                                    <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                                </svg>
                            </div>
                            <input type="password" id="password" placeholder="••••••" required minlength="3" class="w-full h-11 px-4 bg-transparent border-0 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-0 text-[14px]">
                        </div>
                    </div>

                    <!-- Confirm Password -->
                    <div class="space-y-1.5">
                        <label class="block text-sm font-semibold text-gray-700 mb-2 uppercase tracking-wide <%= isRtl ? 'text-right' : 'text-left' %>">
                            Confirm Password
                        </label>
                        <div class="relative flex items-center bg-gray-50 border border-gray-300 rounded-lg focus-within:ring-2 focus-within:ring-red-600 focus-within:border-transparent transition-all overflow-hidden">
                            <div class="w-11 h-11 flex items-center justify-center text-gray-400 border-e border-gray-300 shrink-0">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                                    <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                                </svg>
                            </div>
                            <input type="password" id="confirm_password" placeholder="••••••" required minlength="3" class="w-full h-11 px-4 bg-transparent border-0 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-0 text-[14px]">
                        </div>
                    </div>

                    <!-- Submit Button -->
                    <button type="submit" class="w-full bg-red-600 hover:bg-red-700 text-white font-bold py-3 px-4 rounded-lg transition-colors flex justify-center items-center gap-2 mt-6 cursor-pointer shadow-sm">
                        <span>Reset Password</span>
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="9 18 15 12 9 6"></polyline>
                        </svg>
                    </button>
                </form>

                <!-- Back to Login Link -->
                <div class="mt-5 text-center">
                    <a href="/login" class="text-sm text-red-600 hover:text-red-800 hover:underline transition-colors cursor-pointer">
                        <%= currentLang === 'ar' ? 'العودة لتسجيل الدخول' : 'Back to Login' %>
                    </a>
                </div>
            </div>
            
            <!-- Footer Copyright -->
            <p class="text-xs text-white/80 mt-8 text-center select-none font-mono">
                Sokrat VOIP is licensed under GPL. 2006 - 2026.
            </p>
        </div>
    </div>

    <script>
        async function executeReset(event) {
            event.preventDefault();
            const token = document.getElementById('token').value;
            const password = document.getElementById('password').value;
            const confirmPassword = document.getElementById('confirm_password').value;
            const errorMsg = document.getElementById('errorMsg');
            
            if (errorMsg) {
                errorMsg.classList.add('hidden');
                errorMsg.textContent = '';
            }
            
            if (password !== confirmPassword) {
                showError('Passwords do not match');
                return;
            }
            
            try {
                const resp = await fetch('/api/auth/reset-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ token, password })
                });
                const data = await resp.json();
                if (data.success) {
                    window.location.href = '/login?reset=success';
                } else {
                    showError(data.error || 'Failed to reset password');
                }
            } catch (e) {
                showError('An error occurred. Please try again.');
            }
        }
        
        function showError(msg) {
            const errorEl = document.getElementById('errorMsg');
            if (errorEl) {
                errorEl.classList.remove('hidden');
                errorEl.textContent = msg;
            }
        }
    </script>
</body>
</html>
