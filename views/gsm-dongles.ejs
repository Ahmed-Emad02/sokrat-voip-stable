                        <button type="submit" id="ussd-submit-btn" class="bg-red-600 text-white font-medium shadow-sm hover:bg-red-700 focus:ring-2 focus:ring-red-500 focus:ring-offset-2 transition-all disabled:opacity-50 disabled:cursor-not-allowed rounded-lg py-2.5 text-sm flex items-center justify-center gap-2 cursor-pointer">
                            <span id="btn-label"><%= t.sendBtn %></span>
                            <div id="btn-spinner" class="w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin hidden"></div>
                        </button>
