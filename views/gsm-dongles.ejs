                    <%= isRtl ? 'إغلاق' : 'Close' %>
                </button>
            </div>
        </div>
    </div>

    <!-- WebSockets Real-time streaming -->
    <script src="/socket.io/socket.io.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Digital Clock
            const clockEl = document.getElementById('digitalClock');
            if (clockEl) {
                setInterval(() => { clockEl.textContent = new Date().toTimeString().split(' ')[0]; }, 1000);
            }
            
            let loadedDevices = <%- JSON.stringify(devices || []) %>;
            const isRtl = <%= isRtl %>;
            
            const words = {
                stateFree: "<%= t.stateFree %>",
                stateDisconnected: "<%= t.stateDisconnected %>",
                stateGsmNotResponding: "<%= t.stateGsmNotResponding %>",
                stateNotInitializing: "<%= t.stateNotInitializing %>",
                reloadedSuccess: "<%= t.reloadedSuccess %>",
                sendUssdError: "<%= t.sendUssdError %>",
                sending: "<%= t.sending %>",
                sendBtn: "<%= t.sendBtn %>",
                running: "<%= t.running %>",
                refreshBtn: "<%= t.refreshBtn %>",
                resetUsbBtn: "<%= t.resetUsbBtn %>",
                resetUsbStarted: "<%= t.resetUsbStarted %>",
                noDongles: "<%= t.noDongles %>",
                selectPlaceholder: "<%= t.selectPlaceholder %>"
            };

            // Socket.io initialization with safety check to prevent halts if blocked/undefined
            let socket = null;
            if (typeof io !== 'undefined') {
                socket = io();
            } else {
                console.warn("Socket.io (io) is not defined. Real-time updates will be disabled.");
            }
            
            // Elements
            const logsToggle = document.getElementById('logs-toggle-switch');
            const logScreen = document.getElementById('log-screen-console');
            const logsAutoscroll = document.getElementById('logs-autoscroll-chk');
            const clearLogsBtn = document.getElementById('clear-logs-btn');
            
            const ussdForm = document.getElementById('ussd-execution-form');
            const ussdTarget = document.getElementById('ussd-target-dongle');
            const ussdInput = document.getElementById('ussd-code-input');
            const ussdSubmitBtn = document.getElementById('ussd-submit-btn');
            const btnLabel = document.getElementById('btn-label');
            const btnSpinner = document.getElementById('btn-spinner');
            const terminalScreen = document.getElementById('terminal-screen');
            const terminalPlaceholder = document.getElementById('terminal-placeholder');
            
            const globalRefreshBtn = document.getElementById('global-refresh-btn');
            
            // Detail display elements
            const elId = document.getElementById('info-id');
            const elNum = document.getElementById('info-number');
            const elProv = document.getElementById('info-provider');
            const elImei = document.getElementById('info-imei');
            const elImsi = document.getElementById('info-imsi');
            const elGroup = document.getElementById('info-group');
            const elModel = document.getElementById('info-model');
            const elFirm = document.getElementById('info-firmware');
            const elMode = document.getElementById('info-mode');
            const elSub = document.getElementById('info-submode');

            let selectedDongleId = null;
            let allSmsMessages = [];
            let lastUssdText = "";
            let lastUssdTime = 0;

            function appendUssdResponse(logTime, text, isLive) {
                const now = Date.now();
                const normalizedText = String(text || '').trim();
                
                // Deduplicate identical responses printed within 3 seconds
                if (normalizedText === lastUssdText && (now - lastUssdTime) < 3000) {
                    return;
                }
                
                lastUssdText = normalizedText;
                lastUssdTime = now;
                
                const respLine = document.createElement('div');
                respLine.className = 'text-emerald-400 font-bold bg-emerald-950/10 p-2 rounded border border-emerald-900/20 mt-1 whitespace-pre-wrap leading-relaxed select-text';
                
                const displayLabel = isLive ? ' (Live Event)' : '';
                const displayText = normalizedText || '(Empty Response / Terminated by Network)';
                respLine.innerHTML = `<span class="text-zinc-500 font-normal">[${logTime}]${displayLabel}</span> ${displayText}`;
                
                terminalScreen.appendChild(respLine);
                terminalScreen.scrollTop = terminalScreen.scrollHeight;
            }

            // Select Row behavior to display details
            window.selectDevice = function(id) {
                try {
                    const dev = loadedDevices.find(d => d.ID === id);
                    if (!dev) return;
                    
                    // Highlight row
                    document.querySelectorAll('#dongles-table-body tr').forEach(tr => {
                        tr.classList.remove('selected-row');
                    });
                    const selectedRow = document.getElementById('row-' + id);
                    if (selectedRow) selectedRow.classList.add('selected-row');
                    
                    // Fill metadata cards
                    elId.textContent = dev.ID || '-';
                    elNum.textContent = dev.Number || 'Unknown';
                    elProv.textContent = dev['Provider Name'] || 'NONE';
                    elImei.textContent = dev.IMEI || '-';
                    elImsi.textContent = dev.IMSI || '-';
                    elGroup.textContent = dev.Group || '0';
                    elModel.textContent = dev.Model || '-';
                    elFirm.textContent = dev.Firmware || '-';
                    elMode.textContent = dev.Mode || '-';
                    elSub.textContent = dev.Submode || '-';

                    // Update SMS Inbox state
                    selectedDongleId = id;
                    updateSmsInboxTitle();
                    filterAndRenderSms();

                    // Sync select dropdown
                    if (ussdTarget) {
                        ussdTarget.value = id;
                    }
                } catch (err) {
                    console.error("Error inside selectDevice:", err);
                }
            };

            // Initialize detail selection if devices exist
            if (loadedDevices.length > 0) {
                selectDevice(loadedDevices[0].ID);
                
                // Set click listeners on rows
                loadedDevices.forEach(d => {
                    const tr = document.getElementById('row-' + d.ID);
                    if (tr) {
                        tr.style.cursor = 'pointer';
                        tr.addEventListener('click', (e) => {
                            if (e.target.closest('button')) return;
                            selectDevice(d.ID);
                        });
                    }
                });
            }

            // Sync detail card and table highlight when select dropdown is changed
            if (ussdTarget) {
                ussdTarget.addEventListener('change', (e) => {
                    selectDevice(e.target.value);
                });
            }

            // --- SMS INBOX MANAGEMENT ---
            const smsInboxContainer = document.getElementById('sms-inbox-container');
            const smsEmptyPlaceholder = document.getElementById('sms-empty-placeholder');

            function updateSmsInboxTitle() {
                const titleEl = document.getElementById('sms-inbox-title');
                if (titleEl) {
                    const baseText = isRtl ? 'صندوق وارد الرسائل (SMS)' : 'SMS Incoming Inbox';
                    titleEl.innerHTML = `
                        <svg class="text-[var(--accent-color)]" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                            <polyline points="22,6 12,13 2,6"></polyline>
                        </svg>
                        ${baseText} - <span class="accent-orange font-mono">${selectedDongleId}</span>
                    `;
                }
            }

            // Toast Notification system
            const toastContainer = document.getElementById('toast-container');
            
            function showSmsToast(sms) {
                if (!toastContainer) return;
                
                const toast = document.createElement('div');
                // Premium glassmorphism dark-red style
                toast.className = 'bg-zinc-950/90 border border-zinc-900 shadow-2xl p-4 rounded-xl flex flex-col gap-1.5 transform translate-y-5 opacity-0 transition-all duration-300 pointer-events-auto cursor-pointer max-w-xs';
                
                toast.innerHTML = `
                    <div class="flex items-center justify-between text-xs">
                        <span class="text-[var(--accent-color)] font-bold uppercase tracking-wider font-mono">${isRtl ? 'رسالة جديدة' : 'New SMS'}</span>
                        <span class="text-zinc-500 font-mono text-[10px]">${sms.dongleId}</span>
                    </div>
                    <div class="text-xs font-bold text-white">${sms.sender}</div>
                    <p class="text-xs text-zinc-400 truncate">${sms.content}</p>
                `;
                
                toast.onclick = function() {
                    if (selectedDongleId && selectedDongleId.toLowerCase() !== sms.dongleId.toLowerCase()) {
                        selectDevice(sms.dongleId);
                    }
                    showSmsModal(sms.dongleId, sms.sender, sms.content, sms.timestamp);
                    toast.remove();
                };
                
                toastContainer.appendChild(toast);
                
                // Animate entrance
                setTimeout(() => {
                    toast.classList.remove('translate-y-5', 'opacity-0');
                }, 10);
                
                // Auto dismiss after 6 seconds
                setTimeout(() => {
                    toast.classList.add('translate-y-5', 'opacity-0');
                    setTimeout(() => { toast.remove(); }, 300);
                }, 6000);
            }

            function showToast(title, message, type) {
                if (!toastContainer) return;
                const toast = document.createElement('div');
                const borderColor = type === 'error' ? 'border-red-900' : type === 'success' ? 'border-emerald-900' : 'border-zinc-700';
                const titleColor = type === 'error' ? 'text-red-400' : type === 'success' ? 'text-emerald-400' : 'text-zinc-300';
                toast.className = 'bg-zinc-950/90 border ' + borderColor + ' shadow-2xl p-4 rounded-xl flex flex-col gap-1.5 transform translate-y-5 opacity-0 transition-all duration-300 pointer-events-auto max-w-xs';
                toast.innerHTML = '\
                    <div class="flex items-center justify-between text-xs">\
                        <span class="' + titleColor + ' font-bold uppercase tracking-wider">' + title + '</span>\
                    </div>\
                    <p class="text-xs text-zinc-400 whitespace-pre-wrap">' + message + '</p>\
                ';
                toast.onclick = function() { toast.remove(); };
                toastContainer.appendChild(toast);
                setTimeout(function() { toast.classList.remove('translate-y-5', 'opacity-0'); }, 10);
                setTimeout(function() {
                    toast.classList.add('translate-y-5', 'opacity-0');
                    setTimeout(function() { toast.remove(); }, 300);
                }, 8000);
            }

            // Modal DOM elements & controllers
            const smsModal = document.getElementById('sms-modal');
            const smsModalCard = document.getElementById('sms-modal-card');
            const smsModalDongle = document.getElementById('sms-modal-dongle');
            const smsModalSender = document.getElementById('sms-modal-sender');
            const smsModalCopySender = document.getElementById('sms-modal-copy-sender');
            const smsModalTime = document.getElementById('sms-modal-time');
            const smsModalContent = document.getElementById('sms-modal-content');
            
            window.showSmsModal = function(dongleId, sender, content, timestamp) {
                smsModalDongle.textContent = dongleId;
                smsModalSender.textContent = sender;
                smsModalTime.textContent = new Date(timestamp).toLocaleString();
                smsModalContent.textContent = content;
                
                smsModalCopySender.onclick = function() {
                    copyToClipboard(sender, smsModalCopySender);
                };
                
                smsModal.classList.remove('opacity-0', 'pointer-events-none');
                smsModalCard.classList.remove('scale-95', 'opacity-0');
                smsModalCard.classList.add('scale-100', 'opacity-100');
            };
            
            window.closeSmsModal = function() {
                smsModal.classList.add('opacity-0', 'pointer-events-none');
                smsModalCard.classList.remove('scale-100', 'opacity-100');
                smsModalCard.classList.add('scale-95', 'opacity-0');
            };
            
            // Close on outer click
            smsModal.addEventListener('click', (e) => {
                if (e.target === smsModal) closeSmsModal();
            });
            
            // Close on ESC
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape' && !smsModal.classList.contains('opacity-0')) {
                    closeSmsModal();
                }
            });

            function renderSmsCard(sms) {
                const dateStr = new Date(sms.timestamp).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', second: '2-digit' });
                const card = document.createElement('div');
                card.className = 'p-4 bg-zinc-950 border border-zinc-900 hover:border-zinc-800 rounded-xl transition flex flex-col gap-2 cursor-pointer select-none';
                card.id = 'sms-' + sms.id;
                card.innerHTML = `
                    <div class="flex items-center justify-between text-xs pointer-events-none">
                        <div class="flex items-center gap-2 pointer-events-auto">
                            <span class="bg-[var(--accent-color)] text-white font-mono font-bold px-1.5 py-0.5 rounded text-[10px] uppercase">${sms.dongleId}</span>
                            <span class="text-white font-bold font-mono">${sms.sender}</span>
                            <button onclick="copyToClipboard('${sms.sender}', this)" class="text-zinc-600 hover:text-white p-0.5 rounded transition cursor-pointer" title="Copy Number">
                                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                            </button>
                        </div>
                        <span class="text-zinc-500 font-mono">${dateStr}</span>
                    </div>
                    <p class="text-sm text-[var(--text-secondary)] leading-relaxed select-text font-sans truncate pointer-events-none">${sms.content}</p>
                `;
                
                card.addEventListener('click', (e) => {
                    if (e.target.closest('button')) return;
                    showSmsModal(sms.dongleId, sms.sender, sms.content, sms.timestamp);
                });
                
                return card;
            }

            function filterAndRenderSms() {
                if (!selectedDongleId) {
                    showEmptySmsInbox();
                    return;
                }
                
                const filtered = allSmsMessages.filter(sms => (sms.dongleId || '').toLowerCase() === selectedDongleId.toLowerCase());
                smsInboxContainer.innerHTML = '';
                
                if (filtered.length > 0) {
                    filtered.forEach(sms => {
                        smsInboxContainer.appendChild(renderSmsCard(sms));
                    });
                } else {
                    showEmptySmsInbox();
                }
            }

            window.loadSmsInbox = async function() {
                try {
                    const res = await fetch('/api/gsm-dongles/sms');
                    const data = await res.json();
                    if (data.success && data.sms) {
                        allSmsMessages = data.sms;
                        filterAndRenderSms();
                    } else {
                        allSmsMessages = [];
                        showEmptySmsInbox();
                    }
                } catch (e) {
                    console.error("Failed to load SMS inbox:", e);
                }
            };

            window.clearSmsInbox = async function() {
                if (!confirm(isRtl ? 'هل أنت متأكد من مسح صندوق الرسائل؟' : 'Are you sure you want to clear the SMS inbox?')) return;
                try {
                    await fetch('/api/gsm-dongles/clear-sms', { method: 'POST' });
                } catch (e) {
                    console.error("Failed to clear SMS inbox:", e);
                }
            };

            function showEmptySmsInbox() {
                smsInboxContainer.innerHTML = `
                    <div class="text-center py-8 text-[var(--text-muted)] italic" id="sms-empty-placeholder">
                        ${isRtl ? 'لا يوجد رسائل واردة حالياً' : 'No incoming SMS messages'}
                    </div>
                `;
            }

            // Real-time SMS receivers
            if (socket) {
                socket.on('newSms', (sms) => {
                    allSmsMessages.unshift(sms);
                    
                    // Show a real-time toast notification alert
                    showSmsToast(sms);
                    
                    if (selectedDongleId && (sms.dongleId || '').toLowerCase() === selectedDongleId.toLowerCase()) {
                        const placeholder = document.getElementById('sms-empty-placeholder');
                        if (placeholder && placeholder.parentNode) {
                            placeholder.parentNode.removeChild(placeholder);
                        }
                        smsInboxContainer.insertBefore(renderSmsCard(sms), smsInboxContainer.firstChild);
                    }
                });

                socket.on('smsCleared', () => {
                    allSmsMessages = [];
                    showEmptySmsInbox();
                });
            }

            // Initial load
            loadSmsInbox();

            // Real-time log receiver
            if (socket) {
                socket.on('dongleLog', (line) => {
                    if (!logsToggle.checked) return;
                    
                    const lineEl = document.createElement('div');
                    lineEl.className = 'py-0.5 border-b border-zinc-950/20';
                    
                    if (line.includes('ERROR') || line.includes('WARNING') || line.includes('Failed')) {
                        lineEl.className += ' text-rose-500';
                    } else if (line.includes('NOTICE') || line.includes('Got USSD')) {
                        lineEl.className += ' text-emerald-400 font-bold';
                    } else {
                        lineEl.className += ' text-zinc-500';
                    }
                    
                    lineEl.textContent = line;
                    logScreen.appendChild(lineEl);
                    
                    if (logsAutoscroll.checked) {
                        logScreen.scrollTop = logScreen.scrollHeight;
                    }
                });
            }

            // Log Controls
            clearLogsBtn.addEventListener('click', () => {
                logScreen.innerHTML = '<div class="text-zinc-600">[System] Log screen cleared. Awaiting hardware events...</div>';
            });

            // Toggle logs console container visibility
            logsToggle.addEventListener('change', () => {
                logScreen.classList.toggle('hidden', !logsToggle.checked);
            });

            // Copy to clipboard utility with green checkmark feedback (supports non-secure HTTP local IP fallback)
            window.copyToClipboard = function(text, btn) {
                const clean = String(text || '').trim();
                if (!clean || clean === '-' || clean === 'Unknown') return;
                
                function fallbackCopy(val) {
                    const textArea = document.createElement("textarea");
                    textArea.value = val;
                    textArea.style.top = "0";
                    textArea.style.left = "0";
                    textArea.style.position = "fixed";
                    textArea.style.opacity = "0";
                    document.body.appendChild(textArea);
                    textArea.focus();
                    textArea.select();
                    try {
                        document.execCommand('copy');
                        showFeedback();
                    } catch (err) {
                        console.error('Fallback copy failed: ', err);
                    }
                    document.body.removeChild(textArea);
                }

                function showFeedback() {
                    if (btn) {
                        const originalHTML = btn.innerHTML;
                        btn.innerHTML = `<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
                        btn.style.pointerEvents = 'none';
                        setTimeout(() => {
                            btn.innerHTML = originalHTML;
                            btn.style.pointerEvents = 'auto';
                        }, 1500);
                    }
                }

                if (navigator.clipboard && navigator.clipboard.writeText) {
                    navigator.clipboard.writeText(clean).then(showFeedback).catch(() => {
                        fallbackCopy(clean);
                    });
                } else {
                    fallbackCopy(clean);
                }
            };

            // Edit SIM phone number mapping action
            window.editSimNumber = function(dongleId, imsi, currentVal) {
                const promptMsg = isRtl 
                    ? `أدخل رقم الهاتف الجديد للشريحة (IMSI: ${imsi}):` 
                    : `Enter phone number for SIM card (IMSI: ${imsi}):`;
                
                const newNum = prompt(promptMsg, currentVal);
                if (newNum === null) return;
                
                const trimmed = newNum.trim().replace(/\s+/g, '');
                if (!trimmed) return;

                if (!/^\+?\d{11}$/.test(trimmed)) {
                    showToast(dongleId, isRtl ? 'يجب إدخال رقم مكون من 11 رقمًا بالضبط.' : 'Enter exactly 11 digits.', 'error');
                    return;
                }
                
                const displaySpan = document.getElementById('display-num-' + dongleId);
                if (displaySpan) displaySpan.innerHTML = '<span class="text-zinc-500 italic">Saving...</span>';
                
                showToast(dongleId, isRtl ? 'جاري حفظ الرقم...' : 'Saving number and sending AT commands...', 'info');
                
                fetch('/api/gsm-dongles/save-number', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ imsi, number: trimmed, dongleId })
                })
                .then(res => res.json())
                .then(data => {
                    if (data.results) {
                        let details = data.results.map(function(r) {
                            const status = r.error ? '❌' : '✅';
                            return status + ' ' + r.step + (r.error ? ': ' + r.error : '');
                        }).join('\n');
                        showToast(dongleId + ' ' + (data.success ? (isRtl ? 'تم' : 'Done') : (isRtl ? 'فشل' : 'Failed')), details, data.success ? 'success' : 'error');
                    } else if (data.success) {
                        showToast(dongleId, isRtl ? 'تم الحفظ' : 'Number saved', 'success');
                    } else {
                        showToast(dongleId, (isRtl ? 'فشل: ' : 'Failed: ') + (data.error || 'Unknown error'), 'error');
                    }
                    refreshDevicesList();
                })
                .catch(err => {
                    console.error("Error saving SIM number:", err);
                    showToast(dongleId, isRtl ? 'خطأ في الاتصال' : 'Connection error', 'error');
                    refreshDevicesList();
                });
            };

            // Reload single dongle action
            window.reloadDongle = function(id) {
                if (!confirm((isRtl ? 'هل أنت متأكد من إعادة تشغيل الشريحة ' : 'Are you sure you want to reload ') + id + '?')) return;
                
                const btn = document.querySelector(`#row-${id} button`);
                if (btn) btn.disabled = true;
                
                fetch('/api/gsm-dongles/reload/' + id, { method: 'POST' })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) {
                            alert(words.reloadedSuccess + ' (' + id + ')');
                            refreshDevicesList();
                        } else {
                            alert('Error: ' + (data.error || 'Unknown server error'));
                        }
                    })
                    .catch(err => alert('Network error: ' + err.message))
                    .finally(() => { if (btn) btn.disabled = false; });
            };

            // Reset USB port (unplug/replug simulation) for a dongle
            window.resetUsbPort = function(id) {
                const btn = document.getElementById('resetBtn-' + id);
                const span = btn ? btn.querySelector('span') : null;
                const origText = span ? span.innerText : words.resetUsbBtn;
                if (span) span.innerText = words.resetUsbStarted;
                if (btn) btn.disabled = true;

                fetch('/api/gsm-dongles/reset-usb-port', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ dongleId: id })
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        if (data.results) {
                            let details = data.results.map(function(r) {
                                const status = r.error ? '❌' : '✅';
                                return status + ' ' + r.step + (r.error ? ': ' + r.error : '');
                            }).join('\n');
                            showToast(id + ' USB Reset', details, data.results.some(function(r) { return r.error; }) ? 'error' : 'success');
                        }
                        refreshDevicesList();
                    } else {
                        showToast(id + ' Error', data.error || 'Unknown error', 'error');
                    }
                })
                .catch(err => showToast(id + ' Error', 'Network error: ' + err.message, 'error'))
                .finally(() => {
                    if (span) span.innerText = origText;
                    if (btn) btn.disabled = false;
                });
            };

            // Send USSD request action
            ussdForm.addEventListener('submit', (e) => {
                e.preventDefault();
                const target = ussdTarget.value;
                const code = ussdInput.value;
                
                if (!target || !code) return;
                
                btnLabel.textContent = words.sending;
                btnSpinner.classList.remove('hidden');
                ussdSubmitBtn.disabled = true;
                
                const placeholderEl = document.getElementById('terminal-placeholder');
                if (placeholderEl && placeholderEl.parentNode) {
                    placeholderEl.parentNode.removeChild(placeholderEl);
                }
                
                const cmdLine = document.createElement('div');
                cmdLine.className = 'text-zinc-500 mt-2 border-t border-zinc-900 pt-2';
                cmdLine.textContent = `[${new Date().toLocaleTimeString()}] > exec-ussd -d ${target} -c ${code}`;
                terminalScreen.appendChild(cmdLine);
                terminalScreen.scrollTop = terminalScreen.scrollHeight;

                fetch('/api/gsm-dongles/ussd', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ dongle: target, code: code })
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        appendUssdResponse(data.logTime || new Date().toLocaleTimeString(), data.response, false);
                    } else {
                        const respLine = document.createElement('div');
                        respLine.className = 'text-rose-400 font-bold bg-rose-950/10 p-2 rounded border border-rose-900/20 mt-1';
                        respLine.textContent = `[System Error] ${data.error || words.sendUssdError}`;
                        terminalScreen.appendChild(respLine);
                        terminalScreen.scrollTop = terminalScreen.scrollHeight;
                    }
                })
                .catch(err => {
                    const errorLine = document.createElement('div');
                    errorLine.className = 'text-rose-500 font-bold mt-1';
                    errorLine.textContent = `[Network Error] ${err.message}`;
                    terminalScreen.appendChild(errorLine);
                    terminalScreen.scrollTop = terminalScreen.scrollHeight;
                })
                .finally(() => {
                    btnLabel.textContent = words.sendBtn;
                    btnSpinner.classList.add('hidden');
                    ussdSubmitBtn.disabled = false;
                });
            });

            // WebSocket live USSD responses capture
            if (socket) {
                socket.on('ussdResponse', (data) => {
                    if (ussdTarget.value.toLowerCase() === data.dongleId.toLowerCase()) {
                        appendUssdResponse(data.logTime, data.text, true);
                    }
                });

                socket.on('dongleNumberUpdated', (data) => {
                    const btn = document.getElementById('resetBtn-' + data.dongleId);
                    if (btn) {
                        const span = btn.querySelector('span');
                        if (span) span.innerText = words.resetUsbBtn;
                        btn.disabled = false;
                    }
                    refreshDevicesList();
                });

                socket.on('dongleProvisionResult', (data) => {
                    if (data.results) {
                        let details = data.results.map(function(r) {
                            const status = r.error ? '❌' : '✅';
                            return status + ' ' + r.step + (r.error ? ': ' + r.error : '');
                        }).join('\n');
                        showToast(data.dongleId + ' AT Results', details, data.results.some(function(r) { return r.error; }) ? 'error' : 'success');
                    }
                    refreshDevicesList();
                });
            }

            // Refresh Device List AJAX helper
            function refreshDevicesList() {
                globalRefreshBtn.disabled = true;
                
                fetch('/api/gsm-dongles')
                    .then(res => res.json())
                    .then(data => {
                        if (data.success && data.devices) {
                            loadedDevices = data.devices;
                            
                            const tbody = document.getElementById('dongles-table-body');
                            tbody.innerHTML = '';
                            
                            const currentSelected = selectedDongleId || ussdTarget.value;
                            const nextSelected = loadedDevices.some(d => d.ID === currentSelected)
                                ? currentSelected
                                : (loadedDevices[0] ? loadedDevices[0].ID : '');
                            ussdTarget.innerHTML = '';
                            
                            const placeholderOpt = document.createElement('option');
                            placeholderOpt.value = "";
                            placeholderOpt.disabled = true;
                            placeholderOpt.hidden = true;
                            placeholderOpt.textContent = words.selectPlaceholder;
                            if (!nextSelected) {
                                placeholderOpt.selected = true;
                            }
                            ussdTarget.appendChild(placeholderOpt);
                            
                            if (loadedDevices.length === 0) {
                                tbody.innerHTML = `<tr><td colspan="7" class="py-8 text-center text-[var(--text-muted)]">${words.noDongles}</td></tr>`;
                                return;
                            }
                            
                            loadedDevices.forEach(d => {
                                const st = d.State.toLowerCase();
                                const isGsmNotResponding = st.includes('gsm') && st.includes('not responding');
                                const isNotInitializing = st.includes('not initializing');
                                const isNotRegistered = st.includes('not registered');
                                const isFree = st === 'free';
                                const isNotConnected = st.includes('not connect') || st === 'not_connected';
                                const isError = isGsmNotResponding || isNotRegistered;
                                const stateClass = isFree ? 'text-green-500 font-bold' : isError ? 'text-[var(--accent-color)] font-bold' : isNotInitializing ? 'text-amber-500 font-bold' : isNotConnected ? 'text-zinc-500' : 'text-amber-500';
                                const badgeClass = isFree ? 'bg-green-500' : isError ? 'bg-[var(--accent-color)]' : isNotInitializing ? 'bg-amber-500' : isNotConnected ? 'bg-zinc-600' : 'bg-amber-500';
                                let stateWords = d.State;
                                
                                const tr = document.createElement('tr');
                                tr.className = 'border-b border-[var(--border-primary)]/50 hover:bg-[var(--bg-hover)]/20 transition-colors';
                                tr.id = 'row-' + d.ID;
                                tr.style.cursor = 'pointer';
                                tr.innerHTML = `
                                    <td class="py-3.5 px-4 font-mono font-black text-[var(--text-primary)]">${d.ID}</td>
                                    <td class="py-3.5 px-4 text-[var(--text-primary)] font-medium">${d['Provider Name'] || 'NONE'}</td>
                                    <td class="py-3.5 px-4 text-[var(--text-primary)] tracking-[0.08em] font-medium">
                                        <div class="flex items-center gap-2">
                                            <span id="display-num-${d.ID}">${d.Number || 'Unknown'}</span>
                                            <div class="flex items-center gap-1">
                                                ${(d.Number && d.Number !== 'Unknown') ? `<button onclick="copyToClipboard('${d.Number}', this)" class="text-[var(--text-muted)] hover:text-white hover:bg-zinc-800 p-1 rounded transition cursor-pointer" title="${isRtl ? 'نسخ الرقم' : 'Copy Number'}"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg></button>` : ''}
                                                <button onclick="editSimNumber('${d.ID}', '${d.IMSI}', '${(d.Number && d.Number !== 'Unknown') ? d.Number : ''}')" class="text-[var(--text-muted)] hover:text-white hover:bg-zinc-800 p-1 rounded transition cursor-pointer" title="${isRtl ? 'تعديل الرقم' : 'Edit Number'}">
                                                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4z"></path></svg>
                                                </button>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="py-3.5 px-4 text-xs text-[var(--text-primary)] tracking-[0.12em] font-semibold">
                                        <div class="flex items-center gap-1.5">
                                            <span>${d.IMEI || '-'}</span>
                                            ${(d.IMEI && d.IMEI !== '-') ? `<button onclick="copyToClipboard('${d.IMEI}', this)" class="text-[var(--text-muted)] hover:text-white hover:bg-zinc-800 p-1 rounded transition cursor-pointer" title="${isRtl ? 'نسخ IMEI' : 'Copy IMEI'}"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg></button>` : ''}
                                        </div>
                                    </td>
                                    <td class="py-3.5 px-4">
                                         <div class="flex items-center gap-2">
                                             ${function() {
                                                 if (isFree) {
                                                     return `<span class="dongle-status-pill inline-flex items-center bg-green-900/20 text-green-400 rounded-full px-2.5 py-0.5 text-xs font-medium border border-green-900/30"><span class="h-1.5 w-1.5 rounded-full bg-green-500 mr-1.5 shrink-0"></span>${stateWords}</span>`;
                                                 } else if (isError) {
                                                     return `<span class="dongle-status-pill inline-flex items-center bg-red-900/20 text-red-400 rounded-full px-2.5 py-0.5 text-xs font-medium border border-red-900/30"><span class="h-1.5 w-1.5 rounded-full bg-red-500 mr-1.5 shrink-0"></span>${stateWords}</span>`;
                                                 } else if (isNotConnected) {
                                                     return `<span class="dongle-status-pill inline-flex items-center bg-red-500/10 text-red-500 rounded-full px-2.5 py-0.5 text-xs font-medium border border-red-500/20"><span class="h-1.5 w-1.5 rounded-full bg-red-500 mr-1.5 shrink-0"></span>${stateWords}</span>`;
                                                 } else {
                                                     return `<span class="dongle-status-pill inline-flex items-center bg-amber-900/20 text-amber-400 rounded-full px-2.5 py-0.5 text-xs font-medium border border-amber-900/30"><span class="h-1.5 w-1.5 rounded-full bg-amber-500 mr-1.5 shrink-0"></span>${stateWords}</span>`;
                                                 }
                                             }()}
                                         </div>
                                    </td>
                                    <td class="py-3.5 px-4">
                                        <div class="flex items-center gap-2">
                                            <span class="font-mono text-xs">${d.RSSI || '0'}</span>
                                            <svg width="54" height="28" viewBox="0 0 54 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                ${function(){var rv=parseInt(d.RSSI)||0;var bars='';var th=[1,5,9,13,18,23,28];var hh=[4,8,12,16,20,24,28];for(var i=0;i<7;i++){var x=i*8;var h=hh[i];var y=28-h;var f=rv>=th[i]?'var(--accent-color)':'var(--border-primary)';bars+='<rect x="'+x+'" y="'+y+'" width="6" height="'+h+'" rx="1" fill="'+f+'"/>'}return bars}()}
                                            </svg>
                                        </div>
                                    </td>
                                    <td class="dongle-actions-cell py-3.5 px-4 text-center">
                                        <div class="flex items-center justify-center gap-1.5">
                                        <button onclick="reloadDongle('${d.ID}')" class="dongle-action-button dongle-action-primary font-medium focus:ring-2 focus:ring-red-500 focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed rounded-lg px-2.5 py-1 text-xs cursor-pointer gap-1" title="${words.refreshBtn}">
                                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"></path>
                                            </svg>
                                            ${words.refreshBtn}
                                        </button>
                                        <button id="resetBtn-${d.ID}" onclick="resetUsbPort('${d.ID}')" class="dongle-action-button dongle-action-secondary font-medium focus:ring-2 focus:ring-red-500 focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed rounded-lg px-2.5 py-1 text-xs cursor-pointer gap-1" title="${words.resetUsbBtn}">
                                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/>
                                            </svg>
                                            <span>${words.resetUsbBtn}</span>
                                        </button>
                                        </div>
                                    </td>
                                `;
                                tbody.appendChild(tr);
                                
                                tr.addEventListener('click', (e) => {
                                    if (e.target.closest('button')) return;
                                    selectDevice(d.ID);
                                });
                                
                                const opt = document.createElement('option');
                                opt.value = d.ID;
                                opt.textContent = `${d.ID} (${d.Number || 'Unknown'})`;
                                if (d.ID === nextSelected) {
                                    opt.selected = true;
                                }
                                ussdTarget.appendChild(opt);
                            });
                            
                            if (nextSelected) selectDevice(nextSelected);
                        }
                    })
                    .catch(err => console.error('Error refreshing devices:', err))
                    .finally(() => { globalRefreshBtn.disabled = false; });
            }

            globalRefreshBtn.addEventListener('click', refreshDevicesList);
            setInterval(refreshDevicesList, 1000);
        });
    </script>
</body>
</html>
