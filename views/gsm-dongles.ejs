                </h3>
                
                <div class="flex items-center gap-4 text-xs font-semibold select-none <%= isRtl ? 'flex-row-reverse' : '' %>">
                    <div class="flex items-center gap-2">
                        <span><%= t.logToggle %></span>
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" id="logs-toggle-switch" class="sr-only peer">
                            <div class="w-8 h-4 bg-zinc-800 rounded-full peer peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-0.5 after:left-[2px] after:bg-white after:border-zinc-300 after:border after:rounded-full after:h-3 after:w-3 after:transition-all peer-checked:bg-[var(--accent-color)]"></div>
                        </label>
                    </div>
                    
                    <label class="flex items-center gap-1.5 cursor-pointer">
                        <input type="checkbox" id="logs-autoscroll-chk" checked class="accent-[var(--accent-color)] rounded font-bold">
                        <span><%= t.autoscroll %></span>
                    </label>
                    
                    <button id="clear-logs-btn" class="text-zinc-500 hover:text-white transition cursor-pointer font-bold uppercase tracking-wider"><%= t.clearBtn %></button>
                </div>
            </div>
            
            <div class="log-screen p-5 text-[10px] text-zinc-500 flex flex-col gap-1.5 rounded-b-2xl hidden" id="log-screen-console">
                <div class="text-zinc-600">[System] Stream listener initialized. Awaiting hardware events...</div>
