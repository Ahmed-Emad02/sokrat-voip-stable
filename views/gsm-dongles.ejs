                    <span id="sms-modal-time" class="text-zinc-500 font-mono"></span>
                </div>
                <!-- Content Area -->
                <div class="bg-zinc-900/40 border border-zinc-900/60 p-4 rounded-xl max-h-[250px] overflow-y-auto">
                    <p id="sms-modal-content" class="text-sm text-[var(--text-secondary)] leading-relaxed select-text whitespace-pre-wrap font-sans"></p>
                </div>
            </div>
            <!-- Modal Footer -->
