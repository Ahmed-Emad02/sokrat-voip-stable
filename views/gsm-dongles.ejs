                        <div class="flex justify-between items-center border-b border-[var(--border-primary)]/30 pb-1.5"><span class="text-[var(--text-muted)]"><%= t.firmware %>:</span> <span id="info-firmware" class="font-mono text-zinc-400">-</span></div>
                        
                        <div class="flex justify-between items-center border-b border-[var(--border-primary)]/30 pb-1.5">
                            <span class="text-[var(--text-muted)]"><%= t.thIMEI %>:</span>
