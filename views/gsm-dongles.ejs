        </div>

    </div>

    <!-- Toast Notification Container -->
    <div id="toast-container" class="fixed bottom-5 right-5 z-[200] flex flex-col gap-2.5 max-w-sm pointer-events-none"></div>

    <!-- SMS Detail Modal -->
    <div id="sms-modal" class="fixed inset-0 z-[100] flex items-center justify-center bg-black/60 backdrop-blur-sm opacity-0 pointer-events-none transition-all duration-200">
        <div id="sms-modal-card" class="bg-zinc-950 border border-zinc-900 rounded-2xl w-full max-w-lg p-6 shadow-2xl scale-95 opacity-0 transition-all duration-200 flex flex-col gap-4 mx-4">
            <!-- Modal Header -->
            <div class="flex items-center justify-between border-b border-zinc-900 pb-3">
                <h3 class="text-lg font-bold text-white flex items-center gap-2">
                    <svg class="text-[var(--accent-color)]" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                    </svg>
                    <span id="sms-modal-title"><%= isRtl ? 'تفاصيل الرسالة' : 'SMS Message Details' %></span>
                </h3>
                <button onclick="closeSmsModal()" class="text-zinc-500 hover:text-white transition cursor-pointer p-1 rounded-lg hover:bg-zinc-900">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
            </div>
            <!-- Modal Body -->
            <div class="flex flex-col gap-3.5">
                <!-- Meta Row -->
                <div class="flex flex-wrap items-center justify-between gap-2 text-xs">
                    <div class="flex items-center gap-2">
                        <span id="sms-modal-dongle" class="bg-[var(--accent-color)] text-white font-mono font-bold px-2 py-0.5 rounded text-[10px] uppercase"></span>
                        <span id="sms-modal-sender" class="text-white font-bold font-mono text-sm"></span>
                        <button id="sms-modal-copy-sender" class="text-zinc-500 hover:text-white p-0.5 rounded transition cursor-pointer" title="Copy Number">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                        </button>
