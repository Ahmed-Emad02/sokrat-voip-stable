                    </h3>
                    
                    <form id="ussd-execution-form" class="flex flex-col gap-4">
                        <div class="flex flex-col gap-2">
                            <label class="text-xs font-semibold text-[var(--text-secondary)]"><%= isRtl ? 'اختر شريحة الاتصال' : 'Target Dongle' %></label>
                            <select id="ussd-target-dongle" class="bg-[var(--bg-card)] border border-[var(--border-primary)] rounded-lg px-3 py-2 text-sm text-[var(--text-primary)] focus:outline-none focus:border-[var(--accent-color)] cursor-pointer" required>
