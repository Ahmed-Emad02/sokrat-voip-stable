                        <div class="flex justify-between items-center border-b border-[var(--border-primary)]/30 pb-1.5"><span class="text-[var(--text-muted)]"><%= t.submode %>:</span> <span id="info-submode" class="font-bold text-white">-</span></div>
                    </div>
