                    <div class="terminal-screen p-4 flex-1 overflow-y-auto text-xs text-emerald-400 font-mono flex flex-col gap-2 rounded-b-2xl" id="terminal-screen">
                        <div class="text-green-400 font-mono text-sm select-none" id="terminal-placeholder">
                            <%= t.terminalPlaceholder %>
