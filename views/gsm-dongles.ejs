                </div>

                <!-- USSD Terminal Display -->
                <div class="panel-surface rounded-2xl flex flex-col h-[260px]">
                    <div class="px-4 py-3 border-b border-[var(--border-primary)] flex items-center justify-between shrink-0 bg-black/40 rounded-t-2xl">
                        <div class="flex items-center gap-1.5">
