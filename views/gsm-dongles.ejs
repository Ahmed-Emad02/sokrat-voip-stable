                            <div class="flex items-center bg-[var(--bg-card)] border border-[var(--border-primary)] rounded-lg px-3 focus-within:border-[var(--accent-color)] transition-colors">
                                <span class="text-[var(--accent-color)] font-bold font-mono text-sm leading-none select-none me-1">&gt;</span>
